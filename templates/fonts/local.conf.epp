<?xml version='1.0'?>
<!DOCTYPE fontconfig SYSTEM 'fonts.dtd'>
<fontconfig>
  <match target="font">
    <edit name="rgba" mode="assign">
      <const><%= $subpixel_rendering %></const>
    </edit>
<% if $subpixel_rendering != 'none' { -%>

    <edit name="lcdfilter" mode="assign">
      <const>lcddefault</const>
    </edit>
<% } -%>
  </match>
</fontconfig>
