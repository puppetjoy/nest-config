+def is_dev_board(board: str | None = None) -> bool:
+    board = (board or board_name()).strip() or DEFAULT_BOARD
+    return board != DEFAULT_BOARD
+
+
+def notification_board_label(board: str | None = None) -> str:
+    board = (board or board_name()).strip() or DEFAULT_BOARD
+    return f"🧪 DEV {board}" if is_dev_board(board) else ""
+
+
+def _safe_callback_board(board: str) -> str:
+    board = (board or "").strip()
+    if not re.fullmatch(r"[A-Za-z0-9_.-]{1,48}", board):
+        return ""
+    return board
+
+
+def parse_callback_token(token: str) -> tuple[str, str]:
+    raw = clean_text(token, max_len=120).strip()
+    if ":" not in raw:
+        return "", raw
+    maybe_board, maybe_token = raw.split(":", 1)
+    board = _safe_callback_board(maybe_board)
+    if not board or not maybe_token.strip():
+        return "", raw
+    return board, maybe_token.strip()
+
+
+@contextmanager
+def scoped_board(board: str):
+    board = _safe_callback_board(board)
+    old = os.environ.get("AGENT_REQUEST_KANBAN_BOARD")
+    try:
+        if board:
+            os.environ["AGENT_REQUEST_KANBAN_BOARD"] = board
+        yield
+    finally:
+        if old is None:
+            os.environ.pop("AGENT_REQUEST_KANBAN_BOARD", None)
+        else:
+            os.environ["AGENT_REQUEST_KANBAN_BOARD"] = old
+
+
