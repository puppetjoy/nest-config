+def test_prod_board_notifications_remain_clean_and_voice_summary_has_no_dev_label():
+    if not require_hermes_src():
+        return
+    with kanban_env("agent-requests") as tmp:
+        from agent_request_broker import common
+        from agent_request_broker import kanban_backend as backend
+
+        old_send = backend.telegram_send
+        deliveries = []
+
+        def fake_send(message, *, profile="", reply_markup=None, disable_notification=None):
+            deliveries.append({"message": message, "reply_markup": reply_markup})
+            return {"sent": True, "test": True, "message_id": len(deliveries)}
+
+        backend.telegram_send = fake_send
+        try:
+            talon = load_tool("talon", tmp)
+            submitted = call(talon.agent_request_submit_tool({
+                "title": "Prod board clean label smoke",
+                "request": "Verify production notifications are not labeled as dev.",
+                "target": "star",
+            }))
+            request = submitted["request"]
+            assert submitted["board"] == "agent-requests"
+            assert deliveries
+            assert all(not delivery["message"].startswith("🧪 DEV") for delivery in deliveries)
+            assert all("Board: agent-requests" not in delivery["message"] for delivery in deliveries)
+            assert "DEV" not in common._voice_summary_for_notification(deliveries[-1]["message"])
+
+            star = load_tool("star", tmp)
+            call(star.agent_request_propose_tool({
+                "request_id": request["id"],
+                "summary": "approval-required: prod board clean label smoke",
+                "proposal": "After approval, Star will complete the harmless prod-board smoke.",
+            }))
+            markup = [delivery["reply_markup"] for delivery in deliveries if delivery["reply_markup"]][-1]
+            callback_data = markup["inline_keyboard"][0][0]["callback_data"]
+            assert callback_data.startswith("ar:")
+            assert not callback_data.startswith("ar:agent-requests:")
+        finally:
+            backend.telegram_send = old_send
+
+
+def test_dev_board_notifications_are_labeled_and_callbacks_route_to_dev_board():
+    if not require_hermes_src():
+        return
+    with kanban_env("agent-requests-dev") as tmp:
+        from agent_request_broker import common
+        from agent_request_broker import kanban_backend as backend
+
+        old_send = backend.telegram_send
+        deliveries = []
+
+        def fake_send(message, *, profile="", reply_markup=None, disable_notification=None):
+            deliveries.append({
+                "message": message,
+                "profile": profile,
+                "reply_markup": reply_markup,
+                "disable_notification": disable_notification,
+            })
+            return {
+                "sent": True,
+                "test": True,
+                "profile": profile,
+                "disable_notification": disable_notification,
+                "message_id": len(deliveries),
+            }
+
+        backend.telegram_send = fake_send
+        try:
+            talon = load_tool("talon", tmp)
+            submitted = call(talon.agent_request_submit_tool({
+                "title": "Dev board label smoke",
+                "request": "Verify dev-board notifications and callbacks stay on the dev board.",
+                "target": "star",
+            }))
+            request = submitted["request"]
+            assert submitted["board"] == "agent-requests-dev"
+            assert deliveries
+            assert all(delivery["message"].startswith("🧪 DEV agent-requests-dev") for delivery in deliveries)
+            assert all("Board: agent-requests-dev" in delivery["message"] for delivery in deliveries)
+            assert "DEV agent-requests-dev" in common._voice_summary_for_notification(deliveries[-1]["message"])
+
+            star = load_tool("star", tmp)
+            proposed = call(star.agent_request_propose_tool({
+                "request_id": request["id"],
+                "summary": "approval-required: dev board label smoke",
+                "proposal": "After approval, Star will complete the harmless dev-board smoke.",
+            }))
+            assert proposed["request"]["approval_status"] == "proposed"
+
+            markup = [delivery["reply_markup"] for delivery in deliveries if delivery["reply_markup"]][-1]
+            callback_data = markup["inline_keyboard"][0][0]["callback_data"]
+            assert callback_data.startswith("ar:agent-requests-dev:")
+            callback_token = callback_data.split(":", 1)[1]
+
+            conn = backend.connect()
+            try:
+                rows = conn.execute(
+                    "SELECT action, detail FROM agent_request_notifications WHERE task_id = ? ORDER BY created_at, event_key",
+                    (request["kanban_task_id"],),
+                ).fetchall()
+            finally:
+                conn.close()
+            details = [json.loads(row["detail"]) for row in rows]
+            assert details
+            assert all(detail["board"] == "agent-requests-dev" for detail in details)
+
+            os.environ["AGENT_REQUEST_KANBAN_BOARD"] = "agent-requests"
+            approved = backend.handle_telegram_callback(callback_token, actor="joy")
+            assert approved["ok"] is True
+            assert approved["result"]["board"] == "agent-requests-dev"
+            assert os.environ["AGENT_REQUEST_KANBAN_BOARD"] == "agent-requests"
+
+            conn = backend.connect()
+            try:
+                assert backend.index_for_request(conn, request["id"]) is None
+            finally:
+                conn.close()
+        finally:
+            backend.telegram_send = old_send
+
