+def test_failure_counter_auto_block_notifies_agent_request_dispatch_hook(
+    kanban_home,
+    all_assignees_spawnable,
+    monkeypatch,
+):
+    """Circuit-breaker blocks should wake request-aware notifications.
+
+    Native Kanban subscriptions already see the ``gave_up`` event. The
+    agent-request UX also needs an event-driven broker notification for this
+    auto-block path so action-needed tasks do not silently wait on Joy.
+    """
+    notifications = []
+
+    fake_backend = SimpleNamespace(
+        notify_kanban_event=lambda **kwargs: notifications.append(kwargs) or {"notified": True},
+    )
+    fake_package = SimpleNamespace(kanban_backend=fake_backend)
+    monkeypatch.setitem(sys.modules, "agent_request_broker", fake_package)
+
+    def _bad_spawn(task, ws):
+        raise RuntimeError("iteration budget exhausted")
+
+    conn = kb.connect()
+    try:
+        tid = kb.create_task(conn, title="x", assignee="worker")
+
+        kb.dispatch_once(conn, spawn_fn=_bad_spawn)
+        assert not [n for n in notifications if n["action"] == "blocked"]
+
+        kb.dispatch_once(conn, spawn_fn=_bad_spawn)
+        task = kb.get_task(conn, tid)
+        assert task.status == "blocked"
+    finally:
+        conn.close()
+
+    blocked = [n for n in notifications if n["action"] == "blocked"]
+    assert len(blocked) == 1
+    assert blocked[0]["task_id"] == tid
+    assert blocked[0]["actor"] == "dispatcher"
+    assert "Task auto-blocked after" in blocked[0]["summary"]
+    assert blocked[0]["event_id"] is not None
 
 
