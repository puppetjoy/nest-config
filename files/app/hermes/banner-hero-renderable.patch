+def _banner_markup(markup: str) -> Text:
+    """Parse one-line banner markup into a Rich Text renderable."""
+    return Text.from_markup(markup, emoji=False)
+
+
+def _banner_hero_renderable(hero: str) -> Text:
+    """Render fixed-grid hero art as a non-wrapping renderable.
+
+    Rich treats multiline markup strings in center-justified table cells as
+    independent lines to measure and justify, which shifts sparse half-block
+    art rows and corrupts the terminal cell grid. Parsing the hero into a
+    Text renderable before adding it to the table preserves the original cell
+    positions.
+    """
+    text = Text.from_markup(hero, emoji=False, overflow="ignore")
+    text.no_wrap = True
+    return text
+
