+def _banner_hero_renderable(hero: str):
+    """Render banner hero art without mixing it into surrounding markup.
+
+    Skins document banner_hero as Rich markup, but some terminal art is
+    authored as ANSI because that preserves exact half-block foreground and
+    background state. Keep the hero as its own Rich renderable so Rich can
+    either parse markup or decode ANSI before the table measures/renders it.
+    Concatenating raw ANSI or large markup art into the surrounding banner
+    string lets terminal/control state and line measurement interact with
+    adjacent text.
+    """
+    if "\x1b" in hero:
+        decoded = list(AnsiDecoder().decode(hero))
+        return Group(*decoded) if decoded else Text("")
+    return Text.from_markup(hero)
+
+
+def _banner_markup(markup: str) -> Text:
+    """Parse regular one-line banner markup into a Rich Text renderable."""
+    return Text.from_markup(markup)
 
 
