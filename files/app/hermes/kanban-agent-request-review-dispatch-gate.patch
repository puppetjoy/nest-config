+    kanban_home, all_assignees_spawnable
+):
+    spawns = []
+
+    def fake_spawn(task, workspace):
+        spawns.append((task.id, task.assignee))
+
+    with kb.connect() as conn:
+        review = kb.create_task(
+            conn,
+            title="agent-request review handoff",
+            assignee="talon",
+            tenant="agent-requests",
+        )
+        normal = kb.create_task(conn, title="normal review", assignee="talon")
+        conn.execute("UPDATE tasks SET status = 'review' WHERE id IN (?, ?)", (review, normal))
+
+        res = kb.dispatch_once(conn, spawn_fn=fake_spawn, dispatcher_profile="talon")
+
