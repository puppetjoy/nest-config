+        finally:
+            conn.close()
+
+        reminded = call(talon.agent_request_remind_tool({
+            "request_id": request["id"],
+            "min_interval_seconds": 4 * 60 * 60,
+        }))
+        assert reminded["reminded"] is False
+        assert reminded["notification"]["notified"] is False
+        assert reminded["notification"]["notifications"]
