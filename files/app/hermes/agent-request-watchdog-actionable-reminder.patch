+def test_watchdog_reminder_resends_actionable_notification_with_rate_limit():
+    if not require_hermes_src():
+        return
+    from agent_request_broker import kanban_backend as backend
+
+    with kanban_env() as tmp:
+        old_send = backend.telegram_send
+        deliveries = []
+
+        def fake_send(message, *, profile="", reply_markup=None, disable_notification=None):
+            deliveries.append({
+                "message": message,
+                "profile": profile,
+                "reply_markup": reply_markup,
+                "disable_notification": disable_notification,
+            })
+            return {
+                "sent": True,
+                "test": True,
+                "profile": profile,
+                "disable_notification": disable_notification,
+                "message_id": len(deliveries),
+            }
+
+        try:
+            backend.telegram_send = fake_send
+            talon = load_tool("talon", tmp)
+            submitted = call(talon.agent_request_submit_tool({
+                "title": "Watchdog reminder smoke",
+                "request": "Verify watchdog can resend actionable notifications.",
+                "target": "star",
+            }))
+            request = submitted["request"]
+            star = load_tool("star", tmp)
+            proposed = call(star.agent_request_propose_tool({
+                "request_id": request["id"],
+                "summary": "approval-required: watchdog reminder smoke",
+                "proposal": "Approve the harmless reminder smoke.",
+            }))
+            assert proposed["request"]["approval_status"] == "proposed"
+            original_actionable_count = len([delivery for delivery in deliveries if delivery["reply_markup"]])
+
+            skipped = call(talon.agent_request_remind_tool({
+                "request_id": request["id"],
+                "min_interval_seconds": 4 * 60 * 60,
+            }))
+            assert skipped["reminded"] is False
+            assert skipped["reason"] == "recent Joy-visible actionable notification already delivered"
+            assert len([delivery for delivery in deliveries if delivery["reply_markup"]]) == original_actionable_count
+
+            conn = backend.connect()
+            try:
+                conn.execute(
+                    "UPDATE agent_request_notifications SET created_at = created_at - 120 WHERE task_id = ? AND action = 'proposed'",
+                    (request["kanban_task_id"],),
+                )
+                conn.commit()
+            finally:
+                conn.close()
+
+            reminded = call(talon.agent_request_remind_tool({
+                "request_id": request["id"],
+                "min_interval_seconds": 60,
+            }))
+            assert reminded["reminded"] is True
+            assert reminded["action"] == "proposed"
+            reminder_actionable = [delivery for delivery in deliveries if delivery["reply_markup"]][original_actionable_count:]
+            assert reminder_actionable
+            assert all(delivery["disable_notification"] is False for delivery in reminder_actionable)
+            labels = [
+                button["text"]
+                for row in reminder_actionable[-1]["reply_markup"]["inline_keyboard"]
+                for button in row
+            ]
+            assert labels == ["✅ Approve", "❌ Deny", "✏️ Steer / request changes"]
+            assert "Watchdog reminder" in reminder_actionable[-1]["message"]
+        finally:
+            backend.telegram_send = old_send
+
