+        request = submitted["request"]
+        star = load_tool("star", tmp)
+        call(star.agent_request_propose_tool({
+            "request_id": request["id"],
+            "summary": "approval-required: dry-run reminder smoke",
+            "proposal": "Approve the harmless dry-run reminder smoke.",
+        }))
+
+        conn = backend.connect()
+        try:
+            assert conn.execute(
+                "SELECT COUNT(*) FROM agent_request_notifications WHERE task_id = ? AND action = 'proposed' AND delivered = 1",
+                (request["kanban_task_id"],),
