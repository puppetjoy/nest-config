+def _notification_detail_is_joy_visible(detail: str) -> bool:
+    try:
+        parsed = json.loads(detail or "{}")
+    except json.JSONDecodeError:
+        return False
+    return bool(parsed.get("sent")) and not bool(parsed.get("dry_run"))
+
+
+def latest_joy_visible_notification(
+    conn: Any,
+    *,
+    task_id: str,
+    action: str,
+    delivery_profile: str | None = None,
+) -> dict[str, Any] | None:
+    sql = """
+        SELECT event_key, request_id, task_id, action, delivered, detail, created_at
+        FROM agent_request_notifications
+        WHERE task_id = ?
+          AND action = ?
+          AND delivered = 1
+    """
+    params: list[Any] = [task_id, action]
+    if delivery_profile:
+        sql += " AND event_key LIKE ?"
+        params.append(f"%:{delivery_profile}")
+    sql += " ORDER BY created_at DESC LIMIT 20"
+    for row in conn.execute(sql, params).fetchall():
+        data = dict(row)
+        if _notification_detail_is_joy_visible(data.get("detail") or ""):
+            return data
+    return None
+
+
+def actionable_reminder_action(conn: Any, item: AgentRequestIndex, task: Any | None = None) -> str:
+    task = task or require_kanban().get_task(conn, item.task_id)
+    if task is None:
+        return ""
+    if item.status == "proposed" and task.status == "blocked" and latest_proposal(conn, item.request_id):
+        return "proposed"
+    if item.status in {REVIEW_REQUESTED, "reviewing"} and task.status == "review" and latest_review(conn, item.request_id):
+        return REVIEW_REQUESTED
+    if item.status == "needs_info" and task.status == "blocked":
+        return "needs_info"
+    if task.status == "blocked" and item.status not in MAINTENANCE_STATUSES:
+        return "blocked"
+    return ""
+
+
+def remind_actionable_request(args: dict[str, Any], *, actor: str) -> dict[str, Any]:
+    request_id = clean_text(args.get("request_id"), max_len=80)
+    task_id = clean_text(args.get("task_id"), max_len=80)
+    min_interval_seconds = max(int(args.get("min_interval_seconds") or 4 * 60 * 60), 60)
+    if not request_id and not task_id:
+        return {"error": "request_id or task_id is required"}
+
+    conn = connect()
+    try:
+        item = index_for_request(conn, request_id) if request_id else index_for_task(conn, task_id)
+        if not item:
+            return {"error": "agent request not found"}
+        task = require_kanban().get_task(conn, item.task_id)
+        if task is None:
+            return {"error": f"Kanban task not found for request {item.request_id}: {item.task_id}"}
+
+        action = actionable_reminder_action(conn, item, task)
+        if not action:
+            return {
+                "request_id": item.request_id,
+                "task_id": item.task_id,
+                "reminded": False,
+                "reason": "request is not currently Joy-actionable",
+                "status": item.status,
+                "kanban_status": task.status,
+            }
+
+        visible_rows = [
+            latest_joy_visible_notification(conn, task_id=item.task_id, action=action, delivery_profile=profile)
+            for profile in notification_delivery_profiles(item, action)
+        ]
+        latest_visible = max((row for row in visible_rows if row), key=lambda row: int(row["created_at"]), default=None)
+        current = now_ts()
+        if latest_visible and current - int(latest_visible["created_at"]) < min_interval_seconds:
+            return {
+                "request_id": item.request_id,
+                "task_id": item.task_id,
+                "action": action,
+                "reminded": False,
+                "reason": "recent Joy-visible actionable notification already delivered",
+                "last_delivered_at": latest_visible["created_at"],
+                "next_allowed_at": int(latest_visible["created_at"]) + min_interval_seconds,
+            }
+
+        summary = (
+            "Watchdog reminder: this request is still waiting for Joy action. "
+            "Re-sending the normal actionable Agent Request notification."
+        )
+        notification = notify_kanban_event(
+            task_id=item.task_id,
+            action=action,
+            actor=actor,
+            summary=summary,
+        )
+        return {
+            "request_id": item.request_id,
+            "task_id": item.task_id,
+            "action": action,
+            "reminded": bool(notification.get("notified")),
+            "notification": notification,
+            "rate_limit_seconds": min_interval_seconds,
+        }
+    finally:
+        conn.close()
+
+
