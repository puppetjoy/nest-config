+def test_block_review_required_enters_review_lane_and_notifies(monkeypatch, worker_env):
+    from hermes_cli import kanban_db as kb
+    from tools import kanban_tools as kt
+
+    notifications = []
+
+    def capture_notification(_kb, _conn, **kwargs):
+        notifications.append(kwargs)
+
+    monkeypatch.setattr(kt, "_notify_agent_request_event", capture_notification)
+
+    reason = "review-required: source change needs Joy acceptance before deploy"
+    out = kt._handle_block({"reason": reason})
+    d = json.loads(out)
+    assert d["ok"] is True
+    assert d["status"] == "review"
+
+    conn = kb.connect()
+    try:
+        task = kb.get_task(conn, worker_env)
+        assert task is not None
+        assert task.status == "review"
+        events = kb.list_events(conn, worker_env)
+        last_event = events[-1]
+        assert last_event.kind == "review_requested"
+        assert isinstance(last_event.payload, dict)
+        assert last_event.payload["source"] == "kanban_block_review_required"
+        run = kb.latest_run(conn, worker_env)
+        assert run is not None
+        assert run.outcome == "review"
+    finally:
+        conn.close()
+
+    assert notifications == [
+        {
+            "task_id": worker_env,
+            "action": "review_requested",
+            "summary": reason,
+            "event_kind": "review_requested",
+        }
+    ]
+
