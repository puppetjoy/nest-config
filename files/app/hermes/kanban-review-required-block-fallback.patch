+def test_block_review_required_syncs_child_followup_request_status(monkeypatch, worker_env):
+    from hermes_cli import kanban_db as kb
+    from tools import kanban_tools as kt
+
+    seen = {}
+    fake_backend = types.ModuleType("agent_request_broker.kanban_backend")
+    setattr(fake_backend, "REVIEW_REQUESTED", "review_requested")
+
+    class FakeItem:
+        request_id = "req_child"
+
+    def fake_notifiable_index_for_task(_conn, task_id):
+        seen["notifiable_task_id"] = task_id
+        return FakeItem(), {"classification": "blocking", "parent_task_id": "t_parent"}
+
+    def fake_update_index_status(_conn, request_id, status):
+        seen["updated"] = (request_id, status)
+
+    setattr(fake_backend, "notifiable_index_for_task", fake_notifiable_index_for_task)
+    setattr(fake_backend, "update_index_status", fake_update_index_status)
+    fake_pkg = types.ModuleType("agent_request_broker")
+    setattr(fake_pkg, "kanban_backend", fake_backend)
+    monkeypatch.setitem(sys.modules, "agent_request_broker", fake_pkg)
+    monkeypatch.setitem(sys.modules, "agent_request_broker.kanban_backend", fake_backend)
+    monkeypatch.setattr(kt, "_notify_agent_request_event", lambda *_args, **_kwargs: None)
+
+    conn = kb.connect()
