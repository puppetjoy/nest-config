+def _review_required_reason(reason: Any) -> bool:
+    """Treat legacy review-required block handoffs as review requests.
+
+    Older worker guidance told agents to call ``kanban_block`` with a
+    ``review-required: ...`` reason for code changes needing Joy's eyes. Once
+    the board gained a dedicated review lane, that idiom should no longer leave
+    work in the generic blocked column.
+    """
+    text = str(reason or "").strip().lower()
+    return text.startswith(("review-required", "review_required", "review required"))
+
+
+def _mark_task_review_requested(kb, conn, task_id: str, *, summary: str, expected_run_id: Optional[int]) -> bool:
+    """Transition ``running/ready -> review`` for review-required handoffs."""
+    with kb.write_txn(conn):
+        if expected_run_id is None:
+            cur = conn.execute(
+                """
+                UPDATE tasks
+                   SET status       = 'review',
+                       claim_lock   = NULL,
+                       claim_expires= NULL,
+                       worker_pid   = NULL
+                 WHERE id = ?
+                   AND status IN ('running', 'ready')
+                """,
+                (task_id,),
+            )
+        else:
+            cur = conn.execute(
+                """
+                UPDATE tasks
+                   SET status       = 'review',
+                       claim_lock   = NULL,
+                       claim_expires= NULL,
+                       worker_pid   = NULL
+                 WHERE id = ?
+                   AND status IN ('running', 'ready')
+                   AND current_run_id = ?
+                """,
+                (task_id, int(expected_run_id)),
+            )
+        if cur.rowcount != 1:
+            return False
+        run_id = kb._end_run(
+            conn, task_id,
+            outcome="review", status="review",
+            summary=summary,
+        )
+        if run_id is None and summary:
+            run_id = kb._synthesize_ended_run(
+                conn, task_id,
+                outcome="review",
+                summary=summary,
+            )
+        kb._append_event(
+            conn, task_id, "review_requested",
+            {"summary": summary, "source": "kanban_block_review_required"},
+            run_id=run_id,
+        )
+        return True
+
+
+def _sync_agent_request_review_status(conn, task_id: str) -> None:
+    """Best-effort sync of request index state for review-required fallbacks."""
+    try:
+        from agent_request_broker import kanban_backend as agent_requests
+    except Exception:
+        return
+    try:
+        if conn.execute(
+            "SELECT name FROM sqlite_master WHERE type = 'table' AND name = 'agent_request_index'"
+        ).fetchone() is None:
+            return
+        item, _child_disposition = agent_requests.notifiable_index_for_task(conn, task_id)
+        if item:
+            agent_requests.update_index_status(conn, item.request_id, agent_requests.REVIEW_REQUESTED)
+    except Exception:
+        logger.exception("agent-request review status sync failed for %s", task_id)
+
