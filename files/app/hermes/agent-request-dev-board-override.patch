+def test_board_name_override_takes_precedence_over_profile_dotenv_board():
+    if not require_hermes_src():
+        return
+    with kanban_env("agent-requests"):
+        from agent_request_broker import kanban_backend as backend
+
+        old_override = os.environ.get("AGENT_REQUEST_KANBAN_BOARD_OVERRIDE")
+        old_board = os.environ.get("AGENT_REQUEST_KANBAN_BOARD")
+        try:
+            os.environ["AGENT_REQUEST_KANBAN_BOARD"] = "agent-requests"
+            os.environ["AGENT_REQUEST_KANBAN_BOARD_OVERRIDE"] = "agent-requests-dev"
+            assert backend.board_name() == "agent-requests-dev"
+        finally:
+            if old_override is None:
+                os.environ.pop("AGENT_REQUEST_KANBAN_BOARD_OVERRIDE", None)
+            else:
+                os.environ["AGENT_REQUEST_KANBAN_BOARD_OVERRIDE"] = old_override
+            if old_board is None:
+                os.environ.pop("AGENT_REQUEST_KANBAN_BOARD", None)
+            else:
+                os.environ["AGENT_REQUEST_KANBAN_BOARD"] = old_board
