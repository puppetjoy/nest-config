+def test_complete_prose_scan_classifies_legacy_board_ids(kanban_home):
+    """A real task id in the legacy/default DB is cross-board, not phantom."""
+    kb.create_board("agent-requests")
+    legacy = kb.connect(board="default")
+    try:
+        legacy_id = kb.create_task(legacy, title="legacy", assignee="star")
+    finally:
+        legacy.close()
+
+    conn = kb.connect(board="agent-requests")
+    try:
+        parent = kb.create_task(conn, title="parent", assignee="x")
+        ok = kb.complete_task(
+            conn, parent,
+            summary=f"See legacy/default Kanban task {legacy_id}",
+        )
+        assert ok is True
+        import json as _json
+        payloads = [
+            _json.loads(r["payload"])
+            for r in conn.execute(
+                "SELECT payload FROM task_events WHERE task_id=? AND kind=?",
+                (parent, "suspected_hallucinated_references"),
+            )
+        ]
+        assert len(payloads) == 1
+        payload = payloads[0]
+        assert payload["phantom_refs"] == []
+        assert payload["current_board"] == "agent-requests"
+        assert payload["cross_board_refs"] == [
+            {"id": legacy_id, "board": "default", "db": "legacy/default Kanban DB"}
+        ]
+    finally:
+        conn.close()
+
+
+def test_created_cards_remains_strictly_board_local(kanban_home):
+    """Cross-board ids still fail the explicit created_cards completion gate."""
+    kb.create_board("agent-requests")
+    legacy = kb.connect(board="default")
+    try:
+        legacy_id = kb.create_task(legacy, title="legacy", assignee="x")
+    finally:
+        legacy.close()
+
+    conn = kb.connect(board="agent-requests")
+    try:
+        parent = kb.create_task(conn, title="parent", assignee="x")
+        with pytest.raises(kb.HallucinatedCardsError):
+            kb.complete_task(
+                conn, parent,
+                summary="done",
+                created_cards=[legacy_id],
+            )
+        task = kb.get_task(conn, parent)
+        assert task is not None
+        assert task.status == "ready"
+    finally:
+        conn.close()
+
+
