+_AUTO_RESUME_HUMAN_BLOCKER_RE = re.compile(
+    r"^(approval-required|review-required|needs[_ -]?info|human-required)\b",
+    re.IGNORECASE,
+)
+
+
+def _latest_blocked_auto_resume_payload(
+    conn: sqlite3.Connection,
+    task_id: str,
+) -> tuple[Optional[dict[str, Any]], Optional[int], Optional[str]]:
+    row = conn.execute(
+        "SELECT payload, created_at FROM task_events "
+        "WHERE task_id = ? AND kind = 'blocked' "
+        "ORDER BY created_at DESC, id DESC LIMIT 1",
+        (task_id,),
+    ).fetchone()
+    if row is None:
+        return None, None, None
+    try:
+        payload = json.loads(row["payload"] or "{}")
+    except Exception:
+        return None, int(row["created_at"]), None
+    if not isinstance(payload, dict):
+        return None, int(row["created_at"]), None
+    reason = payload.get("reason")
+    if isinstance(reason, str) and _AUTO_RESUME_HUMAN_BLOCKER_RE.search(reason.strip()):
+        return None, int(row["created_at"]), reason
+    spec = payload.get("auto_resume")
+    if not isinstance(spec, dict) or spec.get("enabled", True) is False:
+        return None, int(row["created_at"]), reason if isinstance(reason, str) else None
+    return spec, int(row["created_at"]), reason if isinstance(reason, str) else None
+
+
+def _systemctl_show_service(
+    service: str,
+    *,
+    user: bool,
+    timeout: int = 10,
+) -> dict[str, str]:
+    cmd = ["systemctl"]
+    if user:
+        cmd.append("--user")
+    cmd.extend(["show", service, "-p", "ActiveState", "-p", "ActiveEnterTimestampUSec"])
+    proc = subprocess.run(
+        cmd,
+        check=False,
+        stdout=subprocess.PIPE,
+        stderr=subprocess.PIPE,
+        text=True,
+        timeout=timeout,
+    )
+    if proc.returncode != 0:
+        err = (proc.stderr or proc.stdout or "").strip()
+        return {"error": err or f"systemctl exited {proc.returncode}"}
+    result: dict[str, str] = {}
+    for line in proc.stdout.splitlines():
+        if "=" in line:
+            key, value = line.split("=", 1)
+            result[key] = value
+    return result
+
+
+def _service_restart_auto_resume_evidence(
+    spec: dict[str, Any],
+    *,
+    blocked_at: int,
+) -> tuple[bool, dict[str, Any]]:
+    service = spec.get("service")
+    if not isinstance(service, str) or not service.strip():
+        return False, {"reason": "missing service"}
+    scope = str(spec.get("scope", "user")).strip().lower()
+    if scope not in {"user", "system"}:
+        return False, {"reason": f"unsupported service scope {scope!r}"}
+    state = _systemctl_show_service(service.strip(), user=(scope == "user"))
+    if "error" in state:
+        return False, {"service": service, "scope": scope, **state}
+    active_state = state.get("ActiveState") or ""
+    active_enter_raw = state.get("ActiveEnterTimestampUSec") or "0"
+    try:
+        active_enter = int(active_enter_raw) // 1_000_000
+    except ValueError:
+        active_enter = 0
+    min_started_after = spec.get("started_after", blocked_at)
+    try:
+        min_started_after_int = int(min_started_after)
+    except (TypeError, ValueError):
+        min_started_after_int = blocked_at
+    evidence = {
+        "service": service,
+        "scope": scope,
+        "active_state": active_state,
+        "active_enter": active_enter,
+        "started_after": min_started_after_int,
+    }
+    return (
+        active_state == "active" and active_enter > min_started_after_int,
+        evidence,
+    )
+
+
+def _auto_resume_condition_satisfied(
+    spec: dict[str, Any],
+    *,
+    blocked_at: int,
+) -> tuple[bool, dict[str, Any]]:
+    kind = str(spec.get("kind", "")).strip().lower()
+    if kind in {"restart_required", "service_restarted"}:
+        return _service_restart_auto_resume_evidence(spec, blocked_at=blocked_at)
+    return False, {"reason": f"unsupported auto-resume kind {kind!r}"}
+
+
+def auto_resume_satisfied_blockers(conn: sqlite3.Connection) -> list[tuple[str, dict[str, Any]]]:
+    """Resume blocked tasks whose structured machine blocker is satisfied.
+
+    Only the latest ``blocked`` event may opt in via ``auto_resume`` metadata.
+    Free-text blockers, review/approval/needs-info blockers, and unsupported
+    condition kinds remain blocked so human decisions never get guessed away.
+    """
+    rows = conn.execute(
+        "SELECT id FROM tasks WHERE status = 'blocked' ORDER BY priority DESC, created_at ASC"
+    ).fetchall()
+    resumed: list[tuple[str, dict[str, Any]]] = []
+    for row in rows:
+        task_id = row["id"]
+        spec, blocked_at, _reason = _latest_blocked_auto_resume_payload(conn, task_id)
+        if spec is None or blocked_at is None:
+            continue
+        satisfied, evidence = _auto_resume_condition_satisfied(spec, blocked_at=blocked_at)
+        if not satisfied:
+            continue
+        if unblock_task(conn, task_id):
+            with write_txn(conn):
+                conn.execute(
+                    "INSERT INTO task_comments (task_id, author, body, created_at) "
+                    "VALUES (?, ?, ?, ?)",
+                    (
+                        task_id,
+                        "dispatcher",
+                        "Auto-resumed: structured blocker satisfied. Evidence: "
+                        + json.dumps(evidence, sort_keys=True),
+                        int(time.time()),
+                    ),
+                )
+                _append_event(conn, task_id, "auto_resumed", {"evidence": evidence})
+            resumed.append((task_id, evidence))
+    return resumed
+
