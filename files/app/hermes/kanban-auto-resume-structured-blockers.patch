+def test_dispatcher_auto_resumes_satisfied_blocker(kanban_home, monkeypatch):
+    with kb.connect() as conn:
+        tid = kb.create_task(conn, title="dispatcher restart", assignee="talon")
+        assert kb.block_task(
+            conn,
+            tid,
+            reason="deployment-required: restart Talon gateway",
+            auto_resume={
+                "kind": "restart_required",
+                "service": "hermes-gateway@talon.service",
+                "scope": "user",
+            },
+        )
+        blocked_event = conn.execute(
+            "SELECT created_at FROM task_events WHERE task_id = ? AND kind = 'blocked'",
+            (tid,),
+        ).fetchone()
+        active_enter = int(blocked_event["created_at"] + 5) * 1_000_000
+        monkeypatch.setattr(
+            kb,
+            "_systemctl_show_service",
+            lambda service, *, user, timeout=10: {
+                "ActiveState": "active",
+                "ActiveEnterTimestampUSec": str(active_enter),
+            },
+        )
+
+        result = kb.dispatch_once(conn, max_spawn=0)
+        task = kb.get_task(conn, tid)
+        auto_resumed_events = conn.execute(
+            "SELECT 1 FROM task_events WHERE task_id = ? AND kind = 'auto_resumed'",
+            (tid,),
+        ).fetchall()
+
+    assert result.auto_resumed and result.auto_resumed[0][0] == tid
+    assert task is not None
+    assert task.status == "ready"
+    assert len(auto_resumed_events) == 1
