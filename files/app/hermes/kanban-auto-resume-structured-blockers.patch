+def test_auto_resume_satisfied_restart_required_blocker(kanban_home, monkeypatch):
+    with kb.connect() as conn:
+        tid = kb.create_task(conn, title="restart me")
+        assert kb.block_task(
+            conn,
+            tid,
+            reason="deployment-required: restart Talon gateway",
+            auto_resume={
+                "kind": "restart_required",
+                "service": "hermes-gateway@talon.service",
+                "scope": "user",
+            },
+        )
+        blocked_event = conn.execute(
+            "SELECT created_at FROM task_events WHERE task_id = ? AND kind = 'blocked'",
+            (tid,),
+        ).fetchone()
+        active_enter = int(blocked_event["created_at"] + 5) * 1_000_000
+
+        monkeypatch.setattr(
+            kb,
+            "_systemctl_show_service",
+            lambda service, *, user, timeout=10: {
+                "ActiveState": "active",
+                "ActiveEnterTimestampUSec": str(active_enter),
+            },
+        )
+
+        resumed = kb.auto_resume_satisfied_blockers(conn)
+        task = kb.get_task(conn, tid)
+        comments = conn.execute(
+            "SELECT body FROM task_comments WHERE task_id = ? ORDER BY created_at",
+            (tid,),
+        ).fetchall()
+        events = conn.execute(
+            "SELECT kind FROM task_events WHERE task_id = ? ORDER BY id",
+            (tid,),
+        ).fetchall()
+
+    assert resumed and resumed[0][0] == tid
+    assert task is not None
+    assert task.status == "ready"
+    assert any("Auto-resumed" in row["body"] for row in comments)
+    assert "auto_resumed" in [row["kind"] for row in events]
+
