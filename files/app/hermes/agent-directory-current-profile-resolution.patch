+def test_register_honors_profile_name_environment(directory_env, monkeypatch):
+    from tools import agent_directory_tools as directory
+
+    monkeypatch.delenv("HERMES_PROFILE", raising=False)
+    monkeypatch.setenv("HERMES_PROFILE_NAME", "star")
+
+    result = _loads(directory._handle_register({"profile": "star", "mission": "shopping help"}))
+
+    assert result["ok"] is True
+    assert result["profile"] == "star"
+    assert result["action"] == "registered"
+
+    omitted = _loads(directory._handle_register({"mission": "shopping and browsing"}))
+    assert omitted["ok"] is True
+    assert omitted["profile"] == "star"
+    discovered = _loads(directory._handle_discover({"profile": "star"}))
+    assert discovered["agents"][0]["mission"] == "shopping and browsing"
+
+
+def test_register_infers_current_profile_from_named_hermes_home(directory_env, monkeypatch):
+    from tools import agent_directory_tools as directory
+
+    profile_home = directory_env / "profiles" / "star"
+    profile_home.mkdir(parents=True)
+    monkeypatch.setenv("HERMES_HOME", str(profile_home))
+    monkeypatch.setenv("HERMES_KANBAN_HOME", str(directory_env))
+    monkeypatch.delenv("HERMES_AGENT_DIRECTORY_PROFILE", raising=False)
+    monkeypatch.delenv("HERMES_PROFILE", raising=False)
+    monkeypatch.delenv("HERMES_PROFILE_NAME", raising=False)
+    monkeypatch.delenv("HERMES_KANBAN_ASSIGNEE", raising=False)
+
+    explicit = _loads(directory._handle_register({"profile": "star", "mission": "shopping help"}))
+    omitted = _loads(directory._handle_register({"mission": "shopping and browsing"}))
+
+    assert explicit["ok"] is True
+    assert explicit["profile"] == "star"
+    assert omitted["ok"] is True
+    assert omitted["profile"] == "star"
+
+    rejected = _loads(directory._handle_register({"profile": "talon", "mission": "ops"}))
+    assert "error" in rejected
+    assert "current profile ('star')" in rejected["error"]
+
+
