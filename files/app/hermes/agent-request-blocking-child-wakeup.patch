+def agent_request_task_completed(
+    conn: Any,
+    *,
+    task_id: str,
+    action_status: str,
+    actor: str,
+    summary: str,
+) -> dict[str, Any]:
+    init_index(conn)
+    item = index_for_task(conn, task_id)
+    if not item:
+        return {"request": None, "parent_updates": []}
+    update_index_status(conn, item.request_id, action_status)
+    parent_updates = sync_parent_requests_for_child_update(
+        conn,
+        child=item,
+        child_status=action_status,
+        actor=actor,
+        summary=summary,
+    )
+    refreshed = index_for_request(conn, item.request_id)
+    return {
+        "request": public_request(conn, refreshed) if refreshed else None,
+        "parent_updates": parent_updates,
+    }
