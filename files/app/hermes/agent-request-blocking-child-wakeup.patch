+def test_agent_request_task_completed_resumes_parent_after_kanban_completion():
+    if not require_hermes_src():
+        return
+    with kanban_env():
+        from agent_request_broker import kanban_backend as backend
+        from hermes_cli import kanban_db as kb
+
+        old_send = backend.telegram_send
+        messages = []
+        backend.telegram_send = lambda message, **_kw: messages.append(message) or {"sent": True, "test": True}
+        try:
+            parent = backend.submit({
+                "title": "Parent resumes after native kanban complete",
+                "request": "Wake me after the blocking child completes through kanban_complete.",
+                "target": "talon",
+            }, requester="star")["request"]
+            child = backend.submit({
+                "title": "Blocking child native completion",
+                "request": "Finish the prerequisite.",
+                "target": "star",
+                "parent_request_id": parent["id"],
+                "parent_child_classification": "blocking",
+                "parent_child_reason": "Parent cannot continue until this prerequisite is done.",
+            }, requester="talon")["request"]
+
+            conn = backend.connect()
+            try:
+                assert kb.complete_task(conn, child["kanban_task_id"], summary="Child completed through native Kanban tool")
+                completed = backend.agent_request_task_completed(
+                    conn,
+                    task_id=child["kanban_task_id"],
+                    action_status="completed",
+                    actor="star",
+                    summary="Child completed through native Kanban tool",
+                )
+                parent_item = backend.index_for_request(conn, parent["id"])
+                parent_task = kb.get_task(conn, parent["kanban_task_id"])
+            finally:
+                conn.close()
+
+            assert completed["parent_updates"]
+            assert completed["parent_updates"][0]["status"] == "in_progress"
+            assert parent_item.status == "in_progress"
+            assert parent_task.status != "blocked"
+            assert any("eligible to continue" in message for message in messages)
+        finally:
+            backend.telegram_send = old_send
+
+
+def test_completed_blocking_child_with_blocking_repair_relinks_parent_to_repair_path():
+    if not require_hermes_src():
+        return
+    with kanban_env():
+        from agent_request_broker import kanban_backend as backend
+        from hermes_cli import kanban_db as kb
+
+        old_send = backend.telegram_send
+        backend.telegram_send = lambda message, **_kw: {"sent": True, "test": True}
+        try:
+            parent = backend.submit({
+                "title": "Parent waits on current repair path",
+                "request": "Do not stale-wait on a done child if it spawns repair work.",
+                "target": "talon",
+            }, requester="star")["request"]
+            child = backend.submit({
+                "title": "Blocking child that finds repair",
+                "request": "Retest and create repair if still broken.",
+                "target": "star",
+                "parent_request_id": parent["id"],
+                "parent_child_classification": "blocking",
+                "parent_child_reason": "Parent cannot continue until retest/repair path is done.",
+            }, requester="talon")["request"]
+            repair = backend.submit({
+                "title": "Blocking repair follow-up",
+                "request": "Repair the failed retest.",
+                "target": "talon",
+                "parent_request_id": child["id"],
+                "parent_child_classification": "blocking",
+                "parent_child_reason": "The retest failed and requires repair before parent can continue.",
+            }, requester="star")["request"]
+
+            conn = backend.connect()
+            try:
+                assert kb.complete_task(conn, child["kanban_task_id"], summary="Retest finished but left a blocking repair follow-up.")
+                completed = backend.agent_request_task_completed(
+                    conn,
+                    task_id=child["kanban_task_id"],
+                    action_status="completed",
+                    actor="star",
+                    summary="Retest finished but left a blocking repair follow-up.",
+                )
+            finally:
+                conn.close()
+            assert completed["parent_updates"]
+            update = completed["parent_updates"][0]
+            assert update["status"] == backend.WAITING_ON_CHILD
+            assert repair["kanban_task_id"] in update["successor_blocking_children"]
+
+            conn = backend.connect()
+            try:
+                parent_item = backend.index_for_request(conn, parent["id"])
+                parent_task = kb.get_task(conn, parent["kanban_task_id"])
+                context = backend.completion_child_context(conn, parent_item)
+                blocking_open_ids = {row["child_task_id"] for row in context["blocking_open"]}
+            finally:
+                conn.close()
+
+            assert parent_item.status == backend.WAITING_ON_CHILD
+            assert parent_task.status == "blocked"
+            assert repair["kanban_task_id"] in blocking_open_ids
+            assert child["kanban_task_id"] not in blocking_open_ids
+        finally:
+            backend.telegram_send = old_send
+
+
