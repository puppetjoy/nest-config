+++ pb/src/agent_request_broker/kanban_backend.py	2026-06-06 04:13:31.147507408 -0400
@@ -168,10 +168,28 @@
     subject_display: str = ""
 
 
+def _board_from_hermes_kanban_db() -> str:
+    raw = os.environ.get("HERMES_KANBAN_DB", "").strip()
+    if not raw:
+        return ""
+    path = Path(raw)
+    if path.name != "kanban.db" or len(path.parts) < 3:
+        return ""
+    if path.parts[-3] != "boards":
+        return ""
+    return _safe_callback_board(path.parts[-2])
+
+
 def board_name() -> str:
     override = os.environ.get("AGENT_REQUEST_KANBAN_BOARD_OVERRIDE", "").strip()
     if override:
         return override
+    hermes_db_board = _board_from_hermes_kanban_db()
+    if hermes_db_board:
+        return hermes_db_board
+    hermes_board = os.environ.get("HERMES_KANBAN_BOARD", "").strip()
+    if hermes_board:
+        return hermes_board
     return os.environ.get("AGENT_REQUEST_KANBAN_BOARD", DEFAULT_BOARD).strip() or DEFAULT_BOARD
 
 
