+def test_hermes_kanban_db_board_takes_precedence_over_profile_dotenv_board_for_notifications():
+    if not require_hermes_src():
+        return
+    with kanban_env("agent-requests-dev") as tmp:
+        from agent_request_broker import common
+        from agent_request_broker import kanban_backend as backend
+
+        old_send = backend.telegram_send
+        deliveries = []
+
+        def fake_send(message, *, profile="", reply_markup=None, disable_notification=None):
+            deliveries.append({"message": message, "reply_markup": reply_markup})
+            return {"sent": True, "test": True, "message_id": len(deliveries)}
+
+        backend.telegram_send = fake_send
+        try:
+            dev_db = tmp / "kanban" / "boards" / "agent-requests-dev" / "kanban.db"
+            os.environ["HERMES_KANBAN_DB"] = str(dev_db)
+            os.environ["HERMES_KANBAN_BOARD"] = "agent-requests-dev"
+            os.environ["AGENT_REQUEST_KANBAN_BOARD"] = "agent-requests"
+            os.environ.pop("AGENT_REQUEST_KANBAN_BOARD_OVERRIDE", None)
+            assert backend.board_name() == "agent-requests-dev"
+
+            talon = load_tool("talon", tmp)
+            submitted = call(talon.agent_request_submit_tool({
+                "title": "Dev DB board label smoke",
+                "request": "Verify current Hermes Kanban DB drives notification board labels.",
+                "target": "talon",
+            }))
+            request = submitted["request"]
+            assert submitted["board"] == "agent-requests-dev"
+
+            call(talon.agent_request_propose_tool({
+                "request_id": request["id"],
+                "summary": "approval-required: dev DB board label smoke",
+                "proposal": "After approval, Talon will complete the harmless dev DB board smoke.",
+            }))
+            assert deliveries
+            assert all(delivery["message"].startswith("🧪 DEV agent-requests-dev") for delivery in deliveries)
+            assert all("Board: agent-requests-dev" in delivery["message"] for delivery in deliveries)
+            assert "DEV agent-requests-dev" in common._voice_summary_for_notification(deliveries[-1]["message"])
+
+            markup = [delivery["reply_markup"] for delivery in deliveries if delivery["reply_markup"]][-1]
+            callback_data = markup["inline_keyboard"][0][0]["callback_data"]
+            assert callback_data.startswith("ar:agent-requests-dev:")
+
+            conn = backend.connect()
+            try:
+                rows = conn.execute(
+                    "SELECT detail FROM agent_request_notifications WHERE task_id = ? ORDER BY created_at, event_key",
+                    (request["kanban_task_id"],),
+                ).fetchall()
+            finally:
+                conn.close()
+            details = [json.loads(row["detail"]) for row in rows]
+            assert details
+            assert all(detail["board"] == "agent-requests-dev" for detail in details)
+        finally:
+            backend.telegram_send = old_send
+
+
 def test_dev_board_notifications_are_labeled_and_callbacks_route_to_dev_board():
     if not require_hermes_src():
