+    def _summarize_text_for_voice_reply(self, text: str, *, max_chars: int = 900) -> str:
+        """Return a concise, friendly spoken summary for auto voice replies.
+
+        Text chat still receives the full response. Voice replies should be
+        short enough to be useful as an alert or overview instead of reading a
+        long Markdown-heavy answer aloud.
+        """
+        try:
+            from tools.tts_tool import _strip_markdown_for_tts
+        except Exception:
+            def _strip_markdown_for_tts(value: str) -> str:  # type: ignore[no-redef]
+                return re.sub(r"[*_`#\[\]()]", "", value)
+
+        spoken = _strip_markdown_for_tts(text or "")
+        spoken = re.sub(r"https?://\S+", "link", spoken)
+        spoken = re.sub(r"\s+", " ", spoken).strip()
+        if not spoken:
+            return ""
+        if len(spoken) <= max_chars:
+            return spoken
+
+        sentences = re.split(r"(?<=[.!?])\s+", spoken)
+        selected: list[str] = []
+        total = 0
+        for sentence in sentences:
+            sentence = sentence.strip()
+            if not sentence:
+                continue
+            if selected and total + len(sentence) + 1 > max_chars:
+                break
+            selected.append(sentence)
+            total += len(sentence) + 1
+            if len(selected) >= 4:
+                break
+        summary = " ".join(selected).strip()
+        if not summary:
+            summary = spoken[:max_chars].rsplit(" ", 1)[0].strip()
+        return f"Quick voice summary: {summary}"
+
