+def test_completion_cannot_reclassify_open_blocking_child_without_operator_approval():
+    if not require_hermes_src():
+        return
+    with kanban_env() as tmp:
+        from agent_request_broker import kanban_backend as backend
+
+        old_send = backend.telegram_send
+        backend.telegram_send = lambda message, **_kw: {"sent": True, "test": True}
+        try:
+            talon = load_tool("talon", tmp)
+            star = load_tool("star", tmp)
+            parent = call(star.agent_request_submit_tool({
+                "title": "Parent cannot downgrade child",
+                "request": "Do parent work only after child is done.",
+                "target": "talon",
+            }))["request"]
+            child = call(talon.agent_request_submit_tool({
+                "title": "Blocking child stays blocking",
+                "request": "Finish the prerequisite.",
+                "target": "star",
+                "parent_request_id": parent["id"],
+                "parent_child_classification": "blocking",
+                "parent_child_reason": "Parent cannot proceed until this prerequisite is done.",
+            }))["request"]
+
+            completed = backend.update({
+                "request_id": parent["id"],
+                "status": "completed",
+                "summary": "Try to finish anyway.",
+                "metadata": {
+                    "agent_request_child_tasks": [{
+                        "task_id": child["kanban_task_id"],
+                        "classification": "nonblocking_followup",
+                        "reason": "Worker wants to treat it as follow-up now.",
+                    }],
+                },
+            }, actor="talon")
+            assert "existing blocking child classification cannot be reclassified" in completed["error"]
+            assert "Joy/operator approval is required" in completed["error"]
+
+            conn = backend.connect()
+            try:
+                dispositions = backend.child_completion_dispositions(conn, parent["id"])
+            finally:
+                conn.close()
+            assert dispositions[0]["classification"] == "blocking"
+        finally:
+            backend.telegram_send = old_send
+
