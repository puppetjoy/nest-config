+
+def review_handoff_args(request_id: str) -> dict[str, str]:
+    return {
+        "request_id": request_id,
+        "summary": "review-required: source change ready",
+        "worktree_path": "/tmp/worktrees/t_child_guard",
+        "branch_name": "talon/t_child_guard",
+        "commit_refs": "abc1234",
+        "changed_files": "src/example.py\ntests/test_example.py",
+        "tests_run": "pytest tests/test_example.py -q (passed)",
+        "remaining_actions": "push branch; merge to main; deploy; apply Puppet; restart Hermes; verify live",
+        "side_effects_deferred": "push/merge/deploy/apply/restart intentionally not performed before review",
+    }
+
+
+def test_review_handoff_rejects_parent_with_open_blocking_child():
+    if not require_hermes_src():
+        return
+    with kanban_env() as tmp:
+        from agent_request_broker import kanban_backend as backend
+
+        old_send = backend.telegram_send
+        backend.telegram_send = lambda message, **_kw: {"sent": True, "test": True}
+        try:
+            talon = load_tool("talon", tmp)
+            star = load_tool("star", tmp)
+            parent = call(star.agent_request_submit_tool({
+                "title": "Parent with blocking child",
+                "request": "Do parent work only after child is done.",
+                "target": "talon",
+            }))["request"]
+            child = call(talon.agent_request_submit_tool({
+                "title": "Blocking child",
+                "request": "Finish the prerequisite.",
+                "target": "star",
+                "parent_request_id": parent["id"],
+                "parent_child_classification": "blocking",
+                "parent_child_reason": "Parent cannot proceed until this prerequisite is done.",
+            }))["request"]
+
+            handoff = call(talon.agent_request_review_handoff_tool(review_handoff_args(parent["id"])))
+            assert "waiting on open blocking child" in handoff["error"]
+            assert child["kanban_task_id"] in handoff["error"]
+
+            conn = backend.connect()
+            try:
+                item = backend.index_for_request(conn, parent["id"])
+                task = backend.require_kanban().get_task(conn, parent["kanban_task_id"])
+            finally:
+                conn.close()
+            assert item.status == backend.WAITING_ON_CHILD
+            assert task.status == "blocked"
+        finally:
+            backend.telegram_send = old_send
+
+
+def test_review_handoff_allows_parent_after_blocking_child_done():
+    if not require_hermes_src():
+        return
+    with kanban_env() as tmp:
+        from agent_request_broker import kanban_backend as backend
+
+        old_send = backend.telegram_send
+        backend.telegram_send = lambda message, **_kw: {"sent": True, "test": True}
+        try:
+            talon = load_tool("talon", tmp)
+            star = load_tool("star", tmp)
+            parent = call(star.agent_request_submit_tool({
+                "title": "Parent after blocking child",
+                "request": "Continue after the child finishes.",
+                "target": "talon",
+            }))["request"]
+            child = call(talon.agent_request_submit_tool({
+                "title": "Blocking child done before review",
+                "request": "Finish the prerequisite.",
+                "target": "star",
+                "parent_request_id": parent["id"],
+                "parent_child_classification": "blocking",
+                "parent_child_reason": "Parent cannot proceed until this prerequisite is done.",
+            }))["request"]
+            completed = backend.update({
+                "request_id": child["id"],
+                "status": "completed",
+                "summary": "Prerequisite finished.",
+            }, actor="star")
+            assert not completed.get("error")
+
+            handoff = call(talon.agent_request_review_handoff_tool(review_handoff_args(parent["id"])))
+            assert handoff["request"]["status"] == "reviewing"
+            assert handoff["request"]["kanban_status"] == "review"
+        finally:
+            backend.telegram_send = old_send
+
