+def format_open_blocking_children(children: list[dict[str, Any]]) -> str:
+    child_list = ", ".join(
+        f"{child.get('child_task_id')} ({child.get('title')}, status={child.get('status')})"
+        for child in children
+    )
+    return (
+        "Agent-request parent is waiting on open blocking child request(s); "
+        "review/completion cannot proceed until the child is completed, cancelled, "
+        "superseded, or reclassified through a durable Joy/operator approval path. "
+        f"Open blocking children: {child_list}"
+    )
+
+
+def open_blocking_child_error(conn: Any, item: AgentRequestIndex) -> str | None:
+    blocking_open = completion_child_context(conn, item)["blocking_open"]
+    if not blocking_open:
+        return None
+    return format_open_blocking_children(blocking_open)
+
