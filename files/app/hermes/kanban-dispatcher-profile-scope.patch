+def test_dispatcher_profile_scopes_ready_claims(kanban_home, all_assignees_spawnable):
+    spawns = []
+
+    def fake_spawn(task, workspace):
+        spawns.append((task.id, task.assignee))
+
+    with kb.connect() as conn:
+        talon = kb.create_task(conn, title="talon", assignee="talon")
+        star = kb.create_task(conn, title="star", assignee="star")
+        res = kb.dispatch_once(conn, spawn_fn=fake_spawn, dispatcher_profile="star")
+
+        assert res.spawned[0][0] == star
+        assert spawns == [(star, "star")]
+        assert kb.get_task(conn, star).status == "running"
+        assert kb.get_task(conn, talon).status == "ready"
+
+
+def test_dispatcher_profile_scopes_review_claims(kanban_home, all_assignees_spawnable):
+    spawns = []
+
+    def fake_spawn(task, workspace):
+        spawns.append((task.id, task.assignee))
+
+    with kb.connect() as conn:
+        talon = kb.create_task(conn, title="talon-review", assignee="talon")
+        star = kb.create_task(conn, title="star-review", assignee="star")
+        conn.execute("UPDATE tasks SET status = 'review' WHERE id IN (?, ?)", (talon, star))
+
+        res = kb.dispatch_once(conn, spawn_fn=fake_spawn, dispatcher_profile="star")
+
+        assert res.spawned[0][0] == star
+        assert spawns == [(star, "star")]
+        assert kb.get_task(conn, star).status == "running"
+        assert kb.get_task(conn, talon).status == "review"
+
+
+def test_has_spawnable_ready_honors_dispatcher_profile(
+    kanban_home, all_assignees_spawnable
+):
+    with kb.connect() as conn:
+        kb.create_task(conn, title="talon", assignee="talon")
+        assert kb.has_spawnable_ready(conn, dispatcher_profile="talon") is True
+        assert kb.has_spawnable_ready(conn, dispatcher_profile="star") is False
+        assert kb.has_spawnable_ready(conn) is True
+
+
