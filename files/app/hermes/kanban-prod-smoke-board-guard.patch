+def _effective_board_slug(board: Optional[str] = None) -> Optional[str]:
+    """Best-effort board slug for guardrails before opening the DB."""
+    if board:
+        return str(board).strip() or None
+    env_board = os.environ.get("HERMES_KANBAN_BOARD")
+    if env_board:
+        return env_board.strip() or None
+    db_path = os.environ.get("HERMES_KANBAN_DB")
+    if db_path and os.path.basename(db_path) == "kanban.db":
+        parent = os.path.basename(os.path.dirname(db_path))
+        if parent:
+            return parent
+    return None
+
+
+def _prod_agent_requests_smoke_guard(board: Optional[str], title: Any, assignee: Any) -> Optional[str]:
+    """Keep obvious live/dev smoke cards off the production request board.
+
+    Review/actionability smoke tests must target ``agent-requests-dev`` or an
+    isolated board. A worker can still create real production follow-up tasks;
+    this guard only rejects the synthetic ``test-worker``/smoke shapes that are
+    used for lifecycle verification.
+    """
+    if os.environ.get("HERMES_ALLOW_PROD_KANBAN_SMOKE") == "1":
+        return None
+    if _effective_board_slug(board) != "agent-requests":
+        return None
+
+    title_text = str(title or "").strip().lower()
+    assignee_text = str(assignee or "").strip().lower()
+    obvious_smoke_title = any(token in title_text for token in (
+        "smoke", "synthetic", "dev-smoke", "review-required-smoke",
+    ))
+    if assignee_text == "test-worker" or obvious_smoke_title:
+        return tool_error(
+            "refusing to create live/smoke/test-worker task on production "
+            "agent-requests board; pass board='agent-requests-dev' or use an "
+            "isolated temporary board, and visibly label the task as DEV/test"
+        )
+    return None
+
+
