+def test_review_requested_kanban_event_synthesizes_review_before_buttons():
+    if not require_hermes_src():
+        return
+    with kanban_env() as tmp:
+        from agent_request_broker import kanban_backend as backend
+
+        old_send = backend.telegram_send
+        messages = []
+        markups = []
+
+        def fake_send(message, profile=None, reply_markup=None):
+            del profile
+            messages.append(message)
+            markups.append(reply_markup)
+            return {"sent": True, "test": True}
+
+        backend.telegram_send = fake_send
+        try:
+            talon = load_tool("talon", tmp)
+            submitted = call(talon.agent_request_submit_tool({
+                "title": "Kanban review event smoke",
+                "request": "Produce source work and let the Kanban review event notify Joy.",
+                "target": "talon",
+            }))
+            request = submitted["request"]
+
+            notified = backend.notify_kanban_event(
+                task_id=request["kanban_task_id"],
+                action="review_requested",
+                actor="talon",
+                summary="review-required: source change ready via Kanban review event",
+                event_id=32001,
+            )
+            assert notified["notified"] is True
+            assert any("Agent request review requested" in message for message in messages)
+            review_markup = next(markup for markup in markups if markup and any(
+                button["text"] == "✅ Accept review"
+                for row in markup["inline_keyboard"]
+                for button in row
+            ))
+            review_labels = {
+                button["text"]
+                for row in review_markup["inline_keyboard"]
+                for button in row
+            }
+            assert review_labels == {"✅ Accept review", "🔁 Request changes", "❓ Ask question"}
+
+            conn = backend.connect()
+            try:
+                review = backend.latest_review(conn, request["id"])
+                assert review is not None
+                token = review_markup["inline_keyboard"][0][0]["callback_data"].split(":", 1)[1]
+                callback = backend.validate_callback_token(conn, token)["callback"]
+                assert callback["action"] == "review_accept"
+                assert callback["request_id"] == request["id"]
+                assert callback["review_hash"] == review["review_hash"]
+                notification = conn.execute(
+                    "SELECT action, task_id, delivered, detail FROM agent_request_notifications WHERE request_id = ? AND action = ?",
+                    (request["id"], "review_requested"),
+                ).fetchone()
+                callbacks = conn.execute(
+                    "SELECT action, task_id, review_comment_id, review_hash FROM agent_request_callback_tokens WHERE request_id = ? AND action IN ('review_accept', 'review_changes', 'review_question')",
+                    (request["id"],),
+                ).fetchall()
+                assert notification is not None
+                assert notification["task_id"] == request["kanban_task_id"]
+                assert notification["delivered"] == 1
+                detail = json.loads(notification["detail"] or "{}")
+                assert detail.get("attention_required") is True
+                assert {row["action"] for row in callbacks} == {"review_accept", "review_changes", "review_question"}
+                assert {row["task_id"] for row in callbacks} == {request["kanban_task_id"]}
+                assert {row["review_comment_id"] for row in callbacks} == {review["review_comment_id"]}
+                assert {row["review_hash"] for row in callbacks} == {review["review_hash"]}
+            finally:
+                conn.close()
+        finally:
+            backend.telegram_send = old_send
+
+
