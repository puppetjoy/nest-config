+def ensure_review_handoff_for_notification(conn: Any, item: AgentRequestIndex, *, actor: str, summary: str) -> AgentRequestIndex:
+    """Ensure review-requested notifications have a current review artifact.
+
+    Some Kanban review transitions are emitted by the lower-level
+    `review-required` fallback path rather than `agent_request_review_handoff()`.
+    Those events are still actionable reviews, so synthesize the same durable
+    review binding from the latest task comment before building Telegram
+    buttons. Without this, the notification row can be delivered while
+    `actionable_reply_markup()` has no review hash/comment to bind callbacks to.
+    """
+    if latest_review(conn, item.request_id) is not None:
+        return item
+    task = require_kanban().get_task(conn, item.task_id)
+    if task is None:
+        return item
+    comment = _latest_comment_row(conn, item.task_id)
+    details = _direct_fallback_review_details(task, comment, summary)
+    comment_id = int(comment["id"]) if comment else 0
+    record_review_handoff(
+        conn,
+        request_id=item.request_id,
+        comment_id=comment_id,
+        requested_by=actor or item.target or "talon",
+        **details,
+    )
+    if item.status == REVIEW_REQUESTED:
+        return item
+    updated = replace(item, status=REVIEW_REQUESTED, updated_at=now_ts())
+    write_index(conn, updated)
+    return updated
+
