+def test_cleanup_keeps_nonterminal_or_dirty_task_worktree(tmp_path, monkeypatch):
+    from agent_request_broker import kanban_backend as backend
+
+    repo = tmp_path / "repo"
+    repo.mkdir()
+    subprocess.run(["git", "init", "-b", "main"], cwd=repo, check=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)
+    subprocess.run(["git", "config", "user.email", "test@example.invalid"], cwd=repo, check=True)
+    subprocess.run(["git", "config", "user.name", "Test"], cwd=repo, check=True)
+    (repo / "README.md").write_text("base\n", encoding="utf-8")
+    subprocess.run(["git", "add", "README.md"], cwd=repo, check=True)
+    subprocess.run(["git", "commit", "-m", "base"], cwd=repo, check=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)
+    remote = tmp_path / "remote.git"
+    subprocess.run(["git", "init", "--bare", remote], check=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)
+    subprocess.run(["git", "remote", "add", "origin", str(remote)], cwd=repo, check=True)
+    subprocess.run(["git", "push", "-u", "origin", "main"], cwd=repo, check=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)
+
+    root = tmp_path / "worktrees"
+    monkeypatch.setenv("AGENT_REQUEST_WORKTREE_ROOT", str(root))
+    path = root / "nest-config" / "t_1234abcd"
+    branch = "talon/t_1234abcd-cleanup-test"
+    subprocess.run(["git", "-C", str(repo), "worktree", "add", "-b", branch, str(path), "origin/main"], check=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)
+    (path / "dirty.txt").write_text("dirty\n", encoding="utf-8")
+
+    task = types.SimpleNamespace(id="t_1234abcd", status="running", workspace_kind="worktree", workspace_path=str(path), branch_name=branch)
+    result = backend.cleanup_task_workspace(task)
+    assert path.exists()
+    assert "task is not terminal" in result["skipped"]
+
+    task.status = "done"
+    result = backend.cleanup_task_workspace(task)
+    assert path.exists()
+    assert "workspace has dirty files" in result["skipped"]
+
+
