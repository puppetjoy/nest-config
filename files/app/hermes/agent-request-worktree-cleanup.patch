+def test_cleanup_eyrie_registry_deletion_is_env_gated_and_uses_docker_registry_v2(tmp_path, monkeypatch):
+    from agent_request_broker import kanban_backend as backend
+
+    repo = tmp_path / "repo"
+    repo.mkdir()
+    subprocess.run(["git", "init", "-b", "main"], cwd=repo, check=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)
+    subprocess.run(["git", "remote", "add", "origin", "git@gitlab.joyfullee.me:nest/config.git"], cwd=repo, check=True)
+    branch = "talon/t_1234abcd-cleanup-test"
+
+    disabled = backend.delete_eyrie_registry_repository(repo_path=repo, branch=branch)
+    assert disabled["enabled"] is False
+    assert disabled["deleted"] == []
+
+    monkeypatch.setenv("AGENT_REQUEST_CLEANUP_DELETE_EYRIE_REGISTRY_REPOSITORIES", "true")
+    calls = []
+
+    def fake_registry_request(method, url, *, accept_manifest=False):
+        calls.append((method, url, accept_manifest))
+        if url.endswith("/tags/list"):
+            return 200, {"tags": ["latest", "haswell"]}, {}
+        if method == "HEAD":
+            tag = url.rsplit("/", 1)[-1]
+            return 200, None, {"docker-content-digest": f"sha256:{tag}digest"}
+        if method == "DELETE":
+            return 202, None, {}
+        raise AssertionError(f"unexpected registry request: {method} {url}")
+
+    monkeypatch.setattr(backend, "docker_registry_json_request", fake_registry_request)
+    result = backend.delete_eyrie_registry_repository(repo_path=repo, branch=branch)
+
+    assert result["enabled"] is True
+    assert "registry.eyrie/nest/config/talon/t_1234abcd-cleanup-test:latest" in result["deleted"]
+    assert "registry-test.eyrie/nest/config/talon/t_1234abcd-cleanup-test:haswell" in result["deleted"]
+    assert any(call[0] == "HEAD" and call[2] is True for call in calls)
+    assert any(call[0] == "DELETE" and "sha256:" in call[1] for call in calls)
+
