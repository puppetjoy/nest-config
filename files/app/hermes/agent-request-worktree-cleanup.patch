+import urllib.request
 from dataclasses import asdict, dataclass, replace
 import unicodedata
 from datetime import datetime, timezone
@@ -451,6 +454,440 @@ def update_task_workspace(conn: Any, *, task_id: str, policy: WorkspacePolicy) -
     conn.commit()
 
 
+
+TERMINAL_TASK_STATUSES = {"done", "archived"}
+SAFE_TASK_BRANCH_RE = re.compile(r"^(?:talon|star|rollout)/t_[0-9a-f]{8}(?:[-/].*)?$")
+REGISTRY_IMAGE_ARCH_TAGS = ("haswell", "cortex-a53", "sifive-u74")
+REMOTE_BRANCH_DELETE_ENV = "AGENT_REQUEST_CLEANUP_DELETE_REMOTE_BRANCHES"
+REGISTRY_DELETE_ENV = "AGENT_REQUEST_CLEANUP_DELETE_REGISTRY_REPOSITORIES"
+EYRIE_REGISTRY_DELETE_ENV = "AGENT_REQUEST_CLEANUP_DELETE_EYRIE_REGISTRY_REPOSITORIES"
+EYRIE_REGISTRY_HOSTS = ("registry.eyrie", "registry-test.eyrie")
+DOCKER_MANIFEST_ACCEPT = ", ".join(
+    (
+        "application/vnd.docker.distribution.manifest.v2+json",
+        "application/vnd.oci.image.manifest.v1+json",
+        "application/vnd.docker.distribution.manifest.list.v2+json",
+        "application/vnd.oci.image.index.v1+json",
+    )
+)
+GITLAB_TOKEN_ENVS = ("AGENT_REQUEST_GITLAB_TOKEN", "GITLAB_TOKEN", "GITLAB_PRIVATE_TOKEN")
+
+
+
+def run_git(args: list[str], *, cwd: Path | None = None, timeout: int = 60) -> subprocess.CompletedProcess[str]:
+    return subprocess.run(
+        ["git", *args],
+        cwd=str(cwd) if cwd else None,
+        text=True,
+        stdout=subprocess.PIPE,
+        stderr=subprocess.PIPE,
+        timeout=timeout,
+    )
+
+
+def safe_task_branch(branch: str, task_id: str) -> bool:
+    return bool(branch and task_id and task_id in branch and SAFE_TASK_BRANCH_RE.match(branch))
+
+
+def project_path_from_git_remote(repo_path: Path) -> str:
+    result = run_git(["-C", str(repo_path), "remote", "get-url", "origin"])
+    if result.returncode != 0:
+        return ""
+    remote = result.stdout.strip()
+    if remote.endswith(".git"):
+        remote = remote[:-4]
+    match = re.search(r"[:/]([^/:]+/[^/]+)$", remote)
+    return match.group(1) if match else ""
+
+
+def env_flag(name: str) -> bool:
+    return (os.environ.get(name) or "").strip().lower() in {"1", "true", "yes", "on"}
+
+
+def registry_repository_path(*, repo_path: Path, branch: str) -> str:
+    project_path = project_path_from_git_remote(repo_path)
+    return f"{project_path}/{branch}" if project_path and branch else ""
+
+
+def registry_cleanup_candidates(*, repo_path: Path, branch: str) -> list[str]:
+    repo = registry_repository_path(repo_path=repo_path, branch=branch)
+    if not repo:
+        return []
+    candidates = [f"${{CI_REGISTRY}}/{repo}:{tag}" for tag in REGISTRY_IMAGE_ARCH_TAGS]
+    candidates.append(f"${{CI_REGISTRY}}/{repo}:latest")
+    for host in EYRIE_REGISTRY_HOSTS:
+        candidates.extend([f"{host}/{repo}:{tag}" for tag in REGISTRY_IMAGE_ARCH_TAGS])
+        candidates.append(f"{host}/{repo}:latest")
+    return candidates
+
+
+def delete_remote_task_branch(*, repo_path: Path, branch: str) -> dict[str, Any]:
+    result: dict[str, Any] = {"enabled": env_flag(REMOTE_BRANCH_DELETE_ENV), "deleted": False, "branch": branch}
+    if not result["enabled"]:
+        result["reason"] = f"{REMOTE_BRANCH_DELETE_ENV} is not true"
+        return result
+    delete = run_git(["-C", str(repo_path), "push", "origin", "--delete", branch], timeout=120)
+    output = (delete.stderr or delete.stdout or "").strip()
+    if delete.returncode == 0:
+        result["deleted"] = True
+    elif "remote ref does not exist" in output or "unable to delete" in output and "not found" in output:
+        result["deleted"] = True
+        result["already_absent"] = True
+    else:
+        result["reason"] = output or "git push --delete failed"
+    return result
+
+
+def gitlab_token() -> str:
+    for env_name in GITLAB_TOKEN_ENVS:
+        token = (os.environ.get(env_name) or "").strip()
+        if token:
+            return token
+    return ""
+
+
+def gitlab_api_url(repo_path: Path) -> str:
+    explicit = (os.environ.get("AGENT_REQUEST_GITLAB_API_V4_URL") or os.environ.get("CI_API_V4_URL") or "").strip().rstrip("/")
+    if explicit:
+        return explicit
+    remote = run_git(["-C", str(repo_path), "remote", "get-url", "origin"]).stdout.strip()
+    match = re.search(r"(?:git@|https?://)([^/:]+)", remote)
+    host = match.group(1) if match else "gitlab.joyfullee.me"
+    return f"https://{host}/api/v4"
+
+
+def gitlab_project_identifier(repo_path: Path) -> str:
+    explicit = (os.environ.get("AGENT_REQUEST_GITLAB_PROJECT_ID") or os.environ.get("CI_PROJECT_ID") or "").strip()
+    if explicit:
+        return explicit
+    return urllib.parse.quote(project_path_from_git_remote(repo_path), safe="")
+
+
+def gitlab_json_request(method: str, url: str, *, token: str) -> Any:
+    request = urllib.request.Request(url, method=method)
+    request.add_header("PRIVATE-TOKEN", token)
+    with urllib.request.urlopen(request, timeout=20) as response:  # noqa: S310 - operator-scoped GitLab API URL
+        body = response.read().decode("utf-8")
+    return json.loads(body) if body else None
+
+
+def delete_gitlab_registry_repository(*, repo_path: Path, branch: str) -> dict[str, Any]:
+    result: dict[str, Any] = {
+        "enabled": env_flag(REGISTRY_DELETE_ENV),
+        "deleted": [],
+        "target_path": registry_repository_path(repo_path=repo_path, branch=branch),
+    }
+    if not result["enabled"]:
+        result["reason"] = f"{REGISTRY_DELETE_ENV} is not true"
+        return result
+    token = gitlab_token()
+    if not token:
+        result["reason"] = "no GitLab API token environment variable is set"
+        return result
+    api = gitlab_api_url(repo_path)
+    project = gitlab_project_identifier(repo_path)
+    if not project or not result["target_path"]:
+        result["reason"] = "could not determine GitLab project or registry repository path"
+        return result
+    try:
+        page = 1
+        while True:
+            url = f"{api}/projects/{project}/registry/repositories?per_page=100&page={page}"
+            repositories = gitlab_json_request("GET", url, token=token) or []
+            if not repositories:
+                break
+            for repository in repositories:
+                repo_path_value = str(repository.get("path") or "")
+                if repo_path_value == result["target_path"]:
+                    repo_id = repository.get("id")
+                    gitlab_json_request("DELETE", f"{api}/projects/{project}/registry/repositories/{repo_id}", token=token)
+                    result["deleted"].append(repo_path_value)
+            if len(repositories) < 100:
+                break
+            page += 1
+    except urllib.error.HTTPError as exc:
+        result["reason"] = f"GitLab API HTTP {exc.code}"
+    except (OSError, ValueError) as exc:
+        result["reason"] = str(exc)
+    if not result["deleted"] and "reason" not in result:
+        result["reason"] = "matching registry repository not found"
+    return result
+
+
+def eyrie_registry_url(host: str, repo: str, suffix: str) -> str:
+    return f"https://{host}/v2/{repo}/{suffix}"
+
+
+def docker_registry_json_request(method: str, url: str, *, accept_manifest: bool = False) -> tuple[int, Any, dict[str, str]]:
+    request = urllib.request.Request(url, method=method)
+    if accept_manifest:
+        request.add_header("Accept", DOCKER_MANIFEST_ACCEPT)
+    with urllib.request.urlopen(request, timeout=20) as response:  # noqa: S310 - operator-scoped internal registry URL
+        body = response.read().decode("utf-8")
+        headers = {key.lower(): value for key, value in response.headers.items()}
+        parsed = json.loads(body) if body else None
+        return response.status, parsed, headers
+
+
+def delete_eyrie_registry_repository(*, repo_path: Path, branch: str) -> dict[str, Any]:
+    repo = registry_repository_path(repo_path=repo_path, branch=branch)
+    result: dict[str, Any] = {
+        "enabled": env_flag(EYRIE_REGISTRY_DELETE_ENV),
+        "deleted": [],
+        "repositories": [f"{host}/{repo}" for host in EYRIE_REGISTRY_HOSTS] if repo else [],
+    }
+    if not result["enabled"]:
+        result["reason"] = f"{EYRIE_REGISTRY_DELETE_ENV} is not true"
+        return result
+    if not repo:
+        result["reason"] = "could not determine Eyrie registry repository path"
+        return result
+    try:
+        for host in EYRIE_REGISTRY_HOSTS:
+            tags_url = eyrie_registry_url(host, repo, "tags/list")
+            try:
+                _, tags_payload, _ = docker_registry_json_request("GET", tags_url)
+            except urllib.error.HTTPError as exc:
+                if exc.code == 404:
+                    continue
+                raise
+            tags = sorted(str(tag) for tag in (tags_payload or {}).get("tags") or [])
+            for tag in tags:
+                manifest_url = eyrie_registry_url(host, repo, f"manifests/{urllib.parse.quote(tag, safe='')}")
+                _, _, headers = docker_registry_json_request("HEAD", manifest_url, accept_manifest=True)
+                digest = headers.get("docker-content-digest")
+                if not digest:
+                    result.setdefault("skipped", []).append(f"{host}/{repo}:{tag} has no Docker-Content-Digest")
+                    continue
+                delete_url = eyrie_registry_url(host, repo, f"manifests/{urllib.parse.quote(digest, safe=':')}")
+                docker_registry_json_request("DELETE", delete_url, accept_manifest=True)
+                result["deleted"].append(f"{host}/{repo}:{tag}")
+    except urllib.error.HTTPError as exc:
+        result["reason"] = f"Eyrie registry HTTP {exc.code}"
+    except (OSError, ValueError) as exc:
+        result["reason"] = str(exc)
+    if not result["deleted"] and "reason" not in result:
+        result["reason"] = "matching Eyrie registry repository not found"
+    return result
+
+
+def git_commit_ref_exists(*, repo_path: Path, ref: str) -> bool:
+    result = run_git(["-C", str(repo_path), "rev-parse", "--verify", "--quiet", f"{ref}^{{commit}}"])
+    return result.returncode == 0
+
+
+def cleanup_branch_ref(*, repo_path: Path, branch: str) -> tuple[str, str]:
+    if git_commit_ref_exists(repo_path=repo_path, ref=branch):
+        return branch, "local"
+    remote_ref = f"origin/{branch}"
+    if git_commit_ref_exists(repo_path=repo_path, ref=remote_ref):
+        return remote_ref, "remote"
+    return branch, "missing"
+
+
+def cleanup_repo_path_for_workspace(workspace_path: Path) -> Path:
+    repo_name = workspace_path.parent.name
+    for policy in repo_policies():
+        if policy.name == repo_name:
+            return Path(policy.canonical_path).expanduser()
+    return worktree_root() / repo_name
+
+
+def workspace_under_cleanup_root(path: Path) -> bool:
+    try:
+        path.resolve().relative_to(worktree_root().resolve())
+        return True
+    except ValueError:
+        return False
+
+
+def branch_has_unpushed_commits(*, repo_path: Path, branch: str) -> tuple[bool, str]:
+    result = run_git(["-C", str(repo_path), "log", branch, "--not", "--remotes", "--oneline"])
+    if result.returncode != 0:
+        return True, (result.stderr or result.stdout or "git log failed").strip()
+    return bool(result.stdout.strip()), result.stdout.strip()
+
+
+def branch_merged_to_base(*, repo_path: Path, branch: str, base_ref: str = "origin/main") -> tuple[bool, str]:
+    branch_ref, ref_source = cleanup_branch_ref(repo_path=repo_path, branch=branch)
+    if ref_source == "missing":
+        return False, f"neither {branch} nor origin/{branch} exists; resources retained"
+    result = run_git(["-C", str(repo_path), "merge-base", "--is-ancestor", branch_ref, base_ref])
+    if result.returncode == 0:
+        return True, ""
+    return False, (result.stderr or result.stdout or f"{branch_ref} is not merged to {base_ref}").strip()
+
+
+def cleanup_task_workspace(task: Any) -> dict[str, Any]:
+    result: dict[str, Any] = {
+        "task_id": getattr(task, "id", ""),
+        "status": getattr(task, "status", ""),
+        "workspace_kind": getattr(task, "workspace_kind", ""),
+        "workspace_path": getattr(task, "workspace_path", "") or "",
+        "branch_name": getattr(task, "branch_name", "") or "",
+        "removed_worktree": False,
+        "removed_local_branch": False,
+        "removed_remote_branch": False,
+        "queued_remote_branch": False,
+        "queued_registry_images": [],
+        "removed_registry_repositories": [],
+        "skipped": [],
+    }
+    task_id = result["task_id"]
+    branch = result["branch_name"]
+    if result["status"] not in TERMINAL_TASK_STATUSES:
+        result["skipped"].append("task is not terminal")
+        return result
+    if result["workspace_kind"] != "worktree":
+        result["skipped"].append("workspace is not a git worktree")
+        return result
+    if not safe_task_branch(branch, task_id):
+        result["skipped"].append("branch name is not a safe task branch")
+        return result
+    if not result["workspace_path"]:
+        result["skipped"].append("workspace path is empty")
+        return result
+
+    workspace_path = Path(result["workspace_path"]).expanduser()
+    if not workspace_path.is_absolute() or not workspace_under_cleanup_root(workspace_path):
+        result["skipped"].append("workspace path is outside the managed worktree root")
+        return result
+    if workspace_path.name != task_id:
+        result["skipped"].append("workspace leaf does not match task id")
+        return result
+    if not workspace_path.exists():
+        result["skipped"].append("workspace path is already absent")
+        repo_path = cleanup_repo_path_for_workspace(workspace_path)
+    else:
+        repo_probe = run_git(["-C", str(workspace_path), "rev-parse", "--show-toplevel"])
+        if repo_probe.returncode != 0:
+            result["skipped"].append("workspace is not a git checkout")
+            return result
+        repo_common = run_git(["-C", str(workspace_path), "rev-parse", "--git-common-dir"])
+        repo_path = Path(repo_common.stdout.strip()).parent if repo_common.returncode == 0 and repo_common.stdout.strip() else worktree_root() / workspace_path.parent.name
+        status = run_git(["-C", str(workspace_path), "status", "--porcelain"])
+        if status.returncode != 0:
+            result["skipped"].append((status.stderr or status.stdout or "git status failed").strip())
+            return result
+        if status.stdout.strip():
+            result["skipped"].append("workspace has dirty files")
+            return result
+        has_unpushed, detail = branch_has_unpushed_commits(repo_path=repo_path, branch=branch)
+        if has_unpushed:
+            result["skipped"].append("branch has local commits not present on a remote")
+            result["unpushed_commits"] = detail
+            return result
+
+    merged, merged_detail = branch_merged_to_base(repo_path=repo_path, branch=branch)
+    if not merged:
+        result["skipped"].append(merged_detail or "branch is not merged to origin/main; resources retained")
+        return result
+
+    if workspace_path.exists():
+        remove = run_git(["-C", str(repo_path), "worktree", "remove", str(workspace_path)])
+        if remove.returncode == 0:
+            result["removed_worktree"] = True
+        else:
+            result["skipped"].append((remove.stderr or remove.stdout or "git worktree remove failed").strip())
+            return result
+
+    delete_branch = run_git(["-C", str(repo_path), "branch", "-d", branch])
+    if delete_branch.returncode == 0:
+        result["removed_local_branch"] = True
+    else:
+        branch_delete_output = (delete_branch.stderr or delete_branch.stdout or "git branch -d failed").strip()
+        if "not found" not in branch_delete_output and "branch not found" not in branch_delete_output:
+            result["skipped"].append(branch_delete_output)
+
+    remote_cleanup = delete_remote_task_branch(repo_path=repo_path, branch=branch)
+    result["remote_branch_cleanup"] = remote_cleanup
+    if remote_cleanup.get("deleted"):
+        result["removed_remote_branch"] = True
+    else:
+        result["queued_remote_branch"] = True
+
+    registry_cleanup = delete_gitlab_registry_repository(repo_path=repo_path, branch=branch)
+    result["registry_repository_cleanup"] = registry_cleanup
+    registry_deleted = list(registry_cleanup.get("deleted") or [])
+    eyrie_registry_cleanup = delete_eyrie_registry_repository(repo_path=repo_path, branch=branch)
+    result["eyrie_registry_repository_cleanup"] = eyrie_registry_cleanup
+    registry_deleted.extend(eyrie_registry_cleanup.get("deleted") or [])
+    if registry_deleted:
+        result["removed_registry_repositories"] = registry_deleted
+    else:
+        result["queued_registry_images"] = registry_cleanup_candidates(repo_path=repo_path, branch=branch)
+    return result
+
+
+def record_cleanup_result(conn: Any, *, task_id: str, actor: str, cleanup: dict[str, Any]) -> int:
+    action = "cleanup_completed" if cleanup.get("removed_worktree") or cleanup.get("removed_local_branch") or cleanup.get("removed_remote_branch") or cleanup.get("removed_registry_repositories") else "cleanup_queued"
+    queued_images = cleanup.get("queued_registry_images") or []
+    skipped = cleanup.get("skipped") or []
+    summary_parts = []
+    if cleanup.get("removed_worktree"):
+        summary_parts.append("removed local worktree")
+    if cleanup.get("removed_local_branch"):
+        summary_parts.append("removed merged local task branch")
+    if cleanup.get("removed_remote_branch"):
+        summary_parts.append("removed remote task branch")
+    if cleanup.get("queued_remote_branch"):
+        summary_parts.append("queued remote branch cleanup")
+    removed_repositories = cleanup.get("removed_registry_repositories") or []
+    if removed_repositories:
+        summary_parts.append(f"removed {len(removed_repositories)} registry repositories")
+    if queued_images:
+        summary_parts.append(f"queued {len(queued_images)} registry image tags/repositories for cleanup")
+    if skipped:
+        summary_parts.append("skipped: " + "; ".join(str(item) for item in skipped[:3]))
+    summary = "; ".join(summary_parts) or "no cleanup action needed"
+    body = event_comment(
+        request_id="",
+        actor=actor,
+        action=action,
+        summary=summary,
+        cleanup=cleanup,
+    )
+    return require_kanban().add_comment(conn, task_id, actor, body)
+
+
+def cleanup_terminal_task_resources(conn: Any, *, task_id: str, actor: str = "talon") -> dict[str, Any]:
+    task = require_kanban().get_task(conn, task_id)
+    if task is None:
+        return {"task_id": task_id, "skipped": ["task not found"]}
+    cleanup = cleanup_task_workspace(task)
+    if cleanup.get("removed_worktree") or cleanup.get("removed_local_branch") or cleanup.get("removed_remote_branch") or cleanup.get("removed_registry_repositories") or cleanup.get("queued_remote_branch") or cleanup.get("queued_registry_images") or cleanup.get("skipped"):
+        comment_id = record_cleanup_result(conn, task_id=task_id, actor=actor, cleanup=cleanup)
+        cleanup["comment_id"] = comment_id
+    return cleanup
+
+
+def cleanup_terminal_task_sweep(*, actor: str = "talon", include_archived: bool = False, limit: int | None = None) -> dict[str, Any]:
+    conn = connect()
+    try:
+        statuses = ["done"]
+        if include_archived:
+            statuses.append("archived")
+        placeholders = ",".join("?" for _ in statuses)
+        query = f"SELECT id FROM tasks WHERE status IN ({placeholders}) ORDER BY completed_at DESC, created_at DESC"
+        if limit is not None:
+            query += " LIMIT ?"
+            params: list[Any] = [*statuses, int(limit)]
+        else:
+            params = statuses
+        task_ids = [str(row["id"]) for row in conn.execute(query, params).fetchall()]
+        cleanups = [cleanup_terminal_task_resources(conn, task_id=task_id, actor=actor) for task_id in task_ids]
+        return {
