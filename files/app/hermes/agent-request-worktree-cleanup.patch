+
+TERMINAL_TASK_STATUSES = {"done", "archived"}
+SAFE_TASK_BRANCH_RE = re.compile(r"^(?:talon|star|rollout)/t_[0-9a-f]{8}(?:[-/].*)?$")
+REGISTRY_IMAGE_ARCH_TAGS = ("haswell", "cortex-a53", "sifive-u74")
+
+
+def run_git(args: list[str], *, cwd: Path | None = None, timeout: int = 60) -> subprocess.CompletedProcess[str]:
+    return subprocess.run(
+        ["git", *args],
+        cwd=str(cwd) if cwd else None,
+        text=True,
+        stdout=subprocess.PIPE,
+        stderr=subprocess.PIPE,
+        timeout=timeout,
+    )
+
+
+def safe_task_branch(branch: str, task_id: str) -> bool:
+    return bool(branch and task_id and task_id in branch and SAFE_TASK_BRANCH_RE.match(branch))
+
+
+def project_path_from_git_remote(repo_path: Path) -> str:
+    result = run_git(["-C", str(repo_path), "remote", "get-url", "origin"])
+    if result.returncode != 0:
+        return ""
+    remote = result.stdout.strip()
+    if remote.endswith(".git"):
+        remote = remote[:-4]
+    match = re.search(r"[:/]([^/:]+/[^/]+)$", remote)
+    return match.group(1) if match else ""
+
+
+def registry_cleanup_candidates(*, repo_path: Path, branch: str) -> list[str]:
+    project_path = project_path_from_git_remote(repo_path)
+    if not project_path or not branch:
+        return []
+    repo = f"{project_path}/{branch}"
+    candidates = [f"${{CI_REGISTRY}}/{repo}:{tag}" for tag in REGISTRY_IMAGE_ARCH_TAGS]
+    candidates.append(f"${{CI_REGISTRY}}/{repo}:latest")
+    candidates.extend([f"registry.eyrie/{repo}:{tag}" for tag in REGISTRY_IMAGE_ARCH_TAGS])
+    candidates.append(f"registry.eyrie/{repo}:latest")
+    return candidates
+
+
+def workspace_under_cleanup_root(path: Path) -> bool:
+    try:
+        path.resolve().relative_to(worktree_root().resolve())
+        return True
+    except ValueError:
+        return False
+
+
+def branch_has_unpushed_commits(*, repo_path: Path, branch: str) -> tuple[bool, str]:
+    result = run_git(["-C", str(repo_path), "log", branch, "--not", "--remotes", "--oneline"])
+    if result.returncode != 0:
+        return True, (result.stderr or result.stdout or "git log failed").strip()
+    return bool(result.stdout.strip()), result.stdout.strip()
+
+
+def branch_merged_to_base(*, repo_path: Path, branch: str, base_ref: str = "origin/main") -> tuple[bool, str]:
+    result = run_git(["-C", str(repo_path), "merge-base", "--is-ancestor", branch, base_ref])
+    if result.returncode == 0:
+        return True, ""
+    return False, (result.stderr or result.stdout or f"{branch} is not merged to {base_ref}").strip()
+
+
+def cleanup_task_workspace(task: Any) -> dict[str, Any]:
+    result: dict[str, Any] = {
+        "task_id": getattr(task, "id", ""),
+        "status": getattr(task, "status", ""),
+        "workspace_kind": getattr(task, "workspace_kind", ""),
+        "workspace_path": getattr(task, "workspace_path", "") or "",
+        "branch_name": getattr(task, "branch_name", "") or "",
+        "removed_worktree": False,
+        "removed_local_branch": False,
+        "queued_remote_branch": False,
+        "queued_registry_images": [],
+        "skipped": [],
+    }
+    task_id = result["task_id"]
+    branch = result["branch_name"]
+    if result["status"] not in TERMINAL_TASK_STATUSES:
+        result["skipped"].append("task is not terminal")
+        return result
+    if result["workspace_kind"] != "worktree":
+        result["skipped"].append("workspace is not a git worktree")
+        return result
+    if not safe_task_branch(branch, task_id):
+        result["skipped"].append("branch name is not a safe task branch")
+        return result
+    if not result["workspace_path"]:
+        result["skipped"].append("workspace path is empty")
+        return result
+
+    workspace_path = Path(result["workspace_path"]).expanduser()
+    if not workspace_path.is_absolute() or not workspace_under_cleanup_root(workspace_path):
+        result["skipped"].append("workspace path is outside the managed worktree root")
+        return result
+    if workspace_path.name != task_id:
+        result["skipped"].append("workspace leaf does not match task id")
+        return result
+    if not workspace_path.exists():
+        result["skipped"].append("workspace path is already absent")
+        repo_path = worktree_root() / workspace_path.parent.name
+    else:
+        repo_probe = run_git(["-C", str(workspace_path), "rev-parse", "--show-toplevel"])
+        if repo_probe.returncode != 0:
+            result["skipped"].append("workspace is not a git checkout")
+            return result
+        repo_common = run_git(["-C", str(workspace_path), "rev-parse", "--git-common-dir"])
+        repo_path = Path(repo_common.stdout.strip()).parent if repo_common.returncode == 0 and repo_common.stdout.strip() else worktree_root() / workspace_path.parent.name
+        status = run_git(["-C", str(workspace_path), "status", "--porcelain"])
+        if status.returncode != 0:
+            result["skipped"].append((status.stderr or status.stdout or "git status failed").strip())
+            return result
+        if status.stdout.strip():
+            result["skipped"].append("workspace has dirty files")
+            return result
+        has_unpushed, detail = branch_has_unpushed_commits(repo_path=repo_path, branch=branch)
+        if has_unpushed:
+            result["skipped"].append("branch has local commits not present on a remote")
+            result["unpushed_commits"] = detail
+            return result
+        remove = run_git(["-C", str(repo_path), "worktree", "remove", str(workspace_path)])
+        if remove.returncode == 0:
+            result["removed_worktree"] = True
+        else:
+            result["skipped"].append((remove.stderr or remove.stdout or "git worktree remove failed").strip())
+            return result
+
+    merged, merged_detail = branch_merged_to_base(repo_path=repo_path, branch=branch)
+    if merged:
+        delete_branch = run_git(["-C", str(repo_path), "branch", "-d", branch])
+        if delete_branch.returncode == 0:
+            result["removed_local_branch"] = True
+        else:
+            result["skipped"].append((delete_branch.stderr or delete_branch.stdout or "git branch -d failed").strip())
+    else:
+        result["skipped"].append(merged_detail or "branch is not merged to origin/main; local branch retained")
+
+    result["queued_remote_branch"] = True
+    result["queued_registry_images"] = registry_cleanup_candidates(repo_path=repo_path, branch=branch)
+    return result
+
+
+def record_cleanup_result(conn: Any, *, task_id: str, actor: str, cleanup: dict[str, Any]) -> int:
+    action = "cleanup_completed" if cleanup.get("removed_worktree") or cleanup.get("removed_local_branch") else "cleanup_queued"
+    queued_images = cleanup.get("queued_registry_images") or []
+    skipped = cleanup.get("skipped") or []
+    summary_parts = []
+    if cleanup.get("removed_worktree"):
+        summary_parts.append("removed local worktree")
+    if cleanup.get("removed_local_branch"):
+        summary_parts.append("removed merged local task branch")
+    if cleanup.get("queued_remote_branch"):
+        summary_parts.append("queued remote branch cleanup")
+    if queued_images:
+        summary_parts.append(f"queued {len(queued_images)} registry image tags/repositories for cleanup")
+    if skipped:
+        summary_parts.append("skipped: " + "; ".join(str(item) for item in skipped[:3]))
+    summary = "; ".join(summary_parts) or "no cleanup action needed"
+    body = event_comment(
+        request_id="",
+        actor=actor,
+        action=action,
+        summary=summary,
+        cleanup=cleanup,
+    )
+    return require_kanban().add_comment(conn, task_id, actor, body)
+
+
+def cleanup_terminal_task_resources(conn: Any, *, task_id: str, actor: str = "talon") -> dict[str, Any]:
+    task = require_kanban().get_task(conn, task_id)
+    if task is None:
+        return {"task_id": task_id, "skipped": ["task not found"]}
+    cleanup = cleanup_task_workspace(task)
+    if cleanup.get("removed_worktree") or cleanup.get("removed_local_branch") or cleanup.get("queued_remote_branch") or cleanup.get("queued_registry_images") or cleanup.get("skipped"):
+        comment_id = record_cleanup_result(conn, task_id=task_id, actor=actor, cleanup=cleanup)
+        cleanup["comment_id"] = comment_id
+    return cleanup
+
 def urgency_to_priority(urgency: str) -> int:
