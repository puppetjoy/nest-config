+#!/usr/bin/env python3
+"""Sweep terminal Kanban task worktrees, task branches, and registry repositories."""
+from __future__ import annotations
+
+import argparse
+import json
+import os
+import sys
+from pathlib import Path
+
+ROOT = Path(__file__).resolve().parents[1]
+HERMES_SRC = Path(os.environ.get("HERMES_SRC", "/opt/hermes-agent/src"))
+if HERMES_SRC.exists() and HERMES_SRC != ROOT / "src":
+    sys.path.insert(0, str(HERMES_SRC))
+sys.path.insert(0, str(ROOT / "src"))
+
+from agent_request_broker import kanban_backend  # noqa: E402
+
+
+def parser() -> argparse.ArgumentParser:
+    p = argparse.ArgumentParser(description="Clean safe terminal task resources on a Kanban agent-request board.")
+    p.add_argument("--actor", default="talon", help="Operator identity to record, default: talon")
+    p.add_argument("--board", help="Kanban board slug; sets AGENT_REQUEST_KANBAN_BOARD")
+    p.add_argument("--include-archived", action="store_true", help="Also inspect archived tasks")
+    p.add_argument("--limit", type=int, help="Maximum number of terminal tasks to inspect")
+    p.add_argument("--delete-remote-branches", action="store_true", help="Actually delete safe merged remote task branches")
+    p.add_argument("--delete-registry-repositories", action="store_true", help="Actually delete matching GitLab task registry repositories")
+    p.add_argument("--delete-eyrie-registry-repositories", action="store_true", help="Actually delete matching Eyrie Docker Registry v2 task repository tags")
+    p.add_argument("--json", action="store_true", help="Print full JSON result")
+    return p
+
+
+def main(argv: list[str] | None = None) -> int:
+    args = parser().parse_args(argv)
+    if args.board:
+        os.environ["AGENT_REQUEST_KANBAN_BOARD"] = args.board
+    if args.delete_remote_branches:
+        os.environ[kanban_backend.REMOTE_BRANCH_DELETE_ENV] = "true"
+    if args.delete_registry_repositories:
+        os.environ[kanban_backend.REGISTRY_DELETE_ENV] = "true"
+    if args.delete_eyrie_registry_repositories:
+        os.environ[kanban_backend.EYRIE_REGISTRY_DELETE_ENV] = "true"
+    result = kanban_backend.cleanup_terminal_task_sweep(
+        actor=args.actor,
+        include_archived=args.include_archived,
+        limit=args.limit,
+    )
+    if args.json:
+        print(json.dumps(result, ensure_ascii=False, indent=2))
+    else:
+        print(
+            f"cleaned {result['board']}: checked={result['checked']} "
+            f"worktrees={result['removed_worktrees']} local_branches={result['removed_local_branches']} "
+            f"remote_branches={result['removed_remote_branches']} registry_repositories={result['removed_registry_repositories']}"
+        )
+    return 0
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
