+def test_register_update_refreshes_last_seen_for_current_profile(directory_env, monkeypatch):
+    from tools import agent_directory_tools as directory
+
+    monkeypatch.setattr(directory, "_now", lambda: 1000)
+    first = _loads(directory._handle_register({"mission": "Nest operations"}))
+
+    # Lifecycle-driven updates can happen when stable profile metadata changes
+    # while the agent is otherwise alive.  Treat a same-profile register/update
+    # as a freshness observation instead of preserving an old last_seen_at that
+    # makes the entry look stale immediately after a successful update.
+    monkeypatch.setattr(directory, "_now", lambda: 2000)
+    second = _loads(directory._handle_register({"mission": "Nest operations and Hermes routing"}))
+
+    assert first["task_id"] == second["task_id"]
+    assert second["last_seen_at"] == 2000
+
+
