+def test_repair_gave_up_running_divergence_restores_running(kanban_home, monkeypatch):
+    monkeypatch.setattr(kb, "_pid_alive", lambda pid: pid == 12345)
+    with kb.connect() as conn:
+        t = kb.create_task(conn, title="diverged", assignee="talon")
+        kb.claim_task(conn, t, claimer="host:worker")
+        run_id = kb._current_run_id(conn, t)
+        assert run_id is not None
+        conn.execute(
+            "UPDATE tasks SET status = 'blocked', worker_pid = ? WHERE id = ?",
+            (12345, t),
+        )
+        conn.execute(
+            "UPDATE task_runs SET worker_pid = ? WHERE id = ?",
+            (12345, run_id),
+        )
+        conn.commit()
+
+        repairs = kb.repair_gave_up_running_divergence(conn)
+
+        assert len(repairs) == 1
+        assert repairs[0]["task_id"] == t
+        assert repairs[0]["pid_alive"] is True
+        task = kb.get_task(conn, t)
+        assert task.status == "running"
+        assert task.current_run_id == run_id
+        events = kb.list_events(conn, t)
+        assert any(e.kind == "repaired" and e.run_id == run_id for e in events)
+
+
+def test_repair_gave_up_running_divergence_closes_dead_ready_run(kanban_home, monkeypatch):
+    monkeypatch.setattr(kb, "_pid_alive", lambda pid: False)
+    with kb.connect() as conn:
+        t = kb.create_task(conn, title="dead diverged", assignee="talon")
+        kb.claim_task(conn, t, claimer="host:worker")
+        run_id = kb._current_run_id(conn, t)
+        assert run_id is not None
+        conn.execute(
+            "UPDATE tasks SET status = 'ready', worker_pid = ? WHERE id = ?",
+            (12345, t),
+        )
+        conn.execute(
+            "UPDATE task_runs SET worker_pid = ? WHERE id = ?",
+            (12345, run_id),
+        )
+        conn.commit()
+
+        repairs = kb.repair_gave_up_running_divergence(conn)
+
+        assert len(repairs) == 1
+        assert repairs[0]["task_id"] == t
+        assert repairs[0]["pid_alive"] is False
+        task = kb.get_task(conn, t)
+        assert task.status == "ready"
+        assert task.current_run_id is None
+        run = conn.execute("SELECT status, outcome, ended_at FROM task_runs WHERE id = ?", (run_id,)).fetchone()
+        assert run["status"] == "crashed"
+        assert run["outcome"] == "crashed"
+        assert run["ended_at"] is not None
+        events = kb.list_events(conn, t)
+        assert any(e.kind == "repaired" and e.run_id == run_id for e in events)
+
