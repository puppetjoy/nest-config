+def test_failure_counter_does_not_block_racing_active_retry(kanban_home):
+    with kb.connect() as conn:
+        t = kb.create_task(conn, title="race", assignee="talon")
+        kb.claim_task(conn, t, claimer="host:first")
+        first_run = kb._current_run_id(conn, t)
+
+        # Simulate the timeout/crash caller's first transaction: the failed
+        # attempt is closed and the task briefly returns to ready.
+        with kb.write_txn(conn):
+            conn.execute(
+                "UPDATE tasks SET status = 'ready', claim_lock = NULL, "
+                "claim_expires = NULL, worker_pid = NULL WHERE id = ?",
+                (t,),
+            )
+            kb._end_run(conn, t, outcome="crashed", status="crashed")
+
+        # A dispatcher claims the retry before the old attempt's failure
+        # accounting trips the circuit breaker.
+        retry = kb.claim_task(conn, t, claimer="host:retry")
+        assert retry is not None
+        retry_run = kb._current_run_id(conn, t)
+        assert retry_run is not None and retry_run != first_run
+
+        tripped = kb._record_task_failure(
+            conn, t, "pid 123 not alive",
+            outcome="crashed",
+            failure_limit=1,
+            release_claim=False,
+            end_run=False,
+        )
+
+        assert tripped is False
+        task = kb.get_task(conn, t)
+        assert task.status == "running"
+        assert task.current_run_id == retry_run
+        events = kb.list_events(conn, t)
+        assert not any(e.kind == "gave_up" for e in events)
+
