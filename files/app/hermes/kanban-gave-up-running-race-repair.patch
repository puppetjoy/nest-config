+def repair_gave_up_running_divergence(
+    conn: sqlite3.Connection,
+    *,
+    task_id: Optional[str] = None,
+    dry_run: bool = False,
+) -> list[dict]:
+    """Repair tasks with a stale open ``current_run_id`` after gave_up races.
+
+    Historical cleanup races could leave a task row in an actionable-looking
+    state (``ready`` or ``blocked``) while ``current_run_id`` still pointed at
+    an open run. If that run's worker is alive, the durable invariant is that
+    the task is really ``running``. If the worker is gone, the safe repair is to
+    close the stale run, clear the current-run pointer, and leave the task
+    actionable at ``ready``. Each mutation appends an audit event.
+    """
+    params: list[object] = []
+    where = (
+        "t.status IN ('ready', 'blocked') AND t.current_run_id IS NOT NULL "
+        "AND r.id = t.current_run_id AND r.ended_at IS NULL"
+    )
+    if task_id:
+        where += " AND t.id = ?"
+        params.append(task_id)
+    rows = conn.execute(
+        "SELECT t.id, t.status, t.current_run_id, t.claim_lock, "
+        "t.claim_expires, t.worker_pid, r.claim_lock AS run_claim_lock, "
+        "r.claim_expires AS run_claim_expires, r.worker_pid AS run_worker_pid "
+        "FROM tasks t JOIN task_runs r ON r.id = t.current_run_id "
+        f"WHERE {where} ORDER BY t.id",
+        tuple(params),
+    ).fetchall()
+    repairs: list[dict] = []
+    if not rows:
+        return repairs
+    with write_txn(conn):
+        for row in rows:
+            run_id = int(row["current_run_id"])
+            pid = row["run_worker_pid"] or row["worker_pid"]
+            pid_alive = bool(pid and _pid_alive(int(pid)))
+            if pid_alive:
+                repaired_status = "running"
+                reason = "gave_up race left live current run outside running state"
+            else:
+                repaired_status = "ready"
+                reason = "gave_up race left dead current run attached to task"
+            payload = {
+                "previous_status": row["status"],
+                "repaired_status": repaired_status,
+                "run_id": run_id,
+                "worker_pid": int(pid) if pid else None,
+                "pid_alive": pid_alive,
+                "reason": reason,
+            }
+            repairs.append({"task_id": row["id"], **payload})
+            if dry_run:
+                continue
+            if pid_alive:
+                conn.execute(
+                    "UPDATE tasks SET status = 'running', "
+                    "claim_lock = COALESCE(claim_lock, ?), "
+                    "claim_expires = COALESCE(claim_expires, ?), "
+                    "worker_pid = COALESCE(worker_pid, ?) "
+                    "WHERE id = ? AND status IN ('ready', 'blocked') "
+                    "AND current_run_id = ?",
+                    (
+                        row["run_claim_lock"],
+                        row["run_claim_expires"],
+                        row["run_worker_pid"],
+                        row["id"],
+                        run_id,
+                    ),
+                )
+            else:
+                _end_run(
+                    conn, row["id"],
+                    outcome="crashed", status="crashed",
+                    error="repair closed stale current run with no live worker",
+                    metadata={"repair": payload},
+                )
+                conn.execute(
+                    "UPDATE tasks SET status = 'ready', claim_lock = NULL, "
+                    "claim_expires = NULL, worker_pid = NULL "
+                    "WHERE id = ? AND current_run_id IS NULL",
+                    (row["id"],),
+                )
+            _append_event(conn, row["id"], "repaired", payload, run_id=run_id)
+    return repairs
+
+
