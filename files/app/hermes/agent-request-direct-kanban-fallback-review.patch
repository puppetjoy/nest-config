+def test_notification_adapter_registers_direct_kanban_fallback_review():
+    if not require_hermes_src():
+        return
+    with kanban_env():
+        from agent_request_broker import kanban_backend as backend
+        from hermes_cli import kanban_db as kb
+
+        old_send = backend.telegram_send
+        messages = []
+        sends = []
+
+        def fake_send(message, **kwargs):
+            messages.append(message)
+            sends.append(kwargs)
+            return {"sent": True, "test": True}
+
+        backend.telegram_send = fake_send
+        try:
+            conn = backend.connect()
+            try:
+                task_id = kb.create_task(
+                    conn,
+                    title="Watchdog fallback review task",
+                    body=(
+                        "Watchdog follow-up for a suspicious lifecycle shape.\n\n"
+                        "Filed by the stuck-task watchdog as a direct Kanban fallback because "
+                        "agent_request_submit is not available in this cron profile's tool surface."
+                    ),
+                    assignee="talon",
+                    created_by="worker",
+                    tenant=backend.TENANT,
+                    initial_status="running",
+                    board=backend.board_name(),
+                )
+                comment_id = kb.add_comment(
+                    conn,
+                    task_id,
+                    "talon",
+                    (
+                        "Implementation review handoff:\n\n"
+                        "- Worktree: `/tmp/watchdog-fallback`\n"
+                        "- Branch: `talon/watchdog-fallback`\n"
+                        "- Commit: `abc1234`\n\n"
+                        "Changed files:\n"
+                        "- `files/app/hermes/direct-fallback.patch`\n\n"
+                        "Checks run:\n"
+                        "- focused fallback smoke: passed\n\n"
+                        "Deferred side effects:\n"
+                        "- not pushed or deployed before review"
+                    ),
+                )
+                kb._append_event(
+                    conn, task_id, "review_requested",
+                    {"summary": "review-required: direct fallback needs review", "source": "kanban_block_review_required"},
+                    run_id=None,
+                )
+            finally:
+                conn.close()
+
+            notified = backend.notify_kanban_event(
+                task_id=task_id,
+                action="review_requested",
+                actor="talon",
+                summary="review-required: direct fallback needs review",
+                event_id=901,
+            )
+
+            assert notified["notified"] is True
+            assert {item["profile"] for item in notified["notifications"]} == {"talon"}
+            assert len(messages) == 1
+            assert "Agent request review requested" in messages[0]
+            assert "Watchdog fallback review task" in messages[0]
+            assert "Task: " + task_id in messages[0]
+            assert sends[-1].get("reply_markup")
+            assert sends[-1].get("disable_notification") is False
+
+            fallback_request_id = f"ar-kanban-{task_id}"
+            conn = backend.connect()
+            try:
+                index = backend.index_for_request(conn, fallback_request_id)
+                review = backend.latest_review(conn, fallback_request_id)
+                rows = conn.execute(
+                    "SELECT request_id, task_id, action, delivered, detail FROM agent_request_notifications WHERE task_id = ?",
+                    (task_id,),
+                ).fetchall()
+                callback_rows = conn.execute(
+                    "SELECT request_id, task_id, action, review_comment_id FROM agent_request_callback_tokens WHERE task_id = ?",
+                    (task_id,),
+                ).fetchall()
+            finally:
+                conn.close()
+            assert index is not None
+            assert index.request_id == fallback_request_id
+            assert review is not None
+            assert review["review_comment_id"] == comment_id
+            assert review["worktree_path"] == "/tmp/watchdog-fallback"
+            assert review["branch_name"] == "talon/watchdog-fallback"
+            assert "direct-fallback.patch" in review["changed_files"]
+            assert len(rows) == 1
+            assert rows[0]["request_id"] == fallback_request_id
+            assert rows[0]["action"] == "review_requested"
+            assert rows[0]["delivered"] == 1
+            assert {row["action"] for row in callback_rows} == {"review_accept", "review_changes", "review_question"}
+            assert {row["review_comment_id"] for row in callback_rows} == {comment_id}
+        finally:
+            backend.telegram_send = old_send
+
+
