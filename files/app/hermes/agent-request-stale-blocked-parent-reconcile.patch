+def latest_blocked_reason_for_task(conn: Any, task_id: str) -> str:
+    row = conn.execute(
+        """
+        SELECT payload
+        FROM task_events
+        WHERE task_id = ? AND kind = 'blocked'
+        ORDER BY created_at DESC, id DESC
+        LIMIT 1
+        """,
+        (task_id,),
+    ).fetchone()
+    if not row:
+        return ""
+    try:
+        payload = json.loads(row["payload"] or "{}")
+    except Exception:
+        return ""
+    return str(payload.get("reason") or "")
+
+
+def mentioned_open_tasks(conn: Any, *, text: str, ignore_task_ids: set[str] | None = None) -> list[dict[str, Any]]:
+    ignore_task_ids = ignore_task_ids or set()
+    task_ids = sorted({match.group(0) for match in TASK_ID_RE.finditer(text) if match.group(0) not in ignore_task_ids})
+    if not task_ids:
+        return []
+    placeholders = ",".join("?" for _ in task_ids)
+    rows = conn.execute(
+        f"SELECT id, title, status FROM tasks WHERE id IN ({placeholders})",
+        task_ids,
+    ).fetchall()
+    return [dict(row) for row in rows if row["status"] not in {"done", "archived"}]
+
+
+def sync_blocked_parent_requests_for_completed_task(
+    conn: Any,
+    *,
+    task_id: str,
+    child_status: str,
+    actor: str,
+    summary: str,
+) -> list[dict[str, Any]]:
+    if child_status not in {"completed", COMPLETED_WITH_FOLLOWUP}:
+        return []
+    kanban = require_kanban()
+    updates = []
+    rows = conn.execute(
+        """
+        SELECT i.request_id, i.task_id, i.requester, i.target, i.status,
+               i.created_at, i.updated_at, i.title_raw, i.title_icon, i.title_display,
+               i.subject_raw, i.subject_icon, i.subject_display,
+               t.status AS task_status
+        FROM agent_request_index i
+        JOIN tasks t ON t.id = i.task_id
+        WHERE t.status IN ('blocked', 'review')
+          AND i.status NOT IN ('completed', 'cancelled', 'denied', 'failed_probe', 'superseded')
+        ORDER BY i.updated_at, i.created_at
+        """
+    ).fetchall()
+    for row in rows:
+        parent = AgentRequestIndex(**{key: row[key] for key in AgentRequestIndex.__dataclass_fields__})
+        reason = latest_blocked_reason_for_task(conn, parent.task_id)
+        if task_id not in reason:
+            continue
+        open_mentions = mentioned_open_tasks(conn, text=reason, ignore_task_ids={task_id, parent.task_id})
+        if open_mentions:
+            continue
+        parent_summary = (
+            f"Previously blocking follow-up task {task_id} reached {child_status}; "
+            "the stale parent block references no remaining open task, so the parent request is marked done."
+        )
+        comment_id = kanban.add_comment(
+            conn,
+            parent.task_id,
+            actor,
+            event_comment(
+                request_id=parent.request_id,
+                actor=actor,
+                action="completed",
+                summary=parent_summary,
+                response_to_requester=summary,
+            ),
+        )
+        now = int(time.time())
+        conn.execute(
+            """
+            UPDATE tasks
+               SET status = 'done', result = ?, completed_at = ?,
+                   claim_lock = NULL, claim_expires = NULL, worker_pid = NULL,
+                   current_run_id = NULL
+             WHERE id = ? AND status IN ('blocked', 'review')
+            """,
+            (parent_summary, now, parent.task_id),
+        )
+        kanban._append_event(conn, parent.task_id, "completed", {"summary": parent_summary}, run_id=None)
+        update_index_status(conn, parent.request_id, "completed")
+        notification = notify_kanban_event(
+            task_id=parent.task_id,
+            action="completed",
+            actor=actor,
+            summary=parent_summary,
+            comment_id=comment_id,
+        )
+        updates.append({
+            "parent_request_id": parent.request_id,
+            "parent_task_id": parent.task_id,
+            "status": "completed",
+            "summary": parent_summary,
+            "comment_id": comment_id,
+            "notification": notification,
+        })
+    return updates
+
