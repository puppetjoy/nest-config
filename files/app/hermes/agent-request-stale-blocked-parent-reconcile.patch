+def test_completed_native_followup_reconciles_parent_blocked_on_stale_task_reference():
+    if not require_hermes_src():
+        return
+    with kanban_env():
+        from agent_request_broker import kanban_backend as backend
+        from hermes_cli import kanban_db as kb
+
+        old_send = backend.telegram_send
+        messages = []
+        backend.telegram_send = lambda message, **_kw: messages.append(message) or {"sent": True, "test": True}
+        try:
+            parent = backend.submit({
+                "title": "Parent blocked on manually tracked follow-up",
+                "request": "Complete me when the manually referenced repair follow-up is done.",
+                "target": "talon",
+            }, requester="star")["request"]
+            conn = backend.connect()
+            try:
+                first_retest = kb.create_task(
+                    conn,
+                    title="Already completed intermediate retest",
+                    body="A prior retest in the repair path.",
+                    assignee="star",
+                    created_by="talon",
+                    tenant=backend.TENANT,
+                    initial_status="running",
+                    board=backend.board_name(),
+                )
+                repair = kb.create_task(
+                    conn,
+                    title="Manually tracked final repair",
+                    body="This native follow-up is not indexed as its own agent request.",
+                    assignee="talon",
+                    created_by="star",
+                    tenant=backend.TENANT,
+                    initial_status="running",
+                    board=backend.board_name(),
+                )
+                assert kb.complete_task(conn, first_retest, summary="Earlier retest is already done")
+                reason = (
+                    f"Waiting on follow-up `{repair}`: acceptance still not met after retest `{first_retest}`; "
+                    f"`{repair}` needs review/rollout/retest before this parent can complete."
+                )
+                assert kb.block_task(conn, parent["kanban_task_id"], reason=reason)
+                backend.update_index_status(conn, parent["id"], "in_progress")
+                assert kb.complete_task(conn, repair, summary="Final repair rollout and retest passed")
+                completed = backend.agent_request_task_completed(
+                    conn,
+                    task_id=repair,
+                    action_status="completed",
+                    actor="talon",
+                    summary="Final repair rollout and retest passed",
+                )
+                parent_item = backend.index_for_request(conn, parent["id"])
+                parent_task = kb.get_task(conn, parent["kanban_task_id"])
+            finally:
+                conn.close()
+
+            assert completed["parent_updates"]
+            assert completed["parent_updates"][0]["status"] == "completed"
+            assert parent_item.status == "completed"
+            assert parent_task.status == "done"
+            assert "stale parent block" in parent_task.result
+            assert any("marked done" in message for message in messages)
         finally:
             backend.telegram_send = old_send
 
