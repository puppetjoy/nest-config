+def test_detect_crashed_workers_requeues_worker_when_claim_owner_exited(
+    kanban_home, monkeypatch,
+):
+    """Gateway/dispatcher restarts should not burn a task failure attempt."""
+    import hermes_cli.kanban_db as _kb
+
+    host = _kb._claimer_id().split(":", 1)[0]
+    worker_pid = 91001
+    owner_pid = 91002
+
+    monkeypatch.setattr(_kb, "_pid_alive", lambda _pid: False)
+    monkeypatch.setattr(_kb.time, "time", lambda: 1_000_000.0)
+
+    with kb.connect() as conn:
+        tid = kb.create_task(conn, title="restart interrupted", assignee="a")
+        claimed = kb.claim_task(conn, tid, claimer=f"{host}:{owner_pid}")
+        assert claimed is not None
+        run_id = kb._current_run_id(conn, tid)
+        conn.execute(
+            "UPDATE tasks SET worker_pid=?, started_at=?, consecutive_failures=? WHERE id=?",
+            (worker_pid, 999_000, 0, tid),
+        )
+        conn.execute(
+            "UPDATE task_runs SET worker_pid=? WHERE id=?",
+            (worker_pid, run_id),
+        )
+        conn.commit()
+
+        crashed = kb.detect_crashed_workers(conn)
+        task = kb.get_task(conn, tid)
+        run = conn.execute(
+            "SELECT status, outcome, error, ended_at FROM task_runs WHERE id = ?",
+            (run_id,),
+        ).fetchone()
+        events = kb.list_events(conn, tid)
+
+    assert crashed == []
+    assert task is not None
+    assert task.status == "ready"
+    assert task.consecutive_failures == 0
+    assert task.last_failure_error is None
+    assert task.current_run_id is None
+    assert run["status"] == "reclaimed"
+    assert run["outcome"] == "reclaimed"
+    assert "claim owner exited" in run["error"]
+    assert run["ended_at"] is not None
+    assert any(e.kind == "interrupted" for e in events)
+    assert not any(e.kind == "gave_up" for e in events)
+
+
