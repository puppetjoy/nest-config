+def _claim_owner_pid(claim_lock: Optional[str]) -> Optional[int]:
+    """Extract the dispatcher PID from a ``host:pid`` claim lock."""
+    if not claim_lock or ":" not in claim_lock:
+        return None
+    _host, raw_pid = claim_lock.rsplit(":", 1)
+    try:
+        return int(raw_pid)
+    except (TypeError, ValueError):
+        return None
+
+
+def _claim_owner_alive(claim_lock: Optional[str]) -> Optional[bool]:
+    """Return liveness for the local dispatcher process named by a claim lock.
+
+    ``None`` means the lock does not name a host-local ``host:pid`` owner we can
+    safely inspect from this process.
+    """
+    if not claim_lock:
+        return None
+    host_prefix = f"{_claimer_id().split(':', 1)[0]}:"
+    if not claim_lock.startswith(host_prefix):
+        return None
+    owner_pid = _claim_owner_pid(claim_lock)
+    if owner_pid is None:
+        return None
+    return _pid_alive(owner_pid)
+
