 # Handlers
 # ---------------------------------------------------------------------------
 
+
+
+def _latest_event(kb, conn, task_id: str, kind: str):
+    try:
+        for event in reversed(kb.list_events(conn, task_id)):
+            if event.kind == kind:
+                return event
+    except Exception:
+        return None
+    return None
+
+
+def _notify_agent_request_event(
+    kb,
+    conn,
+    *,
+    task_id: str,
+    action: str,
+    summary: str = "",
+    event_kind: str | None = None,
+    comment_id: int | None = None,
+    comment_body: str = "",
+) -> None:
+    """Best-effort event-driven hook for Joy's agent-request adapter.
+
+    The broker owns request-aware formatting/dedupe. Kanban remains the durable
+    source of truth; this hook only fires immediately after successful writer
+    mutations so request notifications do not depend on a polling loop.
+    """
+    try:
+        from agent_request_broker import kanban_backend as agent_requests
+    except Exception:
+        return
+    try:
+        if comment_id is not None and comment_body:
+            parsed = agent_requests.parse_event_comment(comment_body)
+            if parsed:
+                agent_requests.notify_structured_comment(
+                    conn, task_id=task_id, comment_id=comment_id, body=comment_body,
+                )
+                return
+        event_id = None
+        run_id = None
+        payload_summary = ""
+        if event_kind:
+            event = _latest_event(kb, conn, task_id, event_kind)
+            if event:
+                event_id = event.id
+                run_id = event.run_id
+                payload = event.payload if isinstance(event.payload, dict) else {}
+                payload_summary = str(payload.get("summary") or payload.get("reason") or "")
+        actor = os.environ.get("HERMES_PROFILE") or os.environ.get("HERMES_KANBAN_ASSIGNEE") or "worker"
+        agent_requests.notify_kanban_event(
+            task_id=task_id,
+            action=action,
+            actor=actor,
+            summary=str(summary or payload_summary or "").strip(),
+            event_id=event_id,
+            comment_id=comment_id,
+            run_id=run_id,
+        )
+    except Exception:
+        logger.exception("agent-request notification hook failed for %s", task_id)
+
 def _handle_show(args: dict, **kw) -> str:
     """Read a task's full state: task row, parents, children, comments,
     runs (attempt history), and the last N events."""
