+def test_reply_prompts_and_callbacks_are_scoped_to_delivery_profile():
+    if not require_hermes_src():
+        return
+    with kanban_env() as tmp:
+        from agent_request_broker import kanban_backend as backend
+
+        old_send = backend.telegram_send
+        deliveries = []
+        backend.telegram_send = lambda message, *, profile="", reply_markup=None: deliveries.append((profile, reply_markup)) or {"sent": True, "test": True}
+        try:
+            first = backend.submit({
+                "title": "Profile scoped first prompt",
+                "request": "First profile should receive only its own reply.",
+                "target": "star",
+            }, requester="talon")
+            second = backend.submit({
+                "title": "Profile scoped second prompt",
+                "request": "Second profile should receive only its own reply.",
+                "target": "star",
+            }, requester="talon")
+            first_id = first["request"]["id"]
+            second_id = second["request"]["id"]
+            backend.propose({"request_id": first_id, "summary": "approval-required: first profile", "proposal": "First profile proposal."}, actor="star")
+            backend.propose({"request_id": second_id, "summary": "approval-required: second profile", "proposal": "Second profile proposal."}, actor="star")
+
+            def steer_token_for(request_id, delivery_profile):
+                conn = backend.connect()
+                try:
+                    for profile, markup in deliveries:
+                        if profile != delivery_profile or not markup:
+                            continue
+                        for row in markup["inline_keyboard"]:
+                            for button in row:
+                                if button["text"] != "✏️ Steer / request changes":
+                                    continue
+                                token = button["callback_data"].split(":", 1)[1]
+                                validation = backend.validate_callback_token(conn, token, delivery_profile=delivery_profile)
+                                if validation.get("ok") and validation["callback"]["request_id"] == request_id:
+                                    return token
+                finally:
+                    conn.close()
+                raise AssertionError(f"no {delivery_profile} steer token for {request_id}")
+
+            first_talon = steer_token_for(first_id, "talon")
+            second_star = steer_token_for(second_id, "star")
+            wrong_profile = backend.handle_telegram_callback(
+                first_talon,
+                actor="joy",
+                chat_id="chat-1",
+                thread_id="topic-1",
+                prompt_message_id=111,
+                delivery_profile="star",
+            )
+            assert wrong_profile["ok"] is False
+            assert wrong_profile["error"] == "wrong_delivery_profile"
+
+            first_prompt = backend.handle_telegram_callback(
+                first_talon,
+                actor="joy",
+                chat_id="chat-1",
+                thread_id="topic-1",
+                prompt_message_id=111,
+                delivery_profile="talon",
+            )
+            assert first_prompt["ok"] is True
+            assert first_prompt["result"]["awaiting_reply"]["delivery_profile"] == "talon"
+            second_prompt = backend.handle_telegram_callback(
+                second_star,
+                actor="joy",
+                chat_id="chat-1",
+                thread_id="topic-1",
+                prompt_message_id=222,
+                delivery_profile="star",
+            )
+            assert second_prompt["ok"] is True
+            assert second_prompt["result"]["awaiting_reply"]["delivery_profile"] == "star"
+
+            talon_routed = backend.handle_telegram_reply(
+                chat_id="chat-1",
+                thread_id="topic-1",
+                text="Talon-profile response.",
+                actor="joy",
+                delivery_profile="talon",
+            )
+            assert talon_routed["handled"] is True
+            assert talon_routed["ok"] is True
+            assert talon_routed["request_id"] == first_id
+
+            star_routed = backend.handle_telegram_reply(
+                chat_id="chat-1",
+                thread_id="topic-1",
+                text="Star-profile response.",
+                actor="joy",
+                delivery_profile="star",
+            )
+            assert star_routed["handled"] is True
+            assert star_routed["ok"] is True
+            assert star_routed["request_id"] == second_id
+        finally:
+            backend.telegram_send = old_send
+
+
 def test_stale_reply_prompts_are_removed_from_active_consideration():
     if not require_hermes_src():
         return
