+def _notify_agent_request_dispatch_event(
+    conn: sqlite3.Connection,
+    task_id: str,
+    *,
+    action: str,
+    actor: str = "",
+    summary: str = "",
+    event_kind: str = "claimed",
+) -> None:
+    """Best-effort request-aware notification for dispatcher events.
+
+    Called after claim_task/claim_review_task returns, so the durable Kanban
+    event has already been committed. The broker owns formatting, routing, and
+    dedupe; Kanban remains the source of truth.
+    """
+    try:
+        from agent_request_broker import kanban_backend as agent_requests
+    except Exception:
+        return
+    try:
+        event_id = None
+        run_id = None
+        for event in reversed(list_events(conn, task_id)):
+            if event.kind == event_kind:
+                event_id = event.id
+                run_id = event.run_id
+                break
+        agent_requests.notify_kanban_event(
+            task_id=task_id,
+            action=action,
+            actor=actor,
+            summary=summary,
+            event_id=event_id,
+            run_id=run_id,
+        )
+    except Exception:
+        _log.exception("agent-request dispatcher notification hook failed for %s", task_id)
+
