+def test_done_task_keeps_diagnostics_but_not_attention_summary(client):
+    """A completed task may retain historical/advisory diagnostics for the
+    drawer, but /board must not mark it as current attention-worthy work.
+    """
+    conn = kb.connect()
+    try:
+        task_id = kb.create_task(conn, title="done prose", assignee="alice")
+        kb.complete_task(conn, task_id, summary="mentioned t_deadbeef1234")
+    finally:
+        conn.close()
+
+    r = client.get("/api/plugins/kanban/board")
+    assert r.status_code == 200
+    data = r.json()
+    tasks = [t for col in data["columns"] for t in col["tasks"]]
+    task_dict = next(t for t in tasks if t["id"] == task_id)
+    assert task_dict["status"] == "done"
+    assert task_dict.get("diagnostics") is not None
+    assert task_dict["diagnostics"][0]["kind"] == "prose_phantom_refs"
+    assert task_dict.get("warnings") is None
+    assert task_dict.get("attention") is None
+
+
+def test_nonterminal_task_with_diagnostics_gets_attention_summary(client):
+    """Nonterminal warning/error diagnostics still feed the global attention
+    summary so actionable work is preserved.
+    """
+    conn = kb.connect()
+    try:
+        task_id = kb.create_task(conn, title="spawn", assignee="worker")
+        conn.execute(
+            "UPDATE tasks SET consecutive_failures=2, last_failure_error='x' WHERE id=?",
+            (task_id,),
+        )
+        conn.commit()
+    finally:
+        conn.close()
+
+    r = client.get("/api/plugins/kanban/board")
+    assert r.status_code == 200
+    data = r.json()
+    tasks = [t for col in data["columns"] for t in col["tasks"]]
+    task_dict = next(t for t in tasks if t["id"] == task_id)
+    assert task_dict["status"] != "done"
+    assert task_dict.get("diagnostics") is not None
+    assert task_dict.get("warnings") is not None
+    assert task_dict.get("attention") == task_dict.get("warnings")
+    assert task_dict["attention"]["highest_severity"] == "error"
+
