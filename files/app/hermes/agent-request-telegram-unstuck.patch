+        try:
+            first = backend.submit({"title": "First numbered", "request": "Need answer one", "target": "star"}, requester="talon")["request"]
+            second = backend.submit({"title": "Second numbered", "request": "Need answer two", "target": "star"}, requester="talon")["request"]
+            conn = backend.connect()
+            try:
+                kanban = backend.require_kanban()
+                for request, message_id in ((first, 16011), (second, 16012)):
+                    kanban.block_task(conn, request["kanban_task_id"], reason="needs-info: test")
+                    backend.update_index_status(conn, request["id"], "needs_info")
+                    item = backend.index_for_request(conn, request["id"])
+                    markup = backend.actionable_reply_markup(conn, item=item, action="needs_info")
+                    token = markup["inline_keyboard"][0][0]["callback_data"].split(":", 1)[1]
+                    callback = backend.validate_callback_token(conn, token)["callback"]
+                    backend.record_reply_prompt(conn, callback=callback, actor="joy", chat_id="chat-1", thread_id="topic-1", prompt_message_id=message_id)
+            finally:
+                conn.close()
+
+            listed = backend.handle_telegram_reply(chat_id="chat-1", thread_id="topic-1", text="unstuck", actor="joy")
+            assert f"`{second['kanban_task_id']}`" in listed["message"]
+
+            result = backend.handle_telegram_reply(chat_id="chat-1", thread_id="topic-1", text="unstuck 1 Answer the newest prompt", actor="joy")
+
+            assert result["handled"] is True
+            assert result["ok"] is True
+            assert result["request_id"] == second["id"]
+            remaining = _active_reply_prompt_rows(backend)
+            assert len(remaining) == 1
+            assert remaining[0]["request_id"] == first["id"]
+        finally:
+            backend.telegram_send = old_send
