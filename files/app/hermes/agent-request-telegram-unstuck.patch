+        return
+    with kanban_env() as tmp:
+        from agent_request_broker import kanban_backend as backend
+
+        old_stale_reason = backend._reply_prompt_stale_reason
+        try:
+            submitted = backend.submit({"title": "Ambiguous task selector", "request": "Two active actions", "target": "star"}, requester="talon")["request"]
+            conn = backend.connect()
+            try:
+                now = backend.now_ts()
+                for token, action, message_id in (("ambig-one", "steer", 19001), ("ambig-two", "review_question", 19002)):
+                    conn.execute(
+                        """
+                        INSERT INTO agent_request_reply_prompts
+                            (prompt_token, request_id, task_id, action, proposal_comment_id,
+                             proposal_hash, review_comment_id, review_hash, actor, chat_id,
+                             thread_id, prompt_message_id, created_at, expires_at, used_at, retired_reason)
+                        VALUES (?, ?, ?, ?, NULL, NULL, NULL, NULL, ?, ?, ?, ?, ?, ?, NULL, '')
+                        """,
+                        (token, submitted["id"], submitted["kanban_task_id"], action, "joy", "chat-1", "topic-1", message_id, now, now + 3600),
+                    )
+                conn.commit()
+            finally:
+                conn.close()
+            backend._reply_prompt_stale_reason = lambda conn, prompt: None
+
+            result = backend.handle_telegram_reply(
+                chat_id="chat-1",
