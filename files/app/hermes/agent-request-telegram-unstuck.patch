+def _retire_reply_prompts(conn: Any, prompt_tokens: list[str], *, reason: str) -> int:
+    if not prompt_tokens:
+        return 0
+    rows = [(now_ts(), reason, token) for token in prompt_tokens]
+    conn.executemany(
+        """
+        UPDATE agent_request_reply_prompts
+           SET used_at = ?, retired_reason = ?
+         WHERE prompt_token = ?
+           AND used_at IS NULL
+        """,
+        rows,
+    )
+    conn.commit()
+    return len(prompt_tokens)
+
+
+def _prompt_action_label(action: str) -> str:
+    return {
+        "steer": "proposal steering",
+        "needs_info_answer": "needs-info answer",
+        "review_changes": "review changes",
+        "review_question": "review question",
+    }.get(action, action.replace("_", " "))
+
+
+def _prompt_age_context(prompt: dict[str, Any]) -> str:
+    current = now_ts()
+    age = max(0, current - int(prompt.get("created_at") or current)) // 60
+    ttl = max(0, int(prompt.get("expires_at") or current) - current) // 60
+    return f"age {age}m, expires in {ttl}m"
+
+
+def _prompt_waiting_label(conn: Any, prompt: dict[str, Any]) -> str:
+    reason = _reply_prompt_stale_reason(conn, prompt)
+    return "waiting" if reason is None else f"not waiting: {reason}"
+
+
+def _prompt_reply_noun(action: str) -> str:
+    return {
+        "steer": "message",
+        "needs_info_answer": "answer",
+        "review_changes": "requested changes",
+        "review_question": "question",
+    }.get(action, "message")
+
+
+def _format_active_prompt_list(conn: Any, prompts: list[dict[str, Any]], *, limit: int = 8, include_details: bool = False) -> str:
+    lines: list[str] = []
+    for idx, prompt in enumerate(prompts[:limit], start=1):
+        item = index_for_request(conn, prompt["request_id"])
+        title = item.subject_display or item.title_display if item else prompt["request_id"]
+        title = clean_text(title, max_len=90)
+        action = _prompt_action_label(prompt["action"])
+        noun = _prompt_reply_noun(prompt["action"])
+        line = f"{idx}. `{prompt['task_id']}` — {action} — send: `unstuck {idx} <{noun}>`"
+        if title:
+            line += f"\n   {title}"
+        if include_details:
+            message_id = prompt.get("prompt_message_id") or "unknown"
+            line += (
+                f"\n   request: `{prompt['request_id']}`; prompt: {message_id}; "
+                f"{_prompt_age_context(prompt)}; {_prompt_waiting_label(conn, prompt)}"
+            )
+        lines.append(line)
+    if len(prompts) > limit:
+        lines.append(f"…and {len(prompts) - limit} more")
+    return "\n".join(lines)
+
+
+def _format_unstuck_help() -> str:
+    return "\n".join(
+        [
+            "Unstuck helps recover Telegram when an agent-request prompt is trapping replies.",
+            "",
+            "Useful commands:",
+            "- `/unstuck` — show active prompts with simple numbers",
+            "- `unstuck 1 try again` — send text to prompt 1",
+            "- `unstuck t_1234abcd try again` — select by visible task id",
+            "- `unstuck ar-YYYYMMDD-HHMMSS-abcdef try again` — select by request id",
+            "- `cancel prompts` — clear all active prompts in this chat",
+            "",
+            "If a selector matches more than one active prompt, I will show numbered choices instead of guessing.",
+        ]
+    )
+
+
+def _selector_hint(prompts: list[dict[str, Any]]) -> str:
+    selectors: list[str] = [str(idx) for idx in range(1, min(len(prompts), 8) + 1)]
+    for prompt in prompts[:8]:
+        for value in (prompt["task_id"], prompt["request_id"]):
+            if value not in selectors:
+                selectors.append(value)
+    return ", ".join(selectors) if selectors else "no active prompt selectors"
+
+
+def _split_unstuck_command(text: str) -> tuple[bool, str, str]:
+    match = UNSTUCK_COMMAND_RE.match(text or "")
+    if not match:
+        return False, "", text or ""
+    command = match.group("command").casefold()
+    if command.startswith("/"):
+        command = command[1:].split("@", 1)[0]
+    return True, command, (text or "")[match.end():].strip()
+
+
+def _newest_prompts_by_request_action(prompts: list[dict[str, Any]]) -> tuple[list[dict[str, Any]], list[str]]:
+    newest: dict[tuple[str, str], dict[str, Any]] = {}
+    stale_tokens: list[str] = []
+    for prompt in sorted(
+        prompts,
+        key=lambda row: (
+            int(row.get("created_at") or 0),
+            int(row.get("prompt_message_id") or 0),
+            row.get("prompt_token") or "",
+        ),
+        reverse=True,
+    ):
+        key = (prompt["request_id"], prompt["action"])
+        if key in newest:
+            stale_tokens.append(prompt["prompt_token"])
+        else:
+            newest[key] = prompt
+    return list(newest.values()), stale_tokens
+
+
+def _attach_reply_prompt_text(conn: Any, prompt: dict[str, Any], *, response: str, actor: str, reason: str = "reply consumed") -> dict[str, Any]:
+    response = sanitize_notification_text(response, max_len=1800)
+    response_labels = {
+        "steer": "Joy provided proposal steering from Telegram.",
+        "needs_info_answer": "Joy answered a blocked/needs-info prompt from Telegram.",
+        "review_changes": "Joy provided requested review changes from Telegram.",
+        "review_question": "Joy provided a review question from Telegram.",
+    }
+    comment_body = event_comment(
+        request_id=prompt["request_id"],
+        actor=actor,
+        action=f"{prompt['action']}_response",
+        summary=response_labels.get(prompt["action"], "Joy replied to an agent-request Telegram prompt."),
+        joy_steering=response,
+    )
+    require_kanban().add_comment(conn, prompt["task_id"], actor, comment_body)
+    _retire_reply_prompts(conn, [prompt["prompt_token"]], reason=reason)
+    return {
+        "handled": True,
+        "ok": True,
+        "request_id": prompt["request_id"],
+        "task_id": prompt["task_id"],
+        "action": prompt["action"],
+        "message": f"Recorded reply for {prompt['request_id']} / {prompt['task_id']} and retired that prompt.",
+    }
+
+
+def handle_telegram_unstuck(
+    *,
+    chat_id: str,
+    actor: str = "joy",
+    thread_id: str = "",
+    text: str = "",
+    command: str = "unstuck",
+) -> dict[str, Any]:
+    """List, retire, or route active Telegram agent-request reply prompts."""
+    conn = connect()
+    try:
+        raw_text = text or ""
+        stripped_text = raw_text.strip()
+        if stripped_text.casefold() in UNSTUCK_HELP_TERMS:
+            return {"handled": True, "ok": True, "message": _format_unstuck_help()}
+
+        prompts = _reply_prompt_candidates(conn, chat_id=chat_id, thread_id=thread_id)
+        prompts, duplicate_tokens = _newest_prompts_by_request_action(prompts)
+        retired_duplicates = _retire_reply_prompts(conn, duplicate_tokens, reason="older duplicate retired by unstuck") if duplicate_tokens else 0
+
+        if command == "cancel prompts" or stripped_text.casefold() in {"cancel", "cancel all", "retire all", "clear", "clear all"}:
+            retired = _retire_reply_prompts(conn, [prompt["prompt_token"] for prompt in prompts], reason="retired by unstuck command")
+            return {"handled": True, "ok": True, "retired_prompts": retired + retired_duplicates, "message": f"Retired {retired + retired_duplicates} active agent-request reply prompt(s) in this chat."}
+
+        if not prompts:
+            msg = "No active agent-request reply prompts are trapping this chat."
+            if retired_duplicates:
+                msg += f" Retired {retired_duplicates} older duplicate prompt(s)."
+            msg += " Send `/unstuck help` for examples."
+            return {"handled": True, "ok": True, "active_prompts": [], "retired_duplicates": retired_duplicates, "message": msg}
+
+        selector_label = ""
+        matching: list[dict[str, Any]] = []
+        steering = ""
+
+        number_match = re.match(r"^\s*(\d+)\b", raw_text)
+        request_match = REQUEST_ID_RE.search(raw_text)
+        task_match = TASK_ID_RE.search(raw_text)
+        if number_match:
+            selector_label = number_match.group(1)
+            selected_index = int(selector_label)
+            steering = raw_text[number_match.end() :].strip(" :-\n\t")
+            if 1 <= selected_index <= len(prompts):
+                matching = [prompts[selected_index - 1]]
+            else:
+                choices = _format_active_prompt_list(conn, prompts)
+                return {
+                    "handled": True,
+                    "ok": False,
+                    "message": f"There is no active prompt numbered {selector_label}. Use one of: {_selector_hint(prompts)}.\n{choices}",
+                }
+        elif request_match:
+            selector_label = request_match.group(0)
+            matching = [prompt for prompt in prompts if prompt["request_id"].casefold() == selector_label.casefold()]
+            steering = (raw_text[: request_match.start()] + raw_text[request_match.end() :]).strip(" :-\n\t")
+        elif task_match:
+            selector_label = task_match.group(0)
+            matching = [prompt for prompt in prompts if prompt["task_id"].casefold() == selector_label.casefold()]
+            steering = (raw_text[: task_match.start()] + raw_text[task_match.end() :]).strip(" :-\n\t")
+
+        if matching:
+            if len(matching) == 1 and steering:
+                return _attach_reply_prompt_text(conn, matching[0], response=steering, actor=actor, reason="unstuck reply consumed")
+            if len(matching) == 1:
+                noun = _prompt_reply_noun(matching[0]["action"])
+                return {
+                    "handled": True,
+                    "ok": True,
+                    "message": f"Selected {selector_label}. Send `unstuck {selector_label} <{noun}>` or reply directly to the prompt.\n{_format_active_prompt_list(conn, matching, include_details=True)}",
+                }
+            return {
+                "handled": True,
+                "ok": False,
+                "message": f"`{selector_label}` matches multiple active prompts, so I will not guess. Use one of these numbers with your message:\n{_format_active_prompt_list(conn, matching, include_details=True)}",
+            }
+
+        if request_match or task_match:
+            selector = (request_match or task_match).group(0)
+            return {
+                "handled": True,
+                "ok": False,
+                "message": f"I found `{selector}`, but it does not match an active prompt in this chat. Use one of: {_selector_hint(prompts)}. Send `/unstuck help` for examples.",
+            }
+
+        if stripped_text:
+            choices = _format_active_prompt_list(conn, prompts)
+            return {
+                "handled": True,
+                "ok": False,
+                "message": f"I did not recognize `{clean_text(stripped_text, max_len=120)}` as an unstuck selector. Use one of: {_selector_hint(prompts)}. Example: `unstuck 1 try again`.\n{choices}",
+            }
+
+        message = "Active agent-request reply prompts in this chat:\n" + _format_active_prompt_list(conn, prompts)
+        if retired_duplicates:
+            message += f"\n\nRetired {retired_duplicates} older duplicate prompt(s)."
+        message += "\n\nUse a number, request id, or task id with your reply text. Send `/unstuck help` for examples. Send `cancel prompts` to clear all active prompts in this chat."
+        return {"handled": True, "ok": True, "active_prompts": prompts, "retired_duplicates": retired_duplicates, "message": message}
+    finally:
+        conn.close()
