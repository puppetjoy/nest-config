+def test_auto_resume_parses_systemd_unix_timestamp_fallback(kanban_home, monkeypatch):
+    with kb.connect() as conn:
+        tid = kb.create_task(conn, title="unix timestamp restart")
+        assert kb.block_task(
+            conn,
+            tid,
+            reason="deployment-required: restart Talon gateway",
+            auto_resume={
+                "kind": "restart_required",
+                "service": "hermes-gateway@talon.service",
+                "scope": "user",
+            },
+        )
+        blocked_event = conn.execute(
+            "SELECT created_at FROM task_events WHERE task_id = ? AND kind = 'blocked'",
+            (tid,),
+        ).fetchone()
+        active_enter = int(blocked_event["created_at"] + 5)
+
+        monkeypatch.setattr(
+            kb,
+            "_systemctl_show_service",
+            lambda service, *, user, timeout=10: {
+                "ActiveState": "active",
+                "ActiveEnterTimestamp": f"@{active_enter}",
+                "ExecMainStartTimestamp": f"@{active_enter}",
+            },
+        )
+
+        resumed = kb.auto_resume_satisfied_blockers(conn)
+        task = kb.get_task(conn, tid)
+
+    assert resumed and resumed[0][0] == tid
+    assert task is not None
+    assert task.status == "ready"
+
+
