--- a/tests/test_agent_request_broker.py
+++ b/tests/test_agent_request_broker.py
@@ -1071,6 +1071,56 @@ def test_blocking_subrequest_marks_parent_waiting_and_child_completion_resumes_p
         finally:
             backend.telegram_send = old_send

+
+def test_completed_blocking_child_reconciles_superseded_parent_review_to_done():
+    if not require_hermes_src():
+        return
+    with kanban_env():
+        from agent_request_broker import kanban_backend as backend
+        from hermes_cli import kanban_db as kb
+
+        old_send = backend.telegram_send
+        backend.telegram_send = lambda message, **_kw: {"sent": True, "test": True}
+        try:
+            parent = backend.submit({
+                "title": "Parent stale review superseded by child",
+                "request": "Original narrow path should not remain reviewable after child completes.",
+                "target": "talon",
+            }, requester="star")["request"]
+            child = backend.submit({
+                "title": "Blocking child satisfies parent",
+                "request": "Complete the corrected broad path.",
+                "target": "star",
+                "parent_request_id": parent["id"],
+                "parent_child_classification": "blocking",
+                "parent_child_reason": "Parent review is superseded by this corrected implementation path.",
+            }, requester="talon")["request"]
+
+            conn = backend.connect()
+            try:
+                conn.execute("UPDATE tasks SET status = 'review' WHERE id = ?", (parent["kanban_task_id"],))
+                backend.update_index_status(conn, parent["id"], backend.REVIEW_REQUESTED)
+                assert kb.complete_task(conn, child["kanban_task_id"], summary="Corrected child path completed.")
+                completed = backend.agent_request_task_completed(
+                    conn,
+                    task_id=child["kanban_task_id"],
+                    action_status="completed",
+                    actor="star",
+                    summary="Corrected child path completed.",
+                )
+                parent_item = backend.index_for_request(conn, parent["id"])
+                parent_task = kb.get_task(conn, parent["kanban_task_id"])
+            finally:
+                conn.close()
+
+            assert completed["parent_updates"]
+            assert completed["parent_updates"][0]["status"] == "completed"
+            assert "superseded by the completed blocking-child path" in completed["parent_updates"][0]["summary"]
+            assert parent_item.status == "completed"
+            assert parent_task.status == "done"
+        finally:
+            backend.telegram_send = old_send
+
