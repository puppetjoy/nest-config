+def test_voice_summary_is_bounded_and_request_aware():
+    from agent_request_broker import common
+
+    message = """🦉 Agent request approved
+Title: CLI approval probe
+Subject: Restart Hermes gateway without waiting through backoff loops
+Next: Approved: remove progressive restart backoff, deploy, apply Puppet, restart Talon, and verify.
+Route: Talon → Talon
+ID: ar-20260606-000000-deadbeef
+Task: t_deadbeef
+
+Proposal:
+This verbose proposal body should not be read aloud in full. """
+
+    summary = common._voice_summary_for_notification(message)
+
+    assert len(summary) <= 220
+    assert summary.startswith("Joy, agent request approved.")
+    assert "Restart Hermes gateway" in summary
+    assert "remove progressive restart backoff" in summary
+    assert "ar-20260606" not in summary
+    assert "t_deadbeef" not in summary
+    assert "verbose proposal body" not in summary
+
+
+def test_telegram_voice_notification_replies_to_text_message_with_summary():
+    from agent_request_broker import common
+
+    keys = ["AGENT_REQUEST_TELEGRAM_VOICE_NOTIFY", "TELEGRAM_BOT_TOKEN", "TELEGRAM_HOME_CHANNEL"]
+    old_env = {key: os.environ.get(key) for key in keys}
+    old_urlopen = common.urllib.request.urlopen
+    old_tts = sys.modules.get("tools.tts_tool")
+    requests = []
+    spoken = []
+
+    class FakeResponse:
+        def __init__(self, payload: bytes):
+            self.payload = payload
+
+        def __enter__(self):
+            return self
+
+        def __exit__(self, *_exc):
+            return False
+
+        def read(self):
+            return self.payload
+
+    def fake_tts(text, output_path=None):
+        spoken.append(text)
+        assert output_path is not None
+        Path(output_path).write_bytes(b"ogg audio")
+        return json.dumps({"success": True, "file_path": output_path})
+
+    def fake_urlopen(request, timeout):
+        requests.append((request, timeout))
+        if request.full_url.endswith("/sendMessage"):
+            return FakeResponse(b'{"ok": true, "result": {"message_id": 77}}')
+        if request.full_url.endswith("/sendVoice"):
+            return FakeResponse(b'{"ok": true, "result": {"message_id": 78}}')
+        raise AssertionError(f"unexpected Telegram URL {request.full_url}")
+
+    try:
+        os.environ["AGENT_REQUEST_TELEGRAM_VOICE_NOTIFY"] = "true"
+        os.environ["TELEGRAM_BOT_TOKEN"] = "dummy-token"
+        os.environ["TELEGRAM_HOME_CHANNEL"] = "123456"
+        tts_mod = types.ModuleType("tools.tts_tool")
+        tts_mod.text_to_speech_tool = fake_tts
+        sys.modules["tools.tts_tool"] = tts_mod
+        common.urllib.request.urlopen = fake_urlopen
+
+        sent = common.telegram_send(
+            "🦉 Agent request review needed\nTitle: Telegram voice UX\nSubject: Attach concise voice summary to the text notification\nNext: Joy can accept review to deploy and restart.\nID: ar-secret-noise",
+            reply_markup={"inline_keyboard": [[{"text": "Accept", "callback_data": "review_accept:1"}]]},
+        )
+
+        assert sent["sent"] is True
+        assert sent["message_id"] == 77
+        assert sent["voice"]["sent"] is True
+        assert sent["voice"]["reply_to_message_id"] == 77
+        assert len(spoken) == 1
+        assert spoken[0] == sent["voice"]["summary"]
+        assert len(spoken[0]) <= 220
+        assert "ar-secret-noise" not in spoken[0]
+        assert len(requests) == 2
+        assert requests[0][0].full_url.endswith("/sendMessage")
+        assert b"reply_markup=" in requests[0][0].data
+        voice_request = requests[1][0]
+        assert voice_request.full_url.endswith("/sendVoice")
+        body = voice_request.data
+        assert b'name="reply_parameters"' in body
+        assert b'"message_id":77' in body
+        assert b'name="voice"' in body
+    finally:
+        common.urllib.request.urlopen = old_urlopen
+        if old_tts is None:
+            sys.modules.pop("tools.tts_tool", None)
+        else:
+            sys.modules["tools.tts_tool"] = old_tts
+        for key, value in old_env.items():
+            if value is None:
+                os.environ.pop(key, None)
+            else:
+                os.environ[key] = value
+
