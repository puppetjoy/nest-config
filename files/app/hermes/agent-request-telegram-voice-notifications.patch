+def _telegram_voice_notifications_enabled() -> bool:
+    value = (os.environ.get("AGENT_REQUEST_TELEGRAM_VOICE_NOTIFY") or "").strip().lower()
+    return value in {"1", "true", "yes", "on"}
+
+
+def _voice_summary_part(value: str, *, max_chars: int = 120) -> str:
+    text = clean_text(value, max_len=max(max_chars * 4, max_chars + 20))
+    text = re.sub(r"https?://\S+", "link", text)
+    text = re.sub(r"[`*_#>\[\]()]", "", text)
+    text = re.sub(r"\s+", " ", text).strip(" -–—:.;")
+    if len(text) > max_chars:
+        text = text[:max_chars].rsplit(" ", 1)[0].strip(" -–—:.;") + "…"
+    return text
+
+
+def _voice_summary_for_notification(message: str, *, max_chars: int = 220) -> str:
+    """Return a one-sentence spoken summary for a verbose text notification."""
+    lines = [line.strip() for line in clean_text(message, max_len=3900).splitlines() if line.strip()]
+    if not lines:
+        return ""
+
+    headline = _voice_summary_part(lines[0], max_chars=80)
+    headline = re.sub(r"^(?:[\W_]*)(?:Agent request|Kanban|Task)[:：]?\s*", "", headline, flags=re.I)
+    headline = headline or "agent request update"
+
+    fields: dict[str, str] = {}
+    for line in lines[1:]:
+        if ":" not in line:
+            continue
+        key, value = line.split(":", 1)
+        key = re.sub(r"\s+", " ", key.strip().casefold())
+        if key in {"title", "subject", "next"} and key not in fields:
+            fields[key] = _voice_summary_part(value, max_chars=140)
+
+    subject = fields.get("subject") or fields.get("title")
+    next_step = fields.get("next")
+    parts = [f"Joy, agent request {headline}"]
+    if subject:
+        parts.append(subject)
+    if next_step:
+        parts.append(next_step)
+    summary = ". ".join(part for part in parts if part).strip()
+    if not summary.endswith(('.', '!', '?', '…')):
+        summary += "."
+    if len(summary) > max_chars:
+        summary = summary[:max_chars].rsplit(" ", 1)[0].strip(" -–—:.;") + "…"
+    return summary
+
+
+def _telegram_send_voice_notification(token: str, chat_id: str, message: str, *, reply_to_message_id: int | None = None) -> dict[str, Any]:
+    summary = _voice_summary_for_notification(message)
+    if not summary:
+        return {"sent": False, "reason": "empty voice summary"}
+
+    try:
+        hermes_src = Path(os.environ.get("HERMES_SRC", "/opt/hermes-agent/src"))
+        if hermes_src.exists() and str(hermes_src) not in sys.path:
+            sys.path.insert(0, str(hermes_src))
+        from tools.tts_tool import text_to_speech_tool
+
+        audio_dir = Path(tempfile.gettempdir()) / "hermes_agent_request_voice"
+        audio_dir.mkdir(parents=True, exist_ok=True)
+        audio_path = audio_dir / f"agent_request_{uuid.uuid4().hex[:12]}.ogg"
+        result_json = text_to_speech_tool(summary, output_path=str(audio_path))
+        result = json.loads(result_json)
+        actual_path = Path(result.get("file_path") or audio_path)
+        if not result.get("success") or not actual_path.is_file():
+            return {"sent": False, "reason": result.get("error") or "TTS failed", "summary": summary}
+
+        try:
+            boundary = f"----hermes-agent-request-{uuid.uuid4().hex}"
+            body = bytearray()
+
+            def add_field(name: str, value: str) -> None:
+                body.extend(f"--{boundary}\r\n".encode())
+                body.extend(f'Content-Disposition: form-data; name="{name}"\r\n\r\n{value}\r\n'.encode())
+
+            add_field("chat_id", chat_id)
+            if reply_to_message_id is not None:
+                add_field(
+                    "reply_parameters",
+                    json.dumps(
+                        {
+                            "message_id": reply_to_message_id,
+                            "chat_id": chat_id,
+                            "allow_sending_without_reply": True,
+                        },
+                        separators=(",", ":"),
+                    ),
+                )
+            body.extend(f"--{boundary}\r\n".encode())
+            body.extend(f'Content-Disposition: form-data; name="voice"; filename="{actual_path.name}"\r\n'.encode())
+            body.extend(b"Content-Type: audio/ogg\r\n\r\n")
+            body.extend(actual_path.read_bytes())
+            body.extend(f"\r\n--{boundary}--\r\n".encode())
+            request = urllib.request.Request(
+                f"https://api.telegram.org/bot{token}/sendVoice",
+                data=bytes(body),
+                method="POST",
+                headers={"Content-Type": f"multipart/form-data; boundary={boundary}"},
+            )
+            with urllib.request.urlopen(request, timeout=20) as response:
+                payload = json.loads(response.read().decode("utf-8"))
+            return {
+                "sent": bool(payload.get("ok")),
+                "ok": payload.get("ok"),
+                "message_id": ((payload.get("result") or {}).get("message_id")),
+                "reply_to_message_id": reply_to_message_id,
+                "summary": summary,
+            }
+        finally:
+            try:
+                actual_path.unlink()
+            except OSError:
+                pass
+    except Exception as exc:  # noqa: BLE001 - voice notification remains best-effort
+        return {"sent": False, "reason": str(exc), "summary": summary}
+
+
