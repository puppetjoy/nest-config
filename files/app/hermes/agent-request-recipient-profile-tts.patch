+        sys.path.insert(0, str(hermes_src))
+    from tools.tts_tool import text_to_speech_tool
+
+    home = _tts_home_for_profile(profile)
+    saved_home = os.environ.get("HERMES_HOME")
+    saved_profile = os.environ.get("HERMES_PROFILE")
+    token = None
+    try:
+        if home is not None:
+            os.environ["HERMES_HOME"] = str(home)
+        if profile:
+            os.environ["HERMES_PROFILE"] = profile
+        try:
+            from hermes_constants import set_hermes_home_override
+
+            token = set_hermes_home_override(home) if home is not None else None
+        except Exception:
+            token = None
+        return text_to_speech_tool(summary, output_path=str(audio_path))
+    finally:
+        if token is not None:
+            try:
+                from hermes_constants import reset_hermes_home_override
+
+                reset_hermes_home_override(token)
+            except Exception:
+                pass
+        if saved_home is None:
+            os.environ.pop("HERMES_HOME", None)
+        else:
+            os.environ["HERMES_HOME"] = saved_home
+        if saved_profile is None:
+            os.environ.pop("HERMES_PROFILE", None)
+        else:
+            os.environ["HERMES_PROFILE"] = saved_profile
+
