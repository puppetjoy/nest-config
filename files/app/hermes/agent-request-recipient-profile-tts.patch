+def test_telegram_voice_notification_uses_recipient_profile_tts_context():
+    from agent_request_broker import common
+
+    with tempfile.TemporaryDirectory() as td:
+        tmp = Path(td)
+        talon_home = tmp / ".hermes" / "profiles" / "talon"
+        star_home = tmp / ".hermes" / "profiles" / "star"
+        talon_home.mkdir(parents=True)
+        star_home.mkdir(parents=True)
+        talon_home.joinpath("config.yaml").write_text(
+            "tts:\n  provider: openai\n  openai:\n    model: gpt-4o-mini-tts\n    voice: alloy\n",
+            encoding="utf-8",
+        )
+        star_home.joinpath("config.yaml").write_text(
+            "tts:\n  provider: openai\n  openai:\n    model: gpt-4o-mini-tts\n    voice: nova\n",
+            encoding="utf-8",
+        )
+
+        keys = ["HOME", "HERMES_HOME", "HERMES_PROFILE"]
+        old_env = {key: os.environ.get(key) for key in keys}
+        old_urlopen = common.urllib.request.urlopen
+        old_tts = sys.modules.get("tools.tts_tool")
+        spoken_contexts = []
+
+        class FakeResponse:
+            def __enter__(self):
+                return self
+
+            def __exit__(self, *_exc):
+                return False
+
+            def read(self):
+                return b'{"ok": true, "result": {"message_id": 612}}'
+
+        def fake_tts(text, output_path=None):
+            spoken_contexts.append({
+                "text": text,
+                "home": os.environ.get("HERMES_HOME"),
+                "profile": os.environ.get("HERMES_PROFILE"),
+            })
+            assert output_path is not None
+            Path(output_path).write_bytes(b"ogg audio")
+            return json.dumps({"success": True, "file_path": output_path})
+
+        try:
+            os.environ["HOME"] = str(tmp)
+            os.environ["HERMES_HOME"] = str(talon_home)
+            os.environ["HERMES_PROFILE"] = "talon"
+            tts_mod = types.ModuleType("tools.tts_tool")
+            tts_mod.text_to_speech_tool = fake_tts
+            sys.modules["tools.tts_tool"] = tts_mod
+            common.urllib.request.urlopen = lambda _request, timeout=20: FakeResponse()
+
+            sent = common._telegram_send_voice_notification(
+                "star-token",
+                "654321",
+                "Agent request comment\nSubject: Star voice\nNext: listen for nova",
+                reply_to_message_id=611,
+                profile="star",
+            )
+
+            assert sent["sent"] is True
+            assert sent["tts_profile"] == "star"
+            assert sent["tts_home"] == str(star_home)
+            assert sent["tts_provider"] == "openai"
+            assert sent["tts_model"] == "gpt-4o-mini-tts"
+            assert sent["tts_voice"] == "nova"
+            assert spoken_contexts == [{
+                "text": sent["summary"],
+                "home": str(star_home),
+                "profile": "star",
+            }]
+            assert os.environ["HERMES_HOME"] == str(talon_home)
+            assert os.environ["HERMES_PROFILE"] == "talon"
+        finally:
+            common.urllib.request.urlopen = old_urlopen
+            if old_tts is None:
+                sys.modules.pop("tools.tts_tool", None)
+            else:
+                sys.modules["tools.tts_tool"] = old_tts
+            for key, value in old_env.items():
+                if value is None:
+                    os.environ.pop(key, None)
+                else:
+                    os.environ[key] = value
+
+
