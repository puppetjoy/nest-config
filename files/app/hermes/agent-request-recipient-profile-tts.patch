+def _tts_profile_audit_detail(profile: str = "") -> dict[str, Any]:
+    """Return non-secret TTS config details for notification audit rows."""
+    home = _tts_home_for_profile(profile)
+    detail: dict[str, Any] = {
+        "tts_profile": profile or None,
+        "tts_home": str(home) if home is not None else None,
+    }
+    config_path = (home / "config.yaml") if home is not None else None
+    if config_path is None or not config_path.is_file():
+        return detail
+    detail["tts_config_source"] = str(config_path)
+    try:
+        import yaml
+
+        config = yaml.safe_load(config_path.read_text(encoding="utf-8")) or {}
+        tts_config = config.get("tts") if isinstance(config, dict) else None
+        if not isinstance(tts_config, dict):
+            return detail
+        provider = str(tts_config.get("provider") or "").strip()
+        if provider:
+            detail["tts_provider"] = provider
+        provider_config = tts_config.get(provider) if provider else None
+        if isinstance(provider_config, dict):
+            model = provider_config.get("model") or provider_config.get("model_id")
+            voice = provider_config.get("voice") or provider_config.get("voice_id")
+            if model:
+                detail["tts_model"] = str(model)
+            if voice:
+                detail["tts_voice"] = str(voice)
+    except Exception as exc:  # noqa: BLE001 - audit detail is best-effort
+        detail["tts_audit_error"] = str(exc)
+    return detail
+
+
