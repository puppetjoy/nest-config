+def test_review_question_reply_creates_actionable_answer_task_and_retires_prompt():
+    if not require_hermes_src():
+        return
+    with kanban_env() as tmp:
+        from agent_request_broker import kanban_backend as backend
+
+        old_send = backend.telegram_send
+        messages = []
+        markups = []
+
+        def fake_send(message, profile=None, reply_markup=None):
+            messages.append(message)
+            markups.append(reply_markup)
+            return {"sent": True, "test": True}
+
+        backend.telegram_send = fake_send
+        try:
+            talon = load_tool("talon", tmp)
+            submitted = call(talon.agent_request_submit_tool({
+                "title": "Review question smoke",
+                "request": "Produce source work and answer review questions.",
+                "target": "talon",
+            }))
+            request = submitted["request"]
+            handoff = call(talon.agent_request_review_handoff_tool({
+                "request_id": request["id"],
+                "summary": "review-required: source change ready",
+                "worktree_path": "/tmp/worktrees/t_review_question",
+                "branch_name": "talon/t_review_question",
+                "commit_refs": "abc1234",
+                "changed_files": "src/example.py",
+                "tests_run": "pytest tests/test_example.py -q (passed)",
+                "remaining_actions": "push branch; merge to main; deploy; restart Hermes; verify live",
+                "side_effects_deferred": "push/merge/deploy/restart intentionally not performed before review",
+            }))
+            assert handoff["request"]["kanban_status"] == "review"
+            assert backend.event_label("review_question_answer_needed") == "review question answer needed"
+
+            review_markup = next(markup for markup in markups if markup and any(
+                button["text"] == "❓ Ask question"
+                for row in markup["inline_keyboard"]
+                for button in row
+            ))
+            question_token = next(
+                button["callback_data"].split(":", 1)[1]
+                for row in review_markup["inline_keyboard"]
+                for button in row
+                if button["text"] == "❓ Ask question"
+            )
+            prompted = backend.handle_telegram_callback(
+                question_token,
+                actor="joy",
+                chat_id="chat-1",
+                thread_id="topic-1",
+                prompt_message_id=4242,
+            )
+            assert prompted["ok"] is True
+            assert prompted["result"]["awaiting_reply"]["request_id"] == request["id"]
+
+            conn = backend.connect()
+            try:
+                active_prompt = conn.execute(
+                    "SELECT * FROM agent_request_reply_prompts WHERE request_id = ? AND action = 'review_question' AND used_at IS NULL",
+                    (request["id"],),
+                ).fetchone()
+                assert active_prompt["review_comment_id"] == handoff["review"]["review_comment_id"]
+                assert active_prompt["review_hash"] == handoff["review"]["review_hash"]
+            finally:
+                conn.close()
+
+            reply = backend.handle_telegram_reply(
+                chat_id="chat-1",
+                thread_id="topic-1",
+                reply_to_message_id=4242,
+                text="Does the deploy step restart Talon or only Star?",
+                actor="joy",
+            )
+            assert reply["handled"] is True
+            assert reply["ok"] is True
+            assert reply["action"] == "review_question"
+            assert reply["answer_task_id"].startswith("t_")
+
+            conn = backend.connect()
+            try:
+                original_task = backend.require_kanban().get_task(conn, request["kanban_task_id"])
+                answer_task = backend.require_kanban().get_task(conn, reply["answer_task_id"])
+                comments = "\n".join(comment.body for comment in backend.require_kanban().list_comments(conn, request["kanban_task_id"]))
+                prompts = conn.execute(
+                    "SELECT used_at, retired_reason FROM agent_request_reply_prompts WHERE prompt_message_id = 4242"
+                ).fetchall()
+            finally:
+                conn.close()
+            assert original_task.status == "review"
+            assert answer_task.status == "ready"
+            assert answer_task.assignee == "talon"
+            assert "Original request id: " + request["id"] in answer_task.body
+            assert "Review comment id: " + str(handoff["review"]["review_comment_id"]) in answer_task.body
+            assert handoff["review"]["review_hash"] in answer_task.body
+            assert "Does the deploy step restart Talon or only Star?" in answer_task.body
+            assert "review_question_response" in comments
+            assert "review_question_answer_needed" in comments
+            assert "answer_task_id" in comments
+            assert reply["answer_task_id"] in comments
+            assert prompts[0]["used_at"] is not None
+            assert prompts[0]["retired_reason"] == "reply consumed"
+            assert any("Agent request review question answer needed" in message for message in messages)
+        finally:
+            backend.telegram_send = old_send
+
+
