+def _review_question_answer_body(
+    *,
+    item: AgentRequestIndex,
+    original_task_id: str,
+    question: str,
+    review: dict[str, Any] | None,
+) -> str:
+    review = review or {}
+    return "\n".join([
+        "Agent request review-question answer task.",
+        "",
+        f"Original request id: {item.request_id}",
+        f"Original task id: {original_task_id}",
+        f"Requester: {item.requester}",
+        f"Target: {item.target}",
+        f"Review comment id: {review.get('review_comment_id') or ''}",
+        f"Review hash: {review.get('review_hash') or ''}",
+        "",
+        "Joy asked this review question:",
+        question,
+        "",
+        "Review artifact binding:",
+        f"- worktree_path: {review.get('worktree_path') or ''}",
+        f"- branch_name: {review.get('branch_name') or ''}",
+        f"- commit_refs: {review.get('commit_refs') or ''}",
+        f"- changed_files: {review.get('changed_files') or ''}",
+        f"- tests_run: {review.get('tests_run') or ''}",
+        f"- remaining_actions: {review.get('remaining_actions') or ''}",
+        f"- side_effects_deferred: {review.get('side_effects_deferred') or ''}",
+        "",
+        "Answer instructions:",
+        "- Answer Joy's review question for the bound review artifact.",
+        "- Comment the answer on the original task so Joy sees the response in the review thread.",
+        "- Do not push, merge, deploy, apply Puppet, or restart services unless the original review is accepted.",
+    ])
+
+
+def _create_review_question_answer_task(
+    conn: Any,
+    *,
+    item: AgentRequestIndex,
+    prompt: dict[str, Any],
+    question: str,
+    actor: str,
+) -> dict[str, Any]:
+    kanban = require_kanban()
+    review = latest_review(conn, item.request_id)
+    title_source = item.subject_display or item.title_display or item.request_id
+    title = f"❓ Answer review question for {title_source}"
+    body = _review_question_answer_body(
+        item=item,
+        original_task_id=prompt["task_id"],
+        question=question,
+        review=review,
+    )
+    answer_task_id = kanban.create_task(
+        conn,
+        title=clean_text(title, max_len=200),
+        body=body,
+        assignee=item.target,
+        created_by=actor,
+        tenant=TENANT,
+        priority=URGENCY_PRIORITIES["high"],
+        idempotency_key=f"agent-request-review-question-answer:{prompt['prompt_token']}",
+        board=board_name(),
+    )
+    answer_comment = event_comment(
+        request_id=item.request_id,
+        actor=actor,
+        action="review_question_answer_needed",
+        summary=f"Review question answer task {answer_task_id} created for {item.target}.",
+        answer_task_id=answer_task_id,
+        review_comment_id=prompt.get("review_comment_id") or "",
+        review_hash=prompt.get("review_hash") or "",
+        joy_steering=question,
+    )
+    comment_id = kanban.add_comment(conn, prompt["task_id"], actor, answer_comment)
+    notification = notify_structured_comment(conn, task_id=prompt["task_id"], comment_id=comment_id, body=answer_comment)
+    return {
+        "answer_task_id": answer_task_id,
+        "review_comment_id": prompt.get("review_comment_id"),
+        "review_hash": prompt.get("review_hash"),
+        "notification": notification,
+    }
+
+
