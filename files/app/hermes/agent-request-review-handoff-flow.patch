+    tests_run = clean_text(args.get("tests_run"), max_len=4000)
+    remaining_actions = clean_text(args.get("remaining_actions"), max_len=4000)
+    side_effects_deferred = clean_text(args.get("side_effects_deferred"), max_len=4000)
