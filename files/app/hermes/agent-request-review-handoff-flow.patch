+#!/usr/bin/env python3
+"""Record trusted Joy review acceptance for a Kanban-backed agent request.
+
+This command is intentionally an operator surface, not a Hermes model-facing
+tool. It binds acceptance to the latest structured review handoff comment/hash
+recorded by the Kanban backend.
+"""
+from __future__ import annotations
+
+import argparse
+import json
+import os
+import sys
+from pathlib import Path
+
+ROOT = Path(__file__).resolve().parents[1]
+HERMES_SRC = Path(os.environ.get("HERMES_SRC", "/opt/hermes-agent/src"))
+if HERMES_SRC.exists() and HERMES_SRC != ROOT / "src":
+    sys.path.insert(0, str(HERMES_SRC))
+sys.path.insert(0, str(ROOT / "src"))
+
+from agent_request_broker import kanban_backend  # noqa: E402
+
+
+def parser() -> argparse.ArgumentParser:
+    p = argparse.ArgumentParser(
+        description="Record trusted Joy acceptance for the latest review handoff on a Kanban-backed agent request.",
+    )
+    p.add_argument("request_id", help="Agent request id, for example ar-20260604-...")
+    p.add_argument("--acceptance", help="Acceptance text from Joy")
+    p.add_argument("--steering", dest="joy_steering", help="Optional constraints or steering from Joy")
+    p.add_argument("--approver", default="joy", help="Trusted approver identity to record, default: joy")
+    p.add_argument("--board", help="Kanban board slug; sets AGENT_REQUEST_KANBAN_BOARD for this invocation")
+    p.add_argument("--json", action="store_true", help="Print full JSON result instead of a short summary")
+    return p
+
+
+def main(argv: list[str] | None = None) -> int:
+    args = parser().parse_args(argv)
+    if args.board:
+        os.environ["AGENT_REQUEST_KANBAN_BOARD"] = args.board
+    result = kanban_backend.trusted_accept_review(
+        {
+            "request_id": args.request_id,
+            "acceptance": args.acceptance or "",
+            "joy_steering": args.joy_steering or "",
+        },
+        approver=args.approver,
+    )
+    if args.json:
+        print(json.dumps(result, ensure_ascii=False, indent=2))
+    elif "error" in result:
+        print(f"error: {result['error']}", file=sys.stderr)
+    else:
+        acceptance = result["review_acceptance"]
+        request = result["request"]
+        print(
+            f"accepted review for {request['id']} on {result['board']}: "
+            f"{acceptance['acceptance_id']} review_comment={acceptance['review_comment_id']} "
+            f"hash={acceptance['review_hash'][:12]}"
+        )
+    return 1 if "error" in result else 0
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
