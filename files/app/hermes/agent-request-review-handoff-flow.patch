+def record_reply_prompt(
+    conn: Any,
+    *,
+    callback: dict[str, Any],
+    actor: str,
+    chat_id: str,
+    thread_id: str = "",
+    prompt_message_id: int | None = None,
+) -> dict[str, Any]:
+    """Persist a bounded Telegram free-form reply prompt."""
+    prompt_token = _make_callback_token()
+    created_at = now_ts()
+    request_id = clean_text(callback["request_id"], max_len=80)
+    action = clean_text(callback["action"], max_len=80)
+    # A newer prompt for the same request/action supersedes older prompts. Use
+    # used_at as the inactive marker so old deployments need no schema change.
+    conn.execute(
+        """
+        UPDATE agent_request_reply_prompts
+           SET used_at = ?
+         WHERE request_id = ?
+           AND action = ?
+           AND used_at IS NULL
+        """,
+        (created_at, request_id, action),
+    )
+    conn.execute(
+        """
+        INSERT INTO agent_request_reply_prompts
+            (prompt_token, request_id, task_id, action, proposal_comment_id,
+             proposal_hash, review_comment_id, review_hash, actor, chat_id,
+             thread_id, prompt_message_id, created_at, expires_at, used_at)
+        VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, NULL)
+        """,
+        (
+            prompt_token,
+            request_id,
+            callback["task_id"],
+            action,
+            callback.get("proposal_comment_id"),
+            callback.get("proposal_hash"),
+            callback.get("review_comment_id"),
+            callback.get("review_hash"),
+            actor,
+            clean_text(chat_id, max_len=80),
+            clean_text(thread_id or "", max_len=80),
+            int(prompt_message_id) if prompt_message_id is not None else None,
+            created_at,
+            created_at + REPLY_PROMPT_TTL_SECONDS,
+        ),
+    )
+    conn.commit()
+    return {
+        "prompt_token": prompt_token,
+        "request_id": request_id,
+        "task_id": callback["task_id"],
+        "action": action,
+        "expires_at": created_at + REPLY_PROMPT_TTL_SECONDS,
+    }
+
+
+def _reply_prompt_stale_reason(conn: Any, prompt: dict[str, Any]) -> str | None:
+    item = index_for_request(conn, prompt["request_id"])
+    task = require_kanban().get_task(conn, prompt["task_id"])
+    if not item or not task:
+        return "request no longer exists"
+    if prompt["action"] == "steer":
+        if item.status != "proposed" or task.status != "blocked":
+            return "request is no longer awaiting proposal steering"
+        current = latest_proposal(conn, prompt["request_id"])
+        if not current:
+            return "no current proposal remains"
+        if (
+            int(current["proposal_comment_id"]) != int(prompt["proposal_comment_id"] or -1)
+            or current["proposal_hash"] != prompt["proposal_hash"]
+        ):
+            return "proposal changed"
+    elif prompt["action"] == "needs_info_answer":
+        if item.status != "needs_info" and task.status != "blocked":
+            return "request is no longer waiting for information"
+    elif prompt["action"] in {"review_changes", "review_question"}:
+        if item.status != REVIEW_REQUESTED or task.status != "review":
+            return "request is no longer awaiting review feedback"
+        current_review = latest_review(conn, prompt["request_id"])
+        if not current_review:
+            return "no current review handoff remains"
+        if (
+            int(current_review["review_comment_id"]) != int(prompt["review_comment_id"] or -1)
+            or current_review["review_hash"] != prompt["review_hash"]
+        ):
+            return "review handoff changed"
+    return None
+
+
+def _active_reply_prompts(rows: list[Any], conn: Any) -> list[dict[str, Any]]:
+    active: list[dict[str, Any]] = []
+    stale_tokens: list[str] = []
+    for row in rows:
+        prompt = dict(row)
+        if _reply_prompt_stale_reason(conn, prompt):
+            stale_tokens.append(prompt["prompt_token"])
+        else:
+            active.append(prompt)
+    if stale_tokens:
+        conn.executemany(
+            "UPDATE agent_request_reply_prompts SET used_at = ? WHERE prompt_token = ? AND used_at IS NULL",
+            [(now_ts(), token) for token in stale_tokens],
+        )
+        conn.commit()
+    return active
+
+
+def _reply_prompt_candidates(
+    conn: Any,
+    *,
+    chat_id: str,
+    thread_id: str = "",
+    reply_to_message_id: int | None = None,
+) -> list[dict[str, Any]]:
+    now = now_ts()
+    chat_id = clean_text(chat_id, max_len=80)
+    thread_id = clean_text(thread_id or "", max_len=80)
+    if reply_to_message_id is not None:
+        rows = conn.execute(
+            """
+            SELECT *
+            FROM agent_request_reply_prompts
+            WHERE chat_id = ?
+              AND prompt_message_id = ?
+              AND used_at IS NULL
+              AND expires_at >= ?
+            ORDER BY created_at DESC
+            """,
+            (chat_id, int(reply_to_message_id), now),
+        ).fetchall()
+    else:
+        rows = conn.execute(
+            """
+            SELECT *
+            FROM agent_request_reply_prompts
+            WHERE chat_id = ?
+              AND thread_id = ?
+              AND used_at IS NULL
+              AND expires_at >= ?
+            ORDER BY created_at DESC
+            LIMIT 8
+            """,
+            (chat_id, thread_id, now),
+        ).fetchall()
+    return _active_reply_prompts(rows, conn)
+
+
+def _active_prompt_context(conn: Any, prompts: list[dict[str, Any]]) -> str:
+    lines = [
+        "More than one agent-request reply prompt is active here.",
+        "Reply directly to the intended prompt message, or include exactly one request id in your reply.",
+        "Active prompts:",
+    ]
+    for prompt in prompts[:8]:
+        item = index_for_request(conn, prompt["request_id"])
+        title = item.subject_display or item.title_display if item else prompt["request_id"]
+        message_id = prompt.get("prompt_message_id") or "unknown"
+        expires = datetime.fromtimestamp(int(prompt["expires_at"]), timezone.utc).strftime("%H:%M UTC")
+        lines.append(
+            f"- {prompt['request_id']} / {prompt['task_id']} / {prompt['action']} — {title} "
+            f"(prompt message {message_id}, expires {expires})"
+        )
+    return "\n".join(lines)
+
+
+def _reply_prompt_request_ids(text: str) -> set[str]:
+    return set(re.findall(r"ar-\d{8}-\d{6}-[0-9a-fA-F]+", text))
+
+
+def _mark_reply_prompt_used(conn: Any, prompt_token: str) -> None:
+    conn.execute("UPDATE agent_request_reply_prompts SET used_at = ? WHERE prompt_token = ?", (now_ts(), prompt_token))
+    conn.commit()
+
+
+def handle_telegram_reply(
+    *,
+    chat_id: str,
+    text: str,
+    actor: str = "joy",
+    thread_id: str = "",
+    reply_to_message_id: int | None = None,
+) -> dict[str, Any]:
+    """Route a Telegram free-form reply through its originating action prompt."""
+    response = clean_text(text, max_len=4000)
+    if not response:
+        return {"handled": False, "ok": False, "error": "empty_reply", "message": "Empty agent-request reply."}
+    conn = connect()
+    try:
+        candidates = _reply_prompt_candidates(
+            conn,
+            chat_id=chat_id,
+            thread_id=thread_id,
+            reply_to_message_id=reply_to_message_id,
+        )
+        if not candidates:
+            return {"handled": False, "ok": False, "error": "no_prompt", "message": "No active agent-request reply prompt matched this message."}
+        if len(candidates) > 1 and reply_to_message_id is None:
+            mentioned = _reply_prompt_request_ids(response)
+            matching = [prompt for prompt in candidates if prompt["request_id"] in mentioned]
+            if len(matching) == 1:
+                candidates = matching
+            else:
+                return {
+                    "handled": True,
+                    "ok": False,
+                    "error": "ambiguous_prompt",
+                    "message": _active_prompt_context(conn, candidates),
+                }
+        prompt = candidates[0]
+        if prompt["action"] in CALLBACK_BINDING_ACTIONS:
+            current = latest_proposal(conn, prompt["request_id"])
+            if not current:
+                return {"handled": True, "ok": False, "error": "stale_prompt", "message": "No current proposal remains for this request. Please retry from a fresh action button."}
+            if (
+                int(current["proposal_comment_id"]) != int(prompt["proposal_comment_id"] or -1)
+                or current["proposal_hash"] != prompt["proposal_hash"]
+            ):
+                return {"handled": True, "ok": False, "error": "stale_prompt", "message": "That reply prompt is stale because the proposal changed. Please retry from the latest action button."}
+        if prompt["action"] in REVIEW_CALLBACK_BINDING_ACTIONS:
+            current_review = latest_review(conn, prompt["request_id"])
+            if not current_review:
+                return {"handled": True, "ok": False, "error": "stale_prompt", "message": "No current review handoff remains for this request. Please retry from a fresh action button."}
+            if (
+                int(current_review["review_comment_id"]) != int(prompt["review_comment_id"] or -1)
+                or current_review["review_hash"] != prompt["review_hash"]
+            ):
+                return {"handled": True, "ok": False, "error": "stale_prompt", "message": "That reply prompt is stale because the review handoff changed. Please retry from the latest action button."}
+        item = index_for_request(conn, prompt["request_id"])
+        task = require_kanban().get_task(conn, prompt["task_id"])
+        if not item or not task:
+            return {"handled": True, "ok": False, "error": "missing_request", "message": "This request no longer exists."}
+        response_labels = {
+            "steer": "Joy provided proposal steering from Telegram.",
+            "needs_info_answer": "Joy answered a blocked/needs-info prompt from Telegram.",
+            "review_changes": "Joy provided requested review changes from Telegram.",
+            "review_question": "Joy provided a review question from Telegram.",
+        }
+        comment_body = event_comment(
+            request_id=prompt["request_id"],
+            actor=actor,
+            action=f"{prompt['action']}_response",
+            summary=response_labels.get(prompt["action"], "Joy replied to an agent-request Telegram prompt."),
+            joy_steering=response,
+        )
+        require_kanban().add_comment(conn, prompt["task_id"], actor, comment_body)
+        resumed = False
+        resume_status = task.status
+        if task.status == "blocked":
+            resumed, resume_error, resume_status = resume_blocked_task_from_reply(
+                conn, prompt["task_id"], actor=actor, action=prompt["action"]
+            )
+            if not resumed:
+                _mark_reply_prompt_used(conn, prompt["prompt_token"])
+        message = f"Recorded reply for {prompt['request_id']} / {prompt['task_id']}."
+        if resumed:
+            message += " Task resumed and is eligible to continue."
+        return {
+            "handled": True,
+            "ok": True,
+            "request_id": prompt["request_id"],
+            "task_id": prompt["task_id"],
+            "action": prompt["action"],
+            "resumed": resumed,
+            "kanban_status": resume_status,
+            "message": message,
+        }
+    finally:
+        conn.close()
+
