+def trusted_accept_review(args: dict[str, Any], *, approver: str = "joy") -> dict[str, Any]:
+    """Record trusted Joy/operator acceptance for the latest review handoff."""
+    kanban = require_kanban()
+    request_id = clean_text(args.get("request_id"), max_len=80)
+    acceptance_text = clean_text(args.get("acceptance"), max_len=4000)
+    steering = clean_text(args.get("joy_steering"), max_len=8000)
+    if not request_id:
+        return {"error": "request_id is required"}
+    if not acceptance_text and not steering:
+        return {"error": "acceptance and/or joy_steering is required"}
+    conn = connect()
+    try:
+        item = index_for_request(conn, request_id)
+        if not item:
+            return {"error": f"No request found with id {request_id}"}
+        task = kanban.get_task(conn, item.task_id)
+        if task is None:
+            return {"error": f"Kanban task not found for request {request_id}: {item.task_id}"}
+        review = latest_review(conn, request_id)
+        if not review:
+            return {"error": "No structured review handoff is recorded for this request"}
+        acceptance_id = make_review_acceptance_id()
+        created = now_ts()
+        comment_body = event_comment(
+            request_id=request_id,
+            actor=approver,
+            action="review_accepted",
+            summary="Joy accepted the referenced review handoff",
+            joy_steering=steering,
+            acceptance_id=acceptance_id,
+            accepted_by=approver,
+            review_comment_id=str(review["review_comment_id"]),
+            review_hash=review["review_hash"],
+            remaining_actions=review.get("remaining_actions") or "",
+            joy_approval=acceptance_text,
+        )
+        comment_id = kanban.add_comment(conn, item.task_id, approver, comment_body)
+        conn.execute(
+            """
+            INSERT INTO agent_request_review_acceptances
+                (acceptance_id, request_id, review_comment_id, review_hash,
+                 accepted_by, acceptance_text, steering, created_at)
+            VALUES (?, ?, ?, ?, ?, ?, ?, ?)
+            """,
+            (acceptance_id, request_id, int(review["review_comment_id"]), review["review_hash"], approver, acceptance_text, steering, created),
+        )
+        conn.commit()
+        accepted, reason = accept_task_review(conn, item.task_id, actor=approver, reason="Joy accepted review handoff")
+        if not accepted:
+            return {"error": f"Review acceptance recorded but task promotion failed: {reason}"}
+        update_index_status(conn, request_id, REVIEW_ACCEPTED)
+        request_notification = notify_structured_comment(
+            conn, task_id=item.task_id, comment_id=comment_id, body=comment_body,
+        )
+        item = index_for_request(conn, request_id)
+        assert item is not None
+        return {
+            "request": public_request(conn, item),
+            "review_acceptance": {
+                "acceptance_id": acceptance_id,
+                "review_comment_id": review["review_comment_id"],
+                "review_hash": review["review_hash"],
+                "accepted_by": approver,
+                "created_at": created,
+            },
+            "board": board_name(),
+            "request_notification": request_notification,
+        }
+    finally:
+        conn.close()
