+        )
+        item = index_for_request(conn, request_id)
+        assert item is not None
+        return {
+            "request": public_request(conn, item),
+            "review_acceptance": {
+                "acceptance_id": acceptance_id,
+                "review_comment_id": review["review_comment_id"],
+                "review_hash": review["review_hash"],
+                "accepted_by": approver,
+                "created_at": created,
+            },
+            "board": board_name(),
+            "request_notification": request_notification,
+        }
+    finally:
+        conn.close()
