+def handle_telegram_reply(
+    *,
+    chat_id: str,
+    text: str,
+    actor: str = "joy",
+    thread_id: str = "",
+    reply_to_message_id: int | None = None,
+) -> dict[str, Any]:
+    """Route a Telegram free-form reply through its originating action prompt."""
+    response = clean_text(text, max_len=4000)
+    if not response:
+        return {"handled": False, "ok": False, "error": "empty_reply", "message": "Empty agent-request reply."}
+    conn = connect()
+    try:
+        candidates = _reply_prompt_candidates(
+            conn,
+            chat_id=chat_id,
+            thread_id=thread_id,
+            reply_to_message_id=reply_to_message_id,
+        )
+        if not candidates:
+            return {"handled": False, "ok": False, "error": "no_prompt", "message": "No active agent-request reply prompt matched this message."}
+        if len(candidates) > 1 and reply_to_message_id is None:
+            return {
+                "handled": True,
+                "ok": False,
+                "error": "ambiguous_prompt",
+                "message": "More than one agent-request reply prompt is active here. Please reply directly to the prompt message or include the request id.",
+            }
+        prompt = candidates[0]
+        if prompt["action"] in CALLBACK_BINDING_ACTIONS:
+            current = latest_proposal(conn, prompt["request_id"])
+            if not current:
+                return {"handled": True, "ok": False, "error": "stale_prompt", "message": "No current proposal remains for this request. Please retry from a fresh action button."}
+            if (
+                int(current["proposal_comment_id"]) != int(prompt["proposal_comment_id"] or -1)
+                or current["proposal_hash"] != prompt["proposal_hash"]
+            ):
+                return {"handled": True, "ok": False, "error": "stale_prompt", "message": "That reply prompt is stale because the proposal changed. Please retry from the latest action button."}
+        item = index_for_request(conn, prompt["request_id"])
+        task = require_kanban().get_task(conn, prompt["task_id"])
+        if not item or not task:
+            return {"handled": True, "ok": False, "error": "missing_request", "message": "This request no longer exists."}
+        response_labels = {
+            "steer": "Joy provided proposal steering from Telegram.",
+            "needs_info_answer": "Joy answered a blocked/needs-info prompt from Telegram.",
+            "review_changes": "Joy provided requested review changes from Telegram.",
+            "review_question": "Joy provided a review question from Telegram.",
+        }
+        comment_body = event_comment(
+            request_id=prompt["request_id"],
+            actor=actor,
+            action=f"{prompt['action']}_response",
+            summary=response_labels.get(prompt["action"], "Joy replied to an agent-request Telegram prompt."),
+            joy_steering=response,
+        )
+        require_kanban().add_comment(conn, prompt["task_id"], actor, comment_body)
+        _mark_reply_prompt_used(conn, prompt["prompt_token"])
+        return {
+            "handled": True,
+            "ok": True,
+            "request_id": prompt["request_id"],
+            "task_id": prompt["task_id"],
+            "action": prompt["action"],
+            "message": f"Recorded reply for {prompt['request_id']} / {prompt['task_id']}.",
+        }
+    finally:
+        conn.close()
+
+
