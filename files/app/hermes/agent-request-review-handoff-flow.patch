+def test_review_handoff_and_trusted_acceptance_resume_followthrough():
+    if not require_hermes_src():
+        return
+    with kanban_env() as tmp:
+        from agent_request_broker import kanban_backend as backend
+
+        old_send = backend.telegram_send
+        messages = []
+        markups = []
+
+        def fake_send(message, profile=None, reply_markup=None):
+            messages.append(message)
+            markups.append(reply_markup)
+            return {"sent": True, "test": True}
+
+        backend.telegram_send = fake_send
+        try:
+            talon = load_tool("talon", tmp)
+            submitted = call(talon.agent_request_submit_tool({
+                "title": "Review smoke",
+                "request": "Implement a small source change and hand it off for review",
+                "target": "talon",
+                "urgency": "high",
+            }))
+            request = submitted["request"]
+            handoff = call(talon.agent_request_review_handoff_tool({
+                "request_id": request["id"],
+                "summary": "review-required: source change ready",
+                "worktree_path": "/tmp/worktrees/t_review",
+                "branch_name": "talon/t_review",
+                "commit_refs": "abc1234",
+                "changed_files": "src/example.py\ntests/test_example.py",
+                "tests_run": "pytest tests/test_example.py -q (passed)",
+                "remaining_actions": "push branch; merge to main; deploy; apply Puppet; restart Hermes; verify live",
+                "side_effects_deferred": "push/merge/deploy/apply/restart intentionally not performed before review",
+            }))
+            assert handoff["request"]["status"] == "reviewing"
+            assert handoff["request"]["work_status"] == "review_needed"
+            assert handoff["request"]["review_status"] == "reviewing"
+            assert handoff["request"]["kanban_status"] == "review"
+            assert handoff["request"]["approval_status"] == "not_required"
+            assert handoff["request"]["review"]["remaining_actions"].startswith("push branch")
+            assert len(handoff["review"]["review_hash"]) == 64
+            assert any("Agent request review requested" in message for message in messages)
+            review_markup = next(markup for markup in markups if markup and any(
+                button["text"] == "✅ Accept review"
+                for row in markup["inline_keyboard"]
+                for button in row
+            ))
+            review_labels = {
+                button["text"]
+                for row in review_markup["inline_keyboard"]
+                for button in row
+            }
+            assert review_labels == {"✅ Accept review", "🔁 Request changes", "❓ Ask question"}
+
+            premature = backend.update({
+                "request_id": request["id"],
+                "status": "completed",
+                "summary": "Should not complete before trusted review acceptance",
+            }, actor="talon")
+            assert "not been accepted through the trusted path" in premature["error"]
+
+            trusted = backend.trusted_accept_review({
+                "request_id": request["id"],
+                "acceptance": "Review accepted; continue through the listed follow-through actions.",
+            }, approver="joy")
+            assert trusted["request"]["status"] == "review_accepted"
+            assert trusted["request"]["review_status"] == "accepted"
+            assert trusted["request"]["kanban_status"] == "ready"
+            assert trusted["request"]["work_status"] == "ready"
+            assert trusted["request"]["approval_status"] == "not_required"
+            assert trusted["review_acceptance"]["review_comment_id"] == handoff["review"]["review_comment_id"]
+            assert trusted["review_acceptance"]["review_hash"] == handoff["review"]["review_hash"]
+            assert any("Agent request review accepted" in message for message in messages)
+
+            stale = backend.trusted_accept_review({
+                "request_id": request["id"],
+                "acceptance": "Repeat acceptance is idempotent against the same latest handoff.",
+            }, approver="joy")
+            assert stale["review_acceptance"]["review_hash"] == handoff["review"]["review_hash"]
+
+            completed = backend.update({
+                "request_id": request["id"],
+                "status": "completed",
+                "summary": "Completed after review acceptance and live verification",
+            }, actor="talon")
+            assert completed["request"]["status"] == "completed"
+            assert completed["request"]["kanban_status"] == "done"
+            assert completed["request"]["review_status"] == "accepted"
+        finally:
