+def mark_task_review(conn: Any, task_id: str, *, summary: str) -> bool:
+    kanban = require_kanban()
+    with kanban.write_txn(conn):
+        cur = conn.execute(
+            """
+            UPDATE tasks
+               SET status = 'review', claim_lock = NULL, claim_expires = NULL, worker_pid = NULL
+             WHERE id = ? AND status IN ('running', 'ready', 'blocked')
+            """,
+            (task_id,),
+        )
+        if cur.rowcount != 1:
+            return False
+        run_id = kanban._end_run(conn, task_id, outcome="review", status="review", summary=summary)
+        kanban._append_event(conn, task_id, "review_requested", {"summary": summary}, run_id=run_id)
+    return True
+
+
+def accept_task_review(conn: Any, task_id: str, *, actor: str, reason: str) -> tuple[bool, str | None]:
+    kanban = require_kanban()
+    with kanban.write_txn(conn):
+        cur = conn.execute(
+            "UPDATE tasks SET status = 'ready', claim_lock = NULL, claim_expires = NULL, worker_pid = NULL WHERE id = ? AND status = 'review'",
+            (task_id,),
+        )
+        if cur.rowcount != 1:
+            row = conn.execute("SELECT status FROM tasks WHERE id = ?", (task_id,)).fetchone()
+            if row and row["status"] in {"ready", "running", "done"}:
+                return True, None
+            return False, f"task {task_id} is not awaiting review"
+        kanban._append_event(conn, task_id, "review_accepted", {"actor": actor, "reason": reason})
+    return True, None
+
+
+def resume_blocked_task_from_reply(conn: Any, task_id: str, *, actor: str, action: str) -> tuple[bool, str | None, str | None]:
+    """Return a blocked task to ready after Joy supplies requested text."""
+    kanban = require_kanban()
+    with kanban.write_txn(conn):
+        cur = conn.execute(
+            "UPDATE tasks SET status = 'ready', claim_lock = NULL, claim_expires = NULL, worker_pid = NULL WHERE id = ? AND status = 'blocked'",
+            (task_id,),
+        )
+        if cur.rowcount == 1:
+            kanban._append_event(conn, task_id, "unblocked", {"actor": actor, "reason": f"Telegram {action} reply recorded"})
+            return True, None, "ready"
+        row = conn.execute("SELECT status FROM tasks WHERE id = ?", (task_id,)).fetchone()
+        if row and row["status"] in {"ready", "running", "done"}:
+            return True, None, row["status"]
+        if row:
+            return False, f"task {task_id} is {row['status']}, not blocked", row["status"]
+        return False, f"task {task_id} was not found", None
+
