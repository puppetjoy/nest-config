+def test_telegram_freeform_replies_route_to_originating_prompt_not_recency():
+    if not require_hermes_src():
+        return
+    with kanban_env() as tmp:
+        from agent_request_broker import kanban_backend as backend
+
+        old_send = backend.telegram_send
+        deliveries = []
+        backend.telegram_send = lambda message, *, profile="", reply_markup=None: deliveries.append(reply_markup) or {"sent": True, "test": True}
+        try:
+            first = backend.submit({
+                "title": "Generic approval prompt",
+                "request": "First request should receive the reply.",
+                "target": "star",
+            }, requester="talon")
+            second = backend.submit({
+                "title": "Generic approval prompt",
+                "request": "Second request is newer but should stay untouched.",
+                "target": "star",
+            }, requester="talon")
+            first_id = first["request"]["id"]
+            second_id = second["request"]["id"]
+            first_proposal = backend.propose({
+                "request_id": first_id,
+                "summary": "approval-required: first generic prompt",
+                "proposal": "First proposal text.",
+            }, actor="star")
+            second_proposal = backend.propose({
+                "request_id": second_id,
+                "summary": "approval-required: second generic prompt",
+                "proposal": "Second proposal text.",
+            }, actor="star")
+            assert first_proposal["request"]["id"] != second_proposal["request"]["id"]
+
+            markups = [markup for markup in deliveries if markup]
+
+            def steer_token_for(request_id):
+                conn = backend.connect()
+                try:
+                    for markup in markups:
+                        for row in markup["inline_keyboard"]:
+                            for button in row:
+                                if button["text"] != "✏️ Steer / request changes":
+                                    continue
+                                token = button["callback_data"].split(":", 1)[1]
+                                validation = backend.validate_callback_token(conn, token)
+                                if validation.get("ok") and validation["callback"]["request_id"] == request_id:
+                                    return token
+                finally:
+                    conn.close()
+                raise AssertionError(f"no steer token for {request_id}")
+
+            first_steer = steer_token_for(first_id)
+            second_steer = steer_token_for(second_id)
+
+            first_prompt = backend.handle_telegram_callback(
+                first_steer,
+                actor="joy",
+                chat_id="chat-1",
+                thread_id="topic-1",
+                prompt_message_id=111,
+            )
+            assert first_prompt["ok"] is True
+            assert first_prompt["result"]["awaiting_reply"]["request_id"] == first_id
+            second_prompt = backend.handle_telegram_callback(
+                second_steer,
+                actor="joy",
+                chat_id="chat-1",
+                thread_id="topic-1",
+                prompt_message_id=222,
+            )
+            assert second_prompt["ok"] is True
+            assert second_prompt["result"]["awaiting_reply"]["request_id"] == second_id
+
+            ambiguous = backend.handle_telegram_reply(
+                chat_id="chat-1",
+                thread_id="topic-1",
+                text="Approved",
+                actor="joy",
+            )
+            assert ambiguous["handled"] is True
+            assert ambiguous["ok"] is False
+            assert ambiguous["error"] == "ambiguous_prompt"
+            assert first_id in ambiguous["message"]
+            assert second_id in ambiguous["message"]
+            assert "prompt message 111" in ambiguous["message"]
+            assert "prompt message 222" in ambiguous["message"]
+
+            routed_by_id = backend.handle_telegram_reply(
+                chat_id="chat-1",
+                thread_id="topic-1",
+                text=f"{second_id} Please revise the second proposal.",
+                actor="joy",
+            )
+            assert routed_by_id["handled"] is True
+            assert routed_by_id["ok"] is True
+            assert routed_by_id["request_id"] == second_id
+
+            routed = backend.handle_telegram_reply(
+                chat_id="chat-1",
+                thread_id="topic-1",
+                reply_to_message_id=111,
+                text="Approved",
+                actor="joy",
+            )
+            assert routed["handled"] is True
+            assert routed["ok"] is True
+            assert routed["request_id"] == first_id
+            assert routed["task_id"] == first["request"]["kanban_task_id"]
+
+            conn = backend.connect()
+            try:
+                kanban = backend.require_kanban()
+                first_comments = "\n".join(comment.body for comment in kanban.list_comments(conn, first["request"]["kanban_task_id"]))
+                second_comments = "\n".join(comment.body for comment in kanban.list_comments(conn, second["request"]["kanban_task_id"]))
+            finally:
+                conn.close()
+            assert "Joy steering" in first_comments
+            assert "Approved" in first_comments
+            assert "Joy steering" in second_comments
+            assert "Please revise the second proposal" in second_comments
+            assert "Approved" not in second_comments
+        finally:
+            backend.telegram_send = old_send
