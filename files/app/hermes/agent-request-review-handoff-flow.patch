+def record_reply_prompt(
+    conn: Any,
+    *,
+    callback: dict[str, Any],
+    actor: str,
+    chat_id: str,
+    thread_id: str = "",
+    prompt_message_id: int | None = None,
+) -> dict[str, Any]:
+    """Persist a bounded Telegram free-form reply prompt."""
+    prompt_token = _make_callback_token()
+    created_at = now_ts()
+    conn.execute(
+        """
+        INSERT INTO agent_request_reply_prompts
+            (prompt_token, request_id, task_id, action, proposal_comment_id,
+             proposal_hash, actor, chat_id, thread_id, prompt_message_id,
+             created_at, expires_at, used_at)
+        VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, NULL)
+        """,
+        (
+            prompt_token,
+            callback["request_id"],
+            callback["task_id"],
+            callback["action"],
+            callback.get("proposal_comment_id"),
+            callback.get("proposal_hash"),
+            actor,
+            clean_text(chat_id, max_len=80),
+            clean_text(thread_id or "", max_len=80),
+            int(prompt_message_id) if prompt_message_id is not None else None,
+            created_at,
+            created_at + REPLY_PROMPT_TTL_SECONDS,
+        ),
+    )
+    conn.commit()
+    return {
+        "prompt_token": prompt_token,
+        "request_id": callback["request_id"],
+        "task_id": callback["task_id"],
+        "action": callback["action"],
+        "expires_at": created_at + REPLY_PROMPT_TTL_SECONDS,
+    }
+
+
+def _reply_prompt_candidates(
+    conn: Any,
+    *,
+    chat_id: str,
+    thread_id: str = "",
+    reply_to_message_id: int | None = None,
+) -> list[dict[str, Any]]:
+    now = now_ts()
+    chat_id = clean_text(chat_id, max_len=80)
+    thread_id = clean_text(thread_id or "", max_len=80)
+    if reply_to_message_id is not None:
+        rows = conn.execute(
+            """
+            SELECT *
+            FROM agent_request_reply_prompts
+            WHERE chat_id = ?
+              AND prompt_message_id = ?
+              AND used_at IS NULL
+              AND expires_at >= ?
+            ORDER BY created_at DESC
+            """,
+            (chat_id, int(reply_to_message_id), now),
+        ).fetchall()
+    else:
+        rows = conn.execute(
+            """
+            SELECT *
+            FROM agent_request_reply_prompts
+            WHERE chat_id = ?
+              AND thread_id = ?
+              AND used_at IS NULL
+              AND expires_at >= ?
+            ORDER BY created_at DESC
+            LIMIT 2
+            """,
+            (chat_id, thread_id, now),
+        ).fetchall()
+    return [dict(row) for row in rows]
+
+
+def _mark_reply_prompt_used(conn: Any, prompt_token: str) -> None:
+    conn.execute("UPDATE agent_request_reply_prompts SET used_at = ? WHERE prompt_token = ?", (now_ts(), prompt_token))
+    conn.commit()
