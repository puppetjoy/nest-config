+def test_archive_completed_requests_dry_run_then_apply():
+    if not require_hermes_src():
+        return
+    with kanban_env("archive-completed-test"):
+        from agent_request_broker import kanban_backend as backend
+
+        old_send = backend.telegram_send
+        backend.telegram_send = lambda message: {"sent": True, "test": True, "message": message}
+        try:
+            old = backend.submit({
+                "title": "Old completed real task",
+                "request": "This completed task is beyond the retention window",
+                "target": "talon",
+            }, requester="talon")["request"]
+            recent = backend.submit({
+                "title": "Recent completed real task",
+                "request": "This completed task is still inside retention",
+                "target": "talon",
+            }, requester="talon")["request"]
+        finally:
+            backend.telegram_send = old_send
+
+        kb = backend.require_kanban()
+        conn = backend.connect()
+        try:
+            assert kb.complete_task(conn, old["kanban_task_id"], summary="done")
+            assert kb.complete_task(conn, recent["kanban_task_id"], summary="done")
+            now = backend.now_ts()
+            old_completed_at = now - 20 * 24 * 60 * 60
+            conn.execute("UPDATE tasks SET completed_at = ? WHERE id = ?", (old_completed_at, old["kanban_task_id"]))
+            conn.execute("UPDATE tasks SET completed_at = ? WHERE id = ?", (now, recent["kanban_task_id"]))
+            conn.commit()
+        finally:
+            conn.close()
+
+        dry_run = backend.archive_completed_requests({"retention_days": 14}, actor="talon")
+        assert dry_run["dry_run"] is True
+        assert dry_run["candidate_count"] == 1
+        assert dry_run["candidates"][0]["request_id"] == old["id"]
+        assert dry_run["archived_count"] == 0
+
+        conn = backend.connect()
+        try:
+            assert kb.get_task(conn, old["kanban_task_id"]).status == "done"
+        finally:
+            conn.close()
+
+        applied = backend.archive_completed_requests({"retention_days": 14, "apply": True}, actor="talon")
+        assert applied["dry_run"] is False
+        assert applied["archived_count"] == 1
+
+        conn = backend.connect()
+        try:
+            assert kb.get_task(conn, old["kanban_task_id"]).status == "archived"
+            assert kb.get_task(conn, recent["kanban_task_id"]).status == "done"
+            visible_done = kb.list_tasks(conn, status="done", include_archived=False)
+            assert {task.id for task in visible_done} == {recent["kanban_task_id"]}
+            archived = kb.list_tasks(conn, status="archived", include_archived=True)
+            assert {task.id for task in archived} == {old["kanban_task_id"]}
+            shown = backend.public_request(conn, backend.index_for_request(conn, old["id"]))
+            assert shown["status"] == "completed"
+            assert shown["kanban_status"] == "archived"
+        finally:
+            conn.close()
