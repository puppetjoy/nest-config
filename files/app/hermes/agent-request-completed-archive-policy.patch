+#!/usr/bin/env python3
+"""Dry-run-first archival for old completed Agent Requests tasks."""
+from __future__ import annotations
+
+import argparse
+import json
+import os
+import sys
+from pathlib import Path
+
+ROOT = Path(__file__).resolve().parents[1]
+HERMES_SRC = Path(os.environ.get("HERMES_SRC", "/opt/hermes-agent/src"))
+if HERMES_SRC.exists() and HERMES_SRC != ROOT / "src":
+    sys.path.insert(0, str(HERMES_SRC))
+sys.path.insert(0, str(ROOT / "src"))
+
+from agent_request_broker import kanban_backend  # noqa: E402
+
+
+def parser() -> argparse.ArgumentParser:
+    p = argparse.ArgumentParser(
+        description="Archive old completed Agent Requests Kanban tasks; dry-run by default.",
+    )
+    p.add_argument("--board", default="agent-requests", help="Kanban board slug, default: agent-requests")
+    p.add_argument("--retention-days", type=int, default=kanban_backend.DEFAULT_COMPLETED_ARCHIVE_RETENTION_DAYS, help="Archive completed tasks older than this many days; default: %(default)s")
+    p.add_argument("--limit", type=int, help="Maximum candidates to inspect/apply")
+    p.add_argument("--apply", action="store_true", help="Actually archive candidates. Omit for dry-run.")
+    p.add_argument("--cleanup-resources", action="store_true", help="After archiving, run terminal worktree/branch cleanup for archived tasks")
+    p.add_argument("--actor", default="talon", help="Operator identity to record, default: talon")
+    p.add_argument("--json", action="store_true", help="Print full JSON result")
+    return p
+
+
+def main(argv: list[str] | None = None) -> int:
+    args = parser().parse_args(argv)
+    if args.board:
+        os.environ["AGENT_REQUEST_KANBAN_BOARD"] = args.board
+    result = kanban_backend.archive_completed_requests(
+        {
+            "retention_days": args.retention_days,
+            "limit": args.limit,
+            "apply": args.apply,
+            "cleanup_resources": args.cleanup_resources,
+        },
+        actor=args.actor,
+    )
+    if args.json:
+        print(json.dumps(result, ensure_ascii=False, indent=2))
+    elif "error" in result:
+        print(f"error: {result['error']}", file=sys.stderr)
+    else:
+        mode = "dry-run" if result.get("dry_run") else "applied"
+        print(
+            f"{mode} archive-completed on {result['board']}: "
+            f"candidates={result['candidate_count']} archived={result['archived_count']} "
+            f"retention_days={result['retention_days']}"
+        )
+        for item in (result.get("candidates") or [])[:10]:
+            print(f"candidate {item['request_id']} task={item['task_id']} completed_at={item['completed_at']} title={item['title']}")
+        if result.get("candidate_count", 0) > 10:
+            print(f"... {result['candidate_count'] - 10} more candidates")
+    return 1 if "error" in result else 0
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
