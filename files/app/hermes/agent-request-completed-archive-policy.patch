+
+def _completed_archive_cutoff(*, retention_days: int, now: int | None = None) -> int:
+    days = max(int(retention_days), 1)
+    return int(now if now is not None else now_ts()) - days * 24 * 60 * 60
+
+
+def completed_archive_candidates(conn: Any, *, retention_days: int = DEFAULT_COMPLETED_ARCHIVE_RETENTION_DAYS, limit: int | None = None, now: int | None = None) -> list[dict[str, Any]]:
+    cutoff = _completed_archive_cutoff(retention_days=retention_days, now=now)
+    sql = """
+        SELECT
+            t.id AS task_id,
+            t.title AS title,
+            t.status AS kanban_status,
+            t.created_at AS created_at,
+            t.completed_at AS completed_at,
+            i.request_id AS request_id,
+            i.status AS request_status,
+            i.requester AS requester,
+            i.target AS target
+        FROM tasks t
+        JOIN agent_request_index i ON i.task_id = t.id
+        WHERE t.status = 'done'
+          AND COALESCE(t.completed_at, t.created_at) <= ?
+        ORDER BY COALESCE(t.completed_at, t.created_at) ASC, t.created_at ASC, t.id ASC
+    """
+    params: list[Any] = [cutoff]
+    if limit is not None:
+        sql += " LIMIT ?"
+        params.append(max(int(limit), 1))
+    return [dict(row) for row in conn.execute(sql, params).fetchall()]
+
+
+def archive_completed_requests(args: dict[str, Any], *, actor: str = "talon") -> dict[str, Any]:
+    """Dry-run-first archival for old completed Agent Requests tasks."""
+    if actor != "talon":
+        return {"error": "Only Talon/operator may archive completed agent-request tasks"}
+    retention_days = int(args.get("retention_days") or DEFAULT_COMPLETED_ARCHIVE_RETENTION_DAYS)
+    if retention_days < 1:
+        return {"error": "retention_days must be >= 1"}
+    limit_arg = args.get("limit")
+    limit = int(limit_arg) if limit_arg is not None else None
+    if limit is not None and limit < 1:
+        return {"error": "limit must be >= 1"}
+    apply = bool(args.get("apply", False))
+    cleanup_resources = bool(args.get("cleanup_resources", False))
+    conn = connect()
+    try:
+        kanban = require_kanban()
+        candidates = completed_archive_candidates(conn, retention_days=retention_days, limit=limit)
+        archived: list[dict[str, Any]] = []
+        cleanups: list[dict[str, Any]] = []
+        if apply:
+            for candidate in candidates:
+                did_archive = kanban.archive_task(conn, candidate["task_id"])
+                archived_item = {**candidate, "archived": did_archive}
+                archived.append(archived_item)
+                if did_archive and cleanup_resources:
+                    cleanups.append(cleanup_terminal_task_resources(conn, task_id=candidate["task_id"], actor=actor))
+        cutoff = _completed_archive_cutoff(retention_days=retention_days)
+        return {
+            "board": board_name(),
+            "dry_run": not apply,
+            "retention_days": retention_days,
+            "cutoff": cutoff,
+            "candidate_count": len(candidates),
+            "archived_count": sum(1 for item in archived if item.get("archived")),
+            "candidates": candidates,
+            "archived": archived,
+            "cleanup_resources": cleanup_resources,
+            "cleanups": cleanups,
+            "policy": {
+                "default_retention_days": DEFAULT_COMPLETED_ARCHIVE_RETENTION_DAYS,
+                "archive_scope": "agent_request_index tasks with Kanban status done older than the retention window",
+                "delete_scope": "none; deletion remains reserved for explicit smoke/test artifact or sensitive-accident cleanup with backup",
+                "dry_run_first": True,
+            },
+        }
+    finally:
+        conn.close()
+
 def urgency_to_priority(urgency: str) -> int:
     return URGENCY_PRIORITIES[urgency]
 
