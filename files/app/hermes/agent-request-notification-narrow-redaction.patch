+def redact_notification_line(line: str) -> tuple[str, bool]:
+    def replace(match: re.Match[str]) -> str:
+        if match.group("blob"):
+            return f"{match.group('blob')}: [redacted sensitive content]"
+        if match.group("bearer"):
+            return "Bearer [redacted secret]"
+        key = match.group("key") or "sensitive value"
+        sep = match.group("sep") or "="
+        spacer = " " if sep == ":" else ""
+        return f"{key}{sep}{spacer}[redacted secret]"
+
+    redacted = SENSITIVE_NOTIFICATION_VALUE_RE.sub(replace, line)
+    return redacted, redacted != line
+
