+def test_board_columns_include_review_metadata(client):
+    r = client.get("/api/plugins/kanban/board")
+    assert r.status_code == 200
+    columns = {c["name"]: c for c in r.json()["columns"]}
+
+    assert columns["review"]["label"] == "Review"
+    assert columns["review"]["description"] == "Awaiting human review"
+
+
+def test_dashboard_bundle_has_review_lane_metadata():
+    repo_root = Path(__file__).resolve().parents[2]
+    bundle = repo_root / "plugins" / "kanban" / "dashboard" / "dist" / "index.js"
+    css = repo_root / "plugins" / "kanban" / "dashboard" / "dist" / "style.css"
+    js = bundle.read_text()
+
+    assert 'review: "Review"' in js
+    assert 'review: "Awaiting human review"' in js
+    assert 'review: "hermes-kanban-dot-review"' in js
+    assert ".hermes-kanban-dot-review" in css.read_text()
 
 
