+def _latest_comment_row(conn: Any, task_id: str) -> dict[str, Any] | None:
+    row = conn.execute(
+        "SELECT id, author, body, created_at FROM task_comments WHERE task_id = ? ORDER BY created_at DESC, id DESC LIMIT 1",
+        (task_id,),
+    ).fetchone()
+    return dict(row) if row else None
+
+
+def _extract_handoff_field(text: str, *labels: str) -> str:
+    for label in labels:
+        pattern = rf"(?im)^\s*(?:[-*]\s*)?{re.escape(label)}\s*:\s*(?:`([^`]+)`|(.+?))\s*$"
+        match = re.search(pattern, text)
+        if match:
+            return clean_text(match.group(1) or match.group(2), max_len=2000)
+    return ""
+
+
+def _extract_handoff_section(text: str, *labels: str, max_len: int = 4000) -> str:
+    for label in labels:
+        pattern = rf"(?ims)^\s*(?:[-*]\s*)?{re.escape(label)}\s*:\s*\n(?P<body>.*?)(?=\n\s*\n\S|\Z)"
+        match = re.search(pattern, text)
+        if match:
+            lines = [line.strip() for line in match.group("body").strip().splitlines()]
+            lines = [line.lstrip("-•* ").strip() for line in lines if line.strip()]
+            return sanitize_notification_text("; ".join(lines), max_len=max_len)
+    return ""
+
+
+def _direct_fallback_review_details(task: Any, comment: dict[str, Any] | None, summary: str) -> dict[str, str]:
+    body = clean_text(comment.get("body") if comment else "", max_len=12000)
+    return {
+        "worktree_path": _extract_handoff_field(body, "Worktree") or clean_text(getattr(task, "workspace_path", ""), max_len=2000),
+        "branch_name": _extract_handoff_field(body, "Branch"),
+        "commit_refs": _extract_handoff_field(body, "Commit", "Commit refs", "Commit SHAs"),
+        "changed_files": _extract_handoff_section(body, "Changed files", max_len=4000) or sanitize_notification_text(summary, max_len=4000),
+        "tests_run": _extract_handoff_section(body, "Checks run", "Validation run", "Tests/checks run", max_len=4000) or "not specified in direct Kanban fallback review handoff",
+        "remaining_actions": _extract_handoff_section(body, "Remaining actions", "Actions authorized after acceptance", max_len=4000) or sanitize_notification_text(summary, max_len=4000),
+        "side_effects_deferred": _extract_handoff_section(body, "Deferred side effects", "Side effects deferred", "Side effects intentionally deferred", max_len=4000) or "direct Kanban fallback review handoff; see task comment for deferred side effects",
+    }
