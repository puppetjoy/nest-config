+def maybe_register_direct_kanban_fallback_review(conn: Any, task_id: str, *, actor: str, summary: str) -> AgentRequestIndex | None:
+    task = require_kanban().get_task(conn, task_id)
+    if task is None:
+        return None
+    body = clean_text(getattr(task, "body", ""), max_len=12000)
