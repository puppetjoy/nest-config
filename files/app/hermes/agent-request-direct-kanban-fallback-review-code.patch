+        status=REVIEW_REQUESTED,
+        created_at=int(getattr(task, "created_at", 0) or now_ts()),
+        updated_at=now_ts(),
+        title_raw=title,
+        title_display=title,
+        subject_raw=title,
+        subject_display=title,
+    )
+    write_index(conn, item)
+    if latest_review(conn, request_id) is None:
+        comment = _latest_comment_row(conn, task_id)
+        details = _direct_fallback_review_details(task, comment, summary)
+        comment_id = int(comment["id"]) if comment else 0
+        record_review_handoff(
+            conn,
+            request_id=request_id,
+            comment_id=comment_id,
+            requested_by=actor or "talon",
+            **details,
+        )
+    return item
+
