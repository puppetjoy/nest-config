+def _reclassify_legacy_prose_payload(payload: dict, cfg: dict) -> dict:
+    """Reclassify pre-cross-board prose diagnostics at render time.
+
+    Older ``suspected_hallucinated_references`` events only persisted
+    ``phantom_refs``. When the caller supplies a bounded resolver, move ids
+    that now resolve outside the current board into ``cross_board_refs`` while
+    leaving true missing-everywhere ids in ``phantom_refs``.
+    """
+    if not isinstance(payload, dict):
+        return {}
+    raw_phantom_refs = payload.get("phantom_refs", []) or []
+    phantom_refs: list[str] = []
+    for ref in raw_phantom_refs:
+        if isinstance(ref, str) and ref not in phantom_refs:
+            phantom_refs.append(ref)
+    if not phantom_refs or payload.get("cross_board_refs") is not None:
+        return payload
+
+    resolver = cfg.get("prose_ref_resolver")
+    if not callable(resolver):
+        return payload
+    try:
+        resolved = resolver(phantom_refs)
+    except Exception:
+        return payload
+    if not isinstance(resolved, list) or not resolved:
+        return payload
+
+    cross_board_refs: list[dict] = []
+    for ref in resolved:
+        if not isinstance(ref, dict):
+            continue
+        tid = ref.get("id")
+        if tid and tid in phantom_refs and all(existing.get("id") != tid for existing in cross_board_refs):
+            cross_board_refs.append(ref)
+    if not cross_board_refs:
+        return payload
+
+    cross_ids = {ref.get("id") for ref in cross_board_refs}
+    out = dict(payload)
+    out["phantom_refs"] = [ref for ref in phantom_refs if ref not in cross_ids]
+    out["cross_board_refs"] = cross_board_refs
+    if not out.get("current_board") and cfg.get("current_board"):
+        out["current_board"] = cfg.get("current_board")
+    return out
+
+
