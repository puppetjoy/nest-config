+def test_legacy_prose_payload_is_reclassified_with_resolver():
+    task = _task(status="done")
+    events = [
+        _event("completed", ts=100, summary="legacy payload"),
+        _event(
+            "suspected_hallucinated_references",
+            ts=101,
+            phantom_refs=["t_deadbeef99", "t_badbadbad"],
+            source="completion_summary",
+        ),
+    ]
+
+    def resolver(ids):
+        assert ids == ["t_deadbeef99", "t_badbadbad"]
+        return [{
+            "id": "t_deadbeef99",
+            "board": "default",
+            "db": "legacy/default Kanban DB",
+        }]
+
+    diags = kd.compute_task_diagnostics(
+        task,
+        events,
+        [],
+        config={
+            "prose_ref_resolver": resolver,
+            "current_board": "agent-requests",
+        },
+    )
+    assert len(diags) == 1
+    d = diags[0]
+    assert d.title == "Completion summary has unresolved and cross-board task ids"
+    assert d.data["phantom_refs"] == ["t_badbadbad"]
+    assert d.data["cross_board_refs"] == [{
+        "id": "t_deadbeef99",
+        "board": "default",
+        "db": "legacy/default Kanban DB",
+    }]
+
