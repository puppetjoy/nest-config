+def test_notification_adapter_notifies_registered_child_task_events():
+    if not require_hermes_src():
+        return
+    with kanban_env():
+        from agent_request_broker import kanban_backend as backend
+        from hermes_cli import kanban_db as kb
+
+        old_send = backend.telegram_send
+        messages = []
+        sends = []
+
+        def fake_send(message, **kwargs):
+            messages.append(message)
+            sends.append(kwargs)
+            return {"sent": True, "test": True}
+
+        backend.telegram_send = fake_send
+        try:
+            parent = backend.submit({
+                "title": "Parent request with silent child",
+                "request": "Coordinate a child task that can require Joy attention.",
+                "target": "talon",
+            }, requester="star")["request"]
+            parent_task_id = parent["kanban_task_id"]
+
+            conn = backend.connect()
+            try:
+                child_task_id = kb.create_task(
+                    conn,
+                    title="Child review handoff needing Joy",
+                    body="Implementation review handoff for the child task.",
+                    assignee="talon",
+                    created_by="talon",
+                    tenant=backend.TENANT,
+                    parents=[parent_task_id],
+                    initial_status="blocked",
+                    board=backend.board_name(),
+                )
+                parent_item = backend.index_for_request(conn, parent["id"])
+                backend.record_child_disposition(
+                    conn,
+                    parent=parent_item,
+                    child_task_id=child_task_id,
+                    classification="nonblocking_followup",
+                    reason="Child can require its own Joy review after the parent spawned it.",
+                    actor="talon",
+                )
+            finally:
+                conn.close()
+
+            notified = backend.notify_kanban_event(
+                task_id=child_task_id,
+                action="blocked",
+                actor="talon",
+                summary="review-required: child implementation needs Joy review",
+                event_id=300,
+            )
+
+            assert notified["notified"] is True
+            assert {item["profile"] for item in notified["notifications"]} == {"star", "talon"}
+            child_messages = [message for message in messages if child_task_id in message]
+            assert len(child_messages) == 2
+            for message in child_messages:
+                assert "Agent request blocked" in message
+                assert "Child review handoff needing Joy" in message
+                assert parent["id"] in message
+                assert f"Task: {child_task_id}" in message
+                assert f"parent request {parent['id']} ({parent_task_id})" in message
+                assert "classification=nonblocking_followup" in message
+                assert "review-required: child implementation needs Joy review" in message
+            assert all(kwargs.get("reply_markup") for kwargs in sends[-2:])
+            assert all(kwargs.get("disable_notification") is False for kwargs in sends[-2:])
+
+            conn = backend.connect()
+            try:
+                rows = conn.execute(
+                    "SELECT request_id, task_id, action, delivered, event_key FROM agent_request_notifications WHERE task_id = ? ORDER BY event_key",
+                    (child_task_id,),
+                ).fetchall()
+                callback_rows = conn.execute(
+                    "SELECT request_id, task_id, action FROM agent_request_callback_tokens WHERE task_id = ? ORDER BY action",
+                    (child_task_id,),
+                ).fetchall()
+            finally:
+                conn.close()
+            assert len(rows) == 2
+            assert {row["request_id"] for row in rows} == {parent["id"]}
+            assert {row["task_id"] for row in rows} == {child_task_id}
+            assert {row["action"] for row in rows} == {"blocked"}
+            assert all(row["delivered"] == 1 for row in rows)
+            assert {row["event_key"].rsplit(":", 1)[1] for row in rows} == {"star", "talon"}
+            assert {row["request_id"] for row in callback_rows} == {parent["id"]}
+            assert {row["task_id"] for row in callback_rows} == {child_task_id}
+            assert {row["action"] for row in callback_rows} == {"needs_info_answer"}
+        finally:
+            backend.telegram_send = old_send
+
