+def _create_guard_board_slug(conn: sqlite3.Connection, board: Optional[str]) -> Optional[str]:
+    """Best-effort board slug for create-time policy guards."""
+    normed = _normalize_board_slug(board)
+    if normed:
+        return normed
+    env_board = os.environ.get("HERMES_KANBAN_BOARD", "").strip()
+    if env_board:
+        try:
+            return _normalize_board_slug(env_board)
+        except ValueError:
+            return None
+    db_path = os.environ.get("HERMES_KANBAN_DB", "").strip()
+    if not db_path:
+        try:
+            row = conn.execute("PRAGMA database_list").fetchone()
+            if row is not None:
+                db_path = str(row["file"] if "file" in row.keys() else row[2])
+        except Exception:
+            db_path = ""
+    if db_path and os.path.basename(db_path) == "kanban.db":
+        parent = os.path.basename(os.path.dirname(db_path))
+        if parent:
+            try:
+                return _normalize_board_slug(parent)
+            except ValueError:
+                return None
+    try:
+        return get_current_board()
+    except Exception:
+        return None
+
+
+def _is_smoke_task_shape(*, title: str, assignee: Optional[str], created_by: Optional[str]) -> bool:
+    title_text = str(title or "").casefold()
+    assignee_text = str(assignee or "").casefold()
+    created_by_text = str(created_by or "").casefold()
+    smoke_tokens = (
+        "dev smoke",
+        "dev-smoke",
+        "smoke",
+        "synthetic",
+        "review-required-smoke",
+        "live-review-required-smoke",
+    )
+    creator_tokens = ("watchdog-smoke", "smoke", "synthetic", "test")
+    return (
+        assignee_text == "test-worker"
+        or any(token in title_text for token in smoke_tokens)
+        or any(token in created_by_text for token in creator_tokens)
+    )
+
+
+def _reject_prod_agent_requests_smoke_task(
+    conn: sqlite3.Connection,
+    *,
+    board: Optional[str],
+    title: str,
+    assignee: Optional[str],
+    created_by: Optional[str],
+) -> None:
+    if os.environ.get("HERMES_ALLOW_PROD_KANBAN_SMOKE") == "1":
+        return
+    if _create_guard_board_slug(conn, board) != "agent-requests":
+        return
+    if not _is_smoke_task_shape(title=title, assignee=assignee, created_by=created_by):
+        return
+    raise ValueError(
+        "refusing to create live/smoke/test-worker task on production "
+        "agent-requests board; pass board='agent-requests-dev' or use an "
+        "isolated temporary board, and visibly label the task as DEV/test"
+    )
+
+
