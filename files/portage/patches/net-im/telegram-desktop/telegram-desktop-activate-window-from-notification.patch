+void ActivateWindowFromNotification(QWindow *window) {
+#ifndef DESKTOP_APP_DISABLE_X11_INTEGRATION
+	if (!window) {
+		return;
+	}
+
+	const base::Platform::XCB::Connection connection;
+	if (!connection || xcb_connection_has_error(connection)) {
+		return;
+	}
+
+	const auto root = base::Platform::XCB::GetRootWindow(connection);
+	if (!root) {
+		return;
+	}
+
+	const auto activeWindowAtom = base::Platform::XCB::GetAtom(
+		connection,
+		"_NET_ACTIVE_WINDOW");
+	if (!activeWindowAtom) {
+		return;
+	}
+
+	xcb_client_message_event_t event = {};
+	event.response_type = XCB_CLIENT_MESSAGE;
+	event.type = activeWindowAtom;
+	event.window = window->winId();
+	event.format = 32;
+	event.data.data32[0] = 1; // source indication: application
+	event.data.data32[1] = XCB_CURRENT_TIME;
+	event.data.data32[2] = 0;
+
+	free(
+		xcb_request_check(
+			connection,
+			xcb_send_event_checked(
+				connection,
+				false,
+				root,
+				XCB_EVENT_MASK_SUBSTRUCTURE_REDIRECT
+					| XCB_EVENT_MASK_SUBSTRUCTURE_NOTIFY,
+				reinterpret_cast<const char*>(&event))));
+	xcb_flush(connection);
+#endif // !DESKTOP_APP_DISABLE_X11_INTEGRATION
+}
